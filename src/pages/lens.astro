---
import Base from '../layouts/Base.astro';
import SEOHead from '../components/SEOHead.astro';
import FocusObject from '../components/FocusObject.astro';
import { url } from '../utils/paths';
---
<Base
  title="The Lens. Your AI marketing team"
  description="Senior marketing operators distilled into 26 Claude Code skills that read your brand context and ship the work alongside you."
>
  <SEOHead
    slot="seo"
    type="service"
    title="The Lens. Your AI marketing team"
    description="Senior marketing operators distilled into 26 Claude Code skills that read your brand context and ship the work alongside you."
    breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'The Lens', url: '/lens' }]}
  />

  <!-- HERO -->
  <section class="section lens-hero dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={420} tiltX={62} tiltY={-18} spin={140} scrollSpin={-80} style="top: 4%; right: -6%;" enterFrom="right" />
      <FocusObject size={260} tiltX={55} tiltY={20} spin={-110} scrollSpin={90} style="bottom: -8%; left: -10%;" enterFrom="left" />

      <div class="container lens-hero-inner">
        <div class="eyebrow reveal">000 · THE LENS</div>
        <h1 class="lens-headline reveal">
          Your AI<br/>
          <span class="gradient-text">marketing team</span>.
        </h1>
        <p class="lens-lead reveal">
          Senior marketing operators distilled into 26 Claude Code skills
          that read your brand context and ship the work alongside you.
          Forty-six playbooks across brand, demand, content, ops and
          productivity. Free to read, free to install, refreshed as the
          models shift.
        </p>
        <div class="lens-ctas reveal">
          <a href={url('/lens/start-here')} class="btn-cta">Start here</a>
          <a href={url('/lens/library')} class="btn-ghost">Browse the library</a>
        </div>
        <p class="lens-secondary-links reveal">
          New to AI? Read the <a href={url('/lens/primer')}>prompting 101</a> or the <a href={url('/lens/cowork')}>Cowork setup primer</a>.
        </p>
        <p class="lens-meta mono reveal">FREE · 46 playbooks · 26 skills · Endurance focus · Updated as the models shift</p>
      </div>
    </div>
  </section>

  <!-- THE GAP -->
  <section class="section section-alt dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={320} tiltX={60} tiltY={-22} spin={150} scrollSpin={-70} style="top: 8%; left: 4%;" enterFrom="left" />
      <div class="container">
        <div class="eyebrow">001 · THE GAP</div>
        <h2 class="big-statement reveal" data-scroll-scale style="transform-origin: left center;">
          Most senior marketers<br/>
          are using AI <span class="gradient-text">like a typewriter</span>.
        </h2>
        <div class="lens-grid">
          <p class="reveal">
            They draft a meta description in ChatGPT. They Midjourney a stock-photo
            replacement. They sit through webinars about agents and walk away
            with a list of tools they'll never actually wire up. The pipeline
            still looks like 2020 with a faster pen.
          </p>
          <p class="reveal">
            The operators a step ahead are using AI as a team. Briefs that
            self-iterate. Content systems that run themselves. Pipelines that
            improve every time a new model ships. The difference isn't talent
            or budget, it's having seen the workflow written down with all
            the failure modes labelled.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IT IS -->
  <section class="section dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={360} tiltX={58} tiltY={18} spin={-130} scrollSpin={100} style="top: 6%; right: 4%;" enterFrom="right" />
      <div class="container">
        <div class="eyebrow">002 · WHAT IT IS</div>
        <h2 class="reveal">A living library, not a course you finish.</h2>
        <p class="lead reveal">
          The Lens is a curated reference for senior marketers. Each entry is
          a complete AI workflow with the prompts, the eval gates, the
          failure modes and a worked example walked through end to end.
          No ninety-minute video that loses relevance the moment a new
          model lands.
        </p>

        <div class="lens-pillars stagger">
          <article class="lens-pillar">
            <div class="pillar-num mono">/A</div>
            <h3>Executable, not theoretical</h3>
            <p>
              Every playbook is shipped as a step-by-step workflow with
              click-paths through the tools you already use, copy-paste
              prompts, downloadable templates and a worked example walked
              through end to end. No "what if you tried" content, only
              workflows you can run today.
            </p>
          </article>
          <article class="lens-pillar">
            <div class="pillar-num mono">/B</div>
            <h3>Eval gates and failure modes named</h3>
            <p>
              Prompts are the easy part. Each entry ships with the
              quality checks the workflow should pass before output goes
              live, the common ways the workflow breaks, and the signals
              that tell you which is happening. Swap the model, re-run
              the checks, ship.
            </p>
          </article>
          <article class="lens-pillar">
            <div class="pillar-num mono">/C</div>
            <h3>Refreshed as the models shift</h3>
            <p>
              When a frontier model lands, the affected workflows get
              re-tested and the entries get updated. If a model change
              breaks a workflow the entry is annotated with what changed
              and what the new shape looks like. The library stays
              current instead of going stale.
            </p>
          </article>
          <article class="lens-pillar">
            <div class="pillar-num mono">/D</div>
            <h3>Search-first, browse second</h3>
            <p>
              Filter by channel, by brand stage, by output type, by model.
              You're not reading the library cover to cover, you're pulling
              the playbook you need for the brief on your desk this week.
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- PICK YOUR STARTING POINT -->
  <section class="section lens-first-time">
    <div class="container">
      <div class="eyebrow">003 · PICK YOUR STARTING POINT</div>
      <h2 class="reveal lens-first-headline">Two questions. Twenty seconds. Your starter playbook.</h2>
      <p class="lens-first-lead reveal">
        The Lens is 46 playbooks. Most readers don't need 46, they need
        the right one for the work in front of them. Answer two
        questions and the diagnostic lands you on it.
      </p>

      <div class="lens-diagnostic reveal" data-diagnostic>
        <div class="diag-step" data-diag-step="1">
          <p class="diag-q">What's the work in front of you this week?</p>
          <div class="diag-options" data-diag-options="1"></div>
        </div>
        <div class="diag-step" data-diag-step="2" hidden>
          <p class="diag-q" data-diag-q2></p>
          <div class="diag-options" data-diag-options="2"></div>
          <button type="button" class="diag-back mono" data-diag-back>← BACK</button>
        </div>
        <div class="diag-step diag-result" data-diag-step="3" hidden>
          <div class="diag-result-tag mono">YOUR STARTER</div>
          <h3 class="diag-result-title" data-diag-title></h3>
          <p class="diag-result-why" data-diag-why></p>
          <p class="diag-result-meta mono" data-diag-meta></p>
          <div class="diag-result-ctas">
            <a href="#" class="btn-cta" data-diag-link>Open the playbook</a>
            <button type="button" class="btn-ghost" data-diag-restart>Start again</button>
          </div>
        </div>
      </div>

      <p class="lens-first-divider mono reveal">OR BROWSE THE COMMON STARTING POINTS</p>

      <div class="lens-first-grid stagger">
        <a href={url('/lens/brand/positioning-audit-pipeline')} class="first-card">
          <div class="first-card-tag mono">START WITH</div>
          <h3>I've inherited a brand and need an honest read</h3>
          <p>Positioning audit, voice extraction, message house. Five to ten working days end to end.</p>
          <span class="first-card-cue mono">POSITIONING AUDIT →</span>
        </a>
        <a href={url('/lens/content/eval-gated-drafting')} class="first-card">
          <div class="first-card-tag mono">START WITH</div>
          <h3>I need to ship more content without losing the brand</h3>
          <p>Eval-gated drafting feeding a social factory. Drafts pass voice, fact and originality gates before a human sees them.</p>
          <span class="first-card-cue mono">EVAL-GATED DRAFTING →</span>
        </a>
        <a href={url('/lens/ops/brief-to-ship-pipeline')} class="first-card">
          <div class="first-card-tag mono">START WITH</div>
          <h3>The team ships but the system around it is chaos</h3>
          <p>Brief-to-ship pipeline. Structured intake, weekly triage, weekly shipping cadence. Replaces ten tools.</p>
          <span class="first-card-cue mono">BRIEF-TO-SHIP →</span>
        </a>
        <a href={url('/lens/demand/channel-mix-simulator')} class="first-card">
          <div class="first-card-tag mono">START WITH</div>
          <h3>I need to defend a budget allocation to the CFO</h3>
          <p>Channel-mix simulator with reach-curve fitting. Walk into the meeting with three scenarios and the maths.</p>
          <span class="first-card-cue mono">CHANNEL-MIX SIMULATOR →</span>
        </a>
        <a href={url('/lens/productivity/daily-briefing-pipeline')} class="first-card">
          <div class="first-card-tag mono">START WITH</div>
          <h3>My day is reactive and I want it back</h3>
          <p>Daily briefing pipeline. Calendar plus inbox plus Slack plus CRM stitched into a five-minute morning brief.</p>
          <span class="first-card-cue mono">DAILY BRIEFING →</span>
        </a>
        <a href={url('/lens/start-here')} class="first-card first-card-fallback">
          <div class="first-card-tag mono">OR</div>
          <h3>None of those, show me the full guide</h3>
          <p>The "Start here" page has the by-situation lookup table, plus the four starting paths and the install path.</p>
          <span class="first-card-cue mono">FULL GUIDE →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- THE STACKS -->
  <section class="section section-alt dwell-pin" id="stacks">
    <div class="dwell-pin-stage">
      <FocusObject size={280} tiltX={50} tiltY={-15} spin={120} scrollSpin={-110} style="top: 8%; right: 5%;" enterFrom="right" />
      <div class="container">
        <div class="eyebrow">004 · THE STACKS</div>
        <h2 class="reveal">Five stacks. Each one growing.</h2>
        <p class="lead reveal">
          The library is organised by what you're trying to ship, not by
          tool. Pull what you need, ignore the rest.
        </p>
        <div class="lens-stacks stagger">
          <a href={url('/lens/brand')} class="lens-stack">
            <div class="stack-num mono">STACK · BRAND</div>
            <h3>Brand &amp; positioning</h3>
            <p>
              Positioning audits, naming sprints, brand-voice extraction,
              endurance brand voice, message houses, tagline systems,
              founder vs institutional voice.
            </p>
            <p class="stack-count mono">7 playbooks · growing →</p>
          </a>
          <a href={url('/lens/demand')} class="lens-stack">
            <div class="stack-num mono">STACK · DEMAND</div>
            <h3>Demand &amp; growth</h3>
            <p>
              Channel-mix, race-day demand, ambassador programmes, event
              sponsorship, retail partner programmes, subscription /
              membership, direct-to-coach, lifecycle journeys, CEP research.
            </p>
            <p class="stack-count mono">11 playbooks · growing →</p>
          </a>
          <a href={url('/lens/content')} class="lens-stack">
            <div class="stack-num mono">STACK · CONTENT</div>
            <h3>Content &amp; channels</h3>
            <p>
              SEO clusters, eval-gated drafting, earned-media pitches,
              social factories, training-content engines, race-result
              automation, segment b-roll, the AI-news pipeline.
            </p>
            <p class="stack-count mono">9 playbooks · growing →</p>
          </a>
          <a href={url('/lens/ops')} class="lens-stack">
            <div class="stack-num mono">STACK · OPS</div>
            <h3>Operating systems</h3>
            <p>
              Brief-to-ship pipelines, gear-launch sequences, end-of-season
              inventory, crash-replacement programmes, brand guardrails as
              code, customer content rights, evaluation frameworks, hiring.
            </p>
            <p class="stack-count mono">9 playbooks · growing →</p>
          </a>
          <a href={url('/lens/productivity')} class="lens-stack">
            <div class="stack-num mono">STACK · PRODUCTIVITY</div>
            <h3>Productivity &amp; back office</h3>
            <p>
              Daily briefings, email triage, meeting prep, call follow-up,
              pipeline rollups, OKR synthesis. The personal-assistant workflows
              that turn Cowork into a real second brain.
            </p>
            <p class="stack-count mono">10 playbooks · growing →</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ACCESS -->
  <section class="section section-alt dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={300} tiltX={50} tiltY={-18} spin={130} scrollSpin={-100} style="top: 6%; right: -6%;" enterFrom="right" />
      <div class="container">
        <div class="eyebrow">005 · FREE TO READ, SUBSCRIBE FOR UPDATES</div>
        <h2 class="reveal">Free to read. <span class="gradient-text">Subscribe</span> for what's new.</h2>
        <p class="lead reveal">
          Every playbook, every skill, the capability reference and the
          AI-news pipeline read free, no signup needed. Subscribe with
          your email if you want a heads-up when new entries ship and
          existing ones get refreshed against new frontier models.
        </p>
        <div class="lens-price reveal">
          <div class="lens-price-inner">
            <div class="price-head">
              <div class="price-tag mono"><span>FREE TO READ</span><span class="price-flag">EMAIL OPTIONAL</span></div>
              <div class="price-amount">£0<span class="price-per">/forever</span></div>
              <p class="price-shape mono">No paywall · No credit card · Unsubscribe anytime</p>
            </div>
            <ul class="price-list">
              <li><strong>Free without signing up.</strong> Read every playbook, every skill, the capability reference and the AI-news pipeline at <a href={url('/lens/library')}>/lens/library</a>. No gate, no overlay.</li>
              <li><strong>Free to install.</strong> The plugin is MIT-licensed and lives on GitHub. Two commands in Claude Code and you have all 26 skills.</li>
              <li><strong>Subscribe for the changes.</strong> One email when new playbooks ship, one when existing entries get refreshed against new frontier models, one weekly AI-news summary (optional).</li>
              <li><strong>No upsell. No drip funnel.</strong> Roughly one email a week. Unsubscribe in one click.</li>
            </ul>
            {/*
              Kit (ConvertKit) embedded-form endpoint. Form ID 9490842,
              UID cf656e168b. The form posts via fetch in no-cors mode
              below so the user stays on the page instead of being
              redirected to Kit's hosted success page.

              Switching services later only needs the action URL and
              field name updated. Kit uses `email_address`, Mailchimp
              uses `EMAIL`, Buttondown uses `email`.
            */}
            <form
              class="lens-signup-form"
              data-newsletter-form
              action="https://app.kit.com/forms/9490842/subscriptions"
              method="POST"
              novalidate
            >
              <label for="lens-email-signup" class="sr-only">Email address</label>
              <input
                type="email"
                id="lens-email-signup"
                name="email_address"
                placeholder="your@email.com"
                required
                autocomplete="email"
              />
              <button type="submit" class="btn-cta" data-newsletter-submit>
                <span data-submit-label>Subscribe for updates</span>
              </button>
            </form>
            <p class="lens-signup-feedback" data-newsletter-feedback role="status" aria-live="polite"></p>
            <p class="price-note">
              <a href={url('/privacy')}>What we do with your data</a>. Or skip the email entirely and read the library at <a href={url('/lens/library')}>/lens/library</a> any time.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE LENS PLUGIN -->
  <section class="section dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={300} tiltX={56} tiltY={-15} spin={140} scrollSpin={-80} style="top: 6%; right: 5%;" enterFrom="right" />
      <div class="container">
        <div class="eyebrow">006 · THE LENS PLUGIN</div>
        <h2 class="reveal">25 marketing workflows your AI agent runs <span class="gradient-text">inside Claude Code</span>.</h2>
        <p class="lead reveal">
          The playbook on this site explains the work. The skill in the
          plugin is the work. Install it once with two commands, then ask
          Claude to set up The Lens. The onboarding skill installs the
          right Cowork plugins alongside, finds your existing brand
          documentation, writes a structured <code>.lens/</code> workspace
          and recommends a starter. Twenty to forty minutes to a working
          setup, then every skill below runs against your actual data.
        </p>
        <pre class="lens-skills-install reveal"><code>/plugin marketplace add Scylark/manual-focus
/plugin install the-lens@manual-focus
set up the lens</code></pre>
        <div class="lens-skills-cta reveal">
          <a href={url('/lens/skills')} class="btn-cta">Browse the skills</a>
          <a href={url('/lens/cowork')} class="btn-ghost">Read the Cowork primer</a>
        </div>
        <p class="lens-skills-note reveal">
          26 skills live · 24 workflow skills · 1 onboarding orchestrator · 1 video-render utility · Source on <a href="https://github.com/Scylark/manual-focus/tree/main/lens-skills" target="_blank" rel="noopener">GitHub ↗</a>
        </p>
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="section section-alt dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={320} tiltX={55} tiltY={20} spin={-160} scrollSpin={80} style="top: 6%; right: 4%;" enterFrom="right" />
      <div class="container">
        <div class="eyebrow">007 · WHO IT'S FOR</div>
        <h2 class="reveal">Senior operators only.</h2>
        <div class="lens-fit-grid">
          <div class="lens-fit reveal">
            <h3>Built for</h3>
            <ul>
              <li>Heads of marketing and CMOs at $5M–$200M brands</li>
              <li>Fractional CMOs running two to four portfolio clients</li>
              <li>Senior in-house operators owning brand, demand or growth</li>
              <li>Marketing leaders at AI-native startups who need depth, not hot takes</li>
            </ul>
          </div>
          <div class="lens-fit reveal">
            <h3>Not built for</h3>
            <ul>
              <li>Generalists trying to break into marketing</li>
              <li>Agencies looking to re-sell the workflows as their own</li>
              <li>Anyone hoping for a "five prompts to grow your business" listicle</li>
              <li>People who want to skim, not ship</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO CURATES IT -->
  <section class="section dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={400} tiltX={58} tiltY={-18} spin={160} scrollSpin={100} style="top: 6%; right: 4%;" enterFrom="right" />
      <div class="container">
        <div class="eyebrow">008 · WHO CURATES IT</div>
        <h2 class="big-statement reveal" data-scroll-scale style="transform-origin: left center;">
          Operators<br/>
          <span class="gradient-text">running the work</span>,<br/>
          not selling the dream.
        </h2>
        <p class="lead reveal">
          The Lens is curated by Manual Focus, a senior marketing
          practice working with endurance brands and AI-native operators,
          with a rotating cast of contributors from the Foundry
          collective. The playbooks are the methodology that practice
          produced. The shapes, the prompts, the eval gates, the
          failure modes seen go wrong over years of senior marketing
          work and designed around.
        </p>
        <p class="reveal">
          As engagements run and patterns prove themselves, illustrative
          examples in each entry are replaced with real ones and the
          eval shapes with what those runs actually produced. When a
          workflow gets retired the entry says so and explains why.
          When a frontier model release changes the result of a
          workflow, the affected entries get annotated and updated.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={260} tiltX={55} tiltY={-22} spin={140} scrollSpin={70} style="top: 8%; left: 4%;" enterFrom="left" />
      <div class="container">
        <div class="eyebrow">009 · BEFORE YOU GO IN</div>
        <h2 class="reveal">The questions you'd be right to ask.</h2>
        <div class="lens-faq stagger">
          <details class="lens-faq-item">
            <summary>It's really free?</summary>
            <p>
              Yes. Every playbook, every skill, the capability reference
              and the AI-news pipeline. No paywall. No credit card. We
              ask for your email so we can let you know when new entries
              ship and existing ones get refreshed, but the library itself
              is fully open at <a href={url('/lens/library')}>/lens/library</a>
              even without signing up.
            </p>
          </details>
          <details class="lens-faq-item">
            <summary>What's in it for Manual Focus, then?</summary>
            <p>
              The Lens is the brand. Senior marketers who use the playbooks
              sometimes find that work emerges that fits a Manual Focus
              engagement, whether Fractional CMO, Strategic Advisor, Build
              and Hand Over, or the AI product. A free, opinionated,
              regularly updated library is how we earn the right to that
              conversation. If you never need us, that's also fine.
            </p>
          </details>
          <details class="lens-faq-item">
            <summary>How is this different from a course?</summary>
            <p>
              A course is content you consume once. The Lens is a reference
              library you keep coming back to. Pull a playbook the day a
              brief lands, swap the model when a new one ships, hand a
              workflow to a junior with the eval harness intact. The shape
              is closer to a Bloomberg Terminal than a Udemy unit.
            </p>
          </details>
          <details class="lens-faq-item">
            <summary>How many playbooks are in there now?</summary>
            <p>
              46 live across the five stacks of Brand, Demand, Content,
              Ops and Productivity, plus 26 runnable skills installable
              as a Claude Code plugin (24 workflow skills, the
              setup-the-lens onboarding orchestrator, and a
              video-script-to-heygen utility for turning playbooks into
              avatar videos via the HeyGen API). The capability reference
              page grades what AI can actually do this quarter. New
              entries ship regularly as new patterns prove themselves
              in live work.
            </p>
          </details>
          <details class="lens-faq-item">
            <summary>Can I share with my team?</summary>
            <p>
              Yes. Pass the URLs around. Install the plugin on every
              team member's Claude Code. The library is meant to be
              used by working teams, not gate-kept.
            </p>
          </details>
          <details class="lens-faq-item">
            <summary>What if a model change breaks a workflow I'm running?</summary>
            <p>
              When a frontier model lands, the affected entries get
              re-tested and annotated with what changed, which prompts
              got updated and whether the workflow still ships in the
              same shape. If your version is running fine, you don't
              need to touch it. Subscribers get notified when an entry
              they would care about has been refreshed.
            </p>
          </details>
          <details class="lens-faq-item">
            <summary>Is this a replacement for hiring Manual Focus?</summary>
            <p>
              For teams that can run the playbooks themselves, yes, this
              is the leverage without the cost of a Fractional CMO. For
              others it sits alongside one of the services as a way to
              keep the in-house team sharp between engagements.
            </p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- CLOSE -->
  <section class="section cta-close dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={520} tiltX={60} tiltY={-20} spin={160} scrollSpin={100} style="top: -10%; left: -10%;" enterFrom="left" />
      <FocusObject size={360} tiltX={50} tiltY={25} spin={-130} scrollSpin={-90} style="bottom: -10%; right: -8%;" enterFrom="right" />

      <div class="container cta-close-inner">
        <h2 class="cta-headline reveal">
          Read the work.<br/>
          <span class="gradient-text">Or pick one playbook and ship.</span>
        </h2>
        <p class="cta-sub reveal">
          The Lens compounds when used, not when read. Start with the
          guide if you're new, or jump straight to the library if you
          know what you're after.
        </p>
        <div class="cta-close-buttons reveal">
          <a href={url('/lens/start-here')} class="btn-cta">Start here</a>
          <a href={url('/lens/library')} class="btn-ghost">Browse the library</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ============================
     LENS HERO
     ============================ */
  /* Hero shares the same container width as the rest of the
     page (1280px from global .container) so the H1 and eyebrow
     align with the section headlines below it instead of sitting
     ~280px further in from the viewport edge. */

  /* Above-the-fold reveal elements need to be visible at load.
     The scroll-driven reveal JS uses an async IntersectionObserver
