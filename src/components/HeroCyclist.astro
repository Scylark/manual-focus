---
/**
 * HeroCyclist — depth-displacement scroll hero, rewritten clean.
 *
 * One source image (1920×1080 illustrated cyclist on a cliff) and one
 * matching greyscale depth map. Three.js displaces a subdivided plane
 * along Z based on the depth values, then arcs the camera on scroll
 * to produce a drone-pass parallax over the still image.
 *
 * The section sizes itself to 16:9 (matching the image aspect) so the
 * image fills its natural shape with no cover-fit cropping or
 * letterboxing. Capped at viewport height on tall displays, floored at
 * 540px so it stays impactful on narrow mobile.
 *
 * Renders the IMG as a base layer until WebGL has its first frame ready,
 * then fades the canvas in over the top. On reduced-motion, touch, or
 * narrow viewports, skips WebGL entirely and leaves the IMG showing.
 */
import { url } from '../utils/paths';

interface Props {
  texture?: string;
  depthMap?: string;
  fallbackImage?: string;
  /** Z displacement strength. 0.10 subtle, 0.20 strong. */
  strength?: number;
  /** Idle camera oscillation on top of the scroll-driven arc. */
  autoplay?: boolean;
}

const {
  texture = '/images/hero-cyclist.webp',
  depthMap = '/images/hero-cyclist-depth.png',
  fallbackImage = '/images/hero-cyclist.jpg',
  strength = 0.15,
  autoplay = true,
} = Astro.props;

const textureUrl = url(texture);
const depthUrl = url(depthMap);
const fallbackUrl = url(fallbackImage);
---

<section
  class="hero-cyclist"
  data-hero-cyclist
  data-texture={textureUrl}
  data-depth={depthUrl}
  data-strength={String(strength)}
  data-autoplay={autoplay ? 'true' : 'false'}
>
  <img
    class="hero-cyclist-img"
    src={fallbackUrl}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <canvas class="hero-cyclist-canvas" aria-hidden="true"></canvas>
  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    /* The image is 16:9. Size the section to match it exactly so the
       image fills its natural shape — no cropping, no letterboxing. */
    aspect-ratio: 16 / 9;
    /* Cap on tall monitors so the hero doesn't dwarf the viewport. */
    max-height: 100svh;
    /* Floor on narrow viewports so it stays impactful. */
    min-height: 540px;
    overflow: hidden;
    background: var(--color-bg);
    isolation: isolate;
  }

  .hero-cyclist-img,
  .hero-cyclist-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    transition: opacity 0.5s ease;
  }

  .hero-cyclist-img {
    z-index: 0;
    /* min/max-height can clip the 16:9 box on extreme viewports — cover
       keeps the image filling whatever the section's final size is. */
    object-fit: cover;
    object-position: center;
  }

  .hero-cyclist-canvas {
    z-index: 1;
    opacity: 0;
  }

  .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-canvas { opacity: 1; }
  .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { opacity: 0; }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    /* Soft left-side darkening so the headline reads on the dawn sky.
       Fades to clear by 65% so the cyclist on the right stays untouched. */
    background: linear-gradient(
      to right,
      rgba(15, 12, 8, 0.50) 0%,
      rgba(15, 12, 8, 0.22) 35%,
      transparent 65%
    );
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    color: #f6f0e8;
  }

  /* Slot child gets pulled to the left half so the headline sits on the
     empty sky, not over the cyclist on the right. */
  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 55%;
  }
  @media (max-width: 900px) {
    .hero-cyclist-content > :global(*) { max-width: 100%; }
  }

  /* Reduced-motion + touch + narrow: keep the IMG, skip WebGL entirely. */
  @media (prefers-reduced-motion: reduce) {
    .hero-cyclist-canvas { display: none; }
    .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { opacity: 1; }
  }
  @media (max-width: 768px) {
    .hero-cyclist-canvas { display: none; }
    .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { opacity: 1; }
  }
</style>

<script>
  import * as THREE from 'three';

  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;

    // Skip WebGL on small viewports, touch devices, and reduced-motion.
    // The IMG fallback is already showing, nothing else to do.
    if (
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      window.matchMedia('(hover: none) and (pointer: coarse)').matches ||
      window.matchMedia('(max-width: 768px)').matches
    ) {
      section.dataset.webglReady = 'true';
      return;
    }

    const canvas = section.querySelector<HTMLCanvasElement>('.hero-cyclist-canvas');
    if (!canvas) return;

    const textureUrl = section.dataset.texture!;
    const depthUrl = section.dataset.depth!;
    const strength = parseFloat(section.dataset.strength || '0.15');
    const autoplay = section.dataset.autoplay === 'true';

    // Renderer.
    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: false,
        antialias: true,
        powerPreference: 'high-performance',
      });
    } catch {
      section.dataset.webglReady = 'true';
      return;
    }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    // Scene + camera. Perspective with shallow FOV so the parallax reads
    // as cinematic rather than wide-angle.
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
    const baseZ = 1.6;
    camera.position.set(0, 0, baseZ);
    camera.lookAt(0, 0, 0);

    // 1×1 plane geometry — we scale to fit at runtime. 200 subdivisions
    // for smooth displacement without crushing low-end GPUs.
    const geometry = new THREE.PlaneGeometry(1, 1, 200, 200);

    // Material. Plain texture lookup + Z-displacement vertex shader.
    // No clever sharpening, no bicubic. Linear sampling looks as good as
    // the texture upload allows.
    const material = new THREE.ShaderMaterial({
      uniforms: {
        uTexture: { value: null as THREE.Texture | null },
        uDepth: { value: null as THREE.Texture | null },
        uStrength: { value: strength },
      },
      vertexShader: /* glsl */ `
        uniform sampler2D uDepth;
        uniform float uStrength;
        varying vec2 vUv;
        void main() {
          vUv = uv;
          float d = texture2D(uDepth, uv).r;
          vec3 displaced = position;
          // Depth 0..1, centred at 0.5 so mid-grey doesn't shift.
          displaced.z += (d - 0.5) * uStrength * 2.0;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(displaced, 1.0);
        }
      `,
      fragmentShader: /* glsl */ `
        uniform sampler2D uTexture;
        varying vec2 vUv;
        void main() {
          gl_FragColor = texture2D(uTexture, vUv);
        }
      `,
    });

    const mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);

    // Texture loading. Configure for sharp upscale: max anisotropy, linear
    // filtering, no mipmaps (we want full-res sampling, not a downsampled
    // mip level when the texture is rendered at native size).
    const loader = new THREE.TextureLoader();
    let loadedCount = 0;
    function onTextureReady() {
      loadedCount++;
      if (loadedCount === 2) {
        // Two RAFs to let layout settle (font swap, content reflow) before
        // measuring the canvas. Then size, render the first frame, expose,
        // and start the animation loop.
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            fitCanvas();
            renderer.render(scene, camera);
            section.dataset.webglReady = 'true';
            startLoop();
          });
        });
      }
    }
    function configureTexture(t: THREE.Texture, isColor: boolean) {
      t.colorSpace = isColor ? THREE.SRGBColorSpace : THREE.NoColorSpace;
      t.minFilter = THREE.LinearFilter;
      t.magFilter = THREE.LinearFilter;
      t.generateMipmaps = false;
      t.anisotropy = renderer.capabilities.getMaxAnisotropy();
      t.needsUpdate = true;
    }
    loader.load(textureUrl, (t) => {
      configureTexture(t, true);
      material.uniforms.uTexture.value = t;
      onTextureReady();
    });
    loader.load(depthUrl, (t) => {
      configureTexture(t, false);
      material.uniforms.uDepth.value = t;
      onTextureReady();
    });

    // Fit the plane to the visible viewport with object-fit:cover behaviour,
    // based on the canvas's actual rendered dimensions (NOT the section's,
    // which can lag during layout). Called via ResizeObserver from the
    // start, so any size change picks up automatically.
    const IMAGE_ASPECT = 16 / 9;
    function fitCanvas() {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      if (w <= 0 || h <= 0) return;

      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();

      // Compute the visible world area at the plane's z=0 depth.
      const vFov = (camera.fov * Math.PI) / 180;
      const viewH = 2 * Math.tan(vFov / 2) * baseZ;
      const viewW = viewH * camera.aspect;

      // Cover: pick the larger overflow direction and scale to fill the
      // other. The plane will overflow the canvas on one axis; the canvas
      // CSS overflow:hidden crops it cleanly.
      const viewAspect = w / h;
      let planeW: number, planeH: number;
      if (viewAspect > IMAGE_ASPECT) {
        // Viewport wider than image — scale to fill width, overflow vertically.
        planeW = viewW;
        planeH = viewW / IMAGE_ASPECT;
      } else {
        // Viewport taller than image — scale to fill height, overflow horizontally.
        planeH = viewH;
        planeW = viewH * IMAGE_ASPECT;
      }
      // Small overscale so camera arcs at extreme positions can't reveal
      // the plane edge.
      mesh.scale.set(planeW * 1.08, planeH * 1.08, 1);
    }

    // ResizeObserver picks up anything that changes the canvas size:
    // window resize, font swap, content reflow, devtools, mobile address
    // bar collapse/expand. This is the only sizing trigger we need.
    const ro = new ResizeObserver(() => fitCanvas());
    ro.observe(canvas);

    // Scroll progress through the section, 0 at top, 1 at bottom.
    let scrollProgress = 0;
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const span = rect.height;
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / span));
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();

    // Pause the render loop when the hero scrolls fully out of view.
    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    // Animation loop. Shallow camera arc driven by scroll, plus an
    // optional autoplay micro-drift breathing the camera at idle.
    let frameId: number | null = null;
    function startLoop() {
      function frame(now: number) {
        if (!inView) {
          frameId = requestAnimationFrame(frame);
          return;
        }
        const t = now / 1000;

        // Scroll-driven shallow arc — about 13° max swing on X, mild Z push.
        const arcAngle = scrollProgress * 0.23;
        const arcX = Math.sin(arcAngle) * 0.32;
        const arcZ = (1 - Math.cos(arcAngle)) * 0.32;
        const arcY = -scrollProgress * 0.06;

        // Autoplay drift: ~1° equivalent oscillation, slow.
        let driftX = 0, driftY = 0;
        if (autoplay) {
          driftX = Math.sin(t * 0.28) * 0.022;
          driftY = Math.cos(t * 0.23) * 0.014;
        }

        camera.position.x = arcX + driftX;
        camera.position.y = arcY + driftY;
        camera.position.z = baseZ - arcZ;
        camera.lookAt(0, 0, 0);

        renderer.render(scene, camera);
        frameId = requestAnimationFrame(frame);
      }
      frameId = requestAnimationFrame(frame);
    }

    // Clean up on page unload (SPA navigation, tab close).
    window.addEventListener('pagehide', () => {
      if (frameId != null) cancelAnimationFrame(frameId);
      ro.disconnect();
      renderer.dispose();
      geometry.dispose();
      material.dispose();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
