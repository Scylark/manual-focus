---
interface Props {
  size?: number;
  tiltX?: number;
  tiltY?: number;
  tiltZ?: number;
  spin?: number;          // continuous rotation period (s). Negative for reverse.
  scrollSpin?: number;    // deg per 1000px scrolled
  hueA?: string;          // e.g. '#C45A2C' — terracotta sunrise (default)
  hueB?: string;          // e.g. '#7CA89A' — soft sage / dawn cyan
  thickness?: number;     // physical extrusion depth in px
  slices?: number;        // number of ring layers per ring
  opacity?: number;
  class?: string;
  style?: string;
  enterFrom?: 'left' | 'right' | 'top' | 'bottom';
}
const {
  size = 320,
  tiltX = 62,
  tiltY = -18,
  tiltZ = 0,
  spin = 90,
  scrollSpin = 60,
  hueA,
  hueB,
  thickness = 50,
  slices = 28,
  opacity = 1,
  class: className = '',
  style = '',
  enterFrom = 'right',
} = Astro.props;

// Pre-compute per-slice values. We no longer bake the hex colour at SSR
// because that hardcodes the theme — instead we expose --t (0..1) per slice
// and let CSS color-mix between the theme-driven --ring-hue-a / --ring-hue-b
// at runtime. Toggling theme then re-tints every ring instantly.
const half = (slices - 1) / 2;
const layers = Array.from({ length: slices }, (_, i) => {
  const t = i / (slices - 1);            // 0..1
  const centerDist = Math.abs(i - half) / half;  // 0 at middle, 1 at edges
  const z = (i - half) * (thickness / slices);   // -thickness/2 .. +thickness/2
  const op = 1 - centerDist * 0.4;
  return { i, t, z, op };
});

const spinDir = spin < 0 ? '-1' : '1';
const spinDur = Math.abs(spin);

// Only write inline --hueA/--hueB overrides when the caller actually
// passed a hex value. Otherwise the slice CSS resolves --ring-hue-a /
// --ring-hue-b directly from :root / [data-theme="dark"] and the ring
// flips with the theme toggle.
const hueOverride = [
  hueA ? `--hueA: ${hueA};` : '',
  hueB ? `--hueB: ${hueB};` : '',
].join('');
---
<div
  class={`focus-object focus-object--${enterFrom} ${className}`}
  style={`--fo-size: ${size}px; --tiltX: ${tiltX}deg; --tiltY: ${tiltY}deg; --tiltZ: ${tiltZ}deg; --spinDur: ${spinDur}s; --spinDir: ${spinDir}; --scrollSpin: ${scrollSpin}; --enter-opacity: ${opacity}; ${hueOverride} ${style}`}
  data-scroll-spin={scrollSpin}
  aria-hidden="true"
>
  <div class="focus-object__perspective">
    <div class="focus-object__tilt">
      <div class="focus-object__scroll">
        <div class="focus-object__spin">
          <div class="ring3d ring3d--top">
            {layers.map(({ t, z, op }) => (
              <div
                class="ring3d__slice"
                style={`transform: translateZ(${z}px); opacity: ${op}; --t: ${t};`}
              ></div>
            ))}
          </div>
          <div class="ring3d ring3d--bot">
            {layers.map(({ t, z, op }) => (
              <div
                class="ring3d__slice"
                style={`transform: translateZ(${z}px); opacity: ${op}; --t: ${t};`}
              ></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .focus-object {
    position: absolute;
    pointer-events: none;
    will-change: transform, opacity;
    transition: opacity 1.4s cubic-bezier(0.22, 1, 0.36, 1),
                transform 1.4s cubic-bezier(0.22, 1, 0.36, 1);
    opacity: 0;
    filter: drop-shadow(0 12px 24px var(--ring-shadow, rgba(26, 22, 18, 0.18)));
    /* Aspect-ratio locked, vmin-driven sizing. --fo-size is the
       desktop-intent maximum (passed via the size prop). Width
       resolves to the smaller of: the declared px max, or 40% of
       the viewport's short side. 40vmin tuned so the typical
       declared 320px ring renders at exactly 320 on a 1280×800
       laptop (40 × 8 = 320), respecting the desktop-approved sizing
       while still scaling DOWN on smaller viewports (≈150px on
       a 375px phone, ≈307px on an iPad). Square aspect-ratio means
       height follows width automatically. Replaces the previous
       fixed-px width/height which didn't adapt at all — a 520px
       declared ring was the same 520px on a phone, an iPad, and a
       4K display. */
    width: min(var(--fo-size, 320px), 40vmin);
    aspect-ratio: 1;
  }

  /* Mobile: drop the drop-shadow filter (the expensive paint op on
     a per-scroll-frame basis), and zero the enterFrom translateX
     so .focus-object--left/right don't sit 100px past the section
     edge while waiting for .has-entered. Mobile Safari doesn't
     reliably clip 3D-transformed children even with body
     overflow-x:hidden — that was the source of the sideways-drag
     on vertical scroll. translateY-only entrance still gives the
     fade-up feel without the horizontal bleed.

     Sizing is handled at the top-level rule via min(--fo-size,
     28vmin) so there's no per-breakpoint sizing override needed
     here. */
  @media (max-width: 768px) {
    .focus-object {
      filter: none;
    }
    .focus-object--right,
    .focus-object--left  { transform: translate(0, 30px); }
  }

  /* Entrance offset (cleared by .has-entered) */
  .focus-object--right { transform: translate(100px, 30px); }
  .focus-object--left  { transform: translate(-100px, 30px); }
  .focus-object--top   { transform: translate(0, -100px); }
  .focus-object--bottom{ transform: translate(0, 100px); }

  .focus-object.has-entered {
    transform: translate(0, 0);
    opacity: var(--enter-opacity, 1);
  }

  .focus-object__perspective {
    width: 100%;
    height: 100%;
    perspective: 1400px;
    perspective-origin: 50% 50%;
  }

  .focus-object__tilt {
    width: 100%;
    height: 100%;
    transform: rotateX(var(--tiltX)) rotateY(var(--tiltY)) rotateZ(var(--tiltZ));
    transform-style: preserve-3d;
  }

  .focus-object__scroll {
    width: 100%;
    height: 100%;
    /* Compose Y parallax (depth-weighted) and Z rotation so each ring drifts
       on its own scroll-curve, selling true depth instead of every ring
       moving in lock-step. */
    transform: translate3d(0, var(--scroll-y, 0), 0) rotateZ(var(--scroll-rot, 0deg));
    transform-style: preserve-3d;
  }

  .focus-object__spin {
    width: 100%;
    height: 100%;
    animation: focus-object-spin var(--spinDur) linear infinite;
    /* Paused by default — JS toggles via IntersectionObserver so the
       spin only runs when the object is actually on-screen. */
    animation-play-state: paused;
    transform-style: preserve-3d;
    transform-origin: 50% 50%;
  }
  .focus-object.is-visible .focus-object__spin {
    animation-play-state: running;
  }
  .focus-object[style*="--spinDir: -1"] .focus-object__spin {
    animation-direction: reverse;
  }

  .ring3d {
    position: absolute;
    width: 60%;
    height: 60%;
    left: 20%;
    transform-style: preserve-3d;
  }
  /* Two interlocking rings — top sits above, bottom below */
  .ring3d--top { top: 8%; }
  .ring3d--bot { top: 32%; }

  .ring3d__slice {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 20px solid;
    background: transparent;
    box-sizing: border-box;
  }
  /* Slice colour interpolated between the two theme hues. Top ring lerps
     A -> B as slices step back, bottom ring lerps B -> A so the two rings
     are mirror-coloured. --t is set per-slice inline. */
  .ring3d--top .ring3d__slice {
    border-color: color-mix(in srgb,
      var(--hueA, var(--ring-hue-a)) calc((1 - var(--t)) * 100%),
      var(--hueB, var(--ring-hue-b)));
  }
  .ring3d--bot .ring3d__slice {
    border-color: color-mix(in srgb,
      var(--hueB, var(--ring-hue-b)) calc((1 - var(--t)) * 100%),
      var(--hueA, var(--ring-hue-a)));
  }

  /* Highlight + shadow on the front and back of the stack — both
     theme-controlled so they soften on the cream backdrop. */
  .ring3d__slice:first-child {
    box-shadow: 0 0 18px var(--ring-inset, rgba(26, 22, 18, 0.18)) inset;
  }
  .ring3d__slice:last-child {
    box-shadow: 0 0 16px var(--ring-highlight, rgba(255, 255, 255, 0.20));
  }

  @keyframes focus-object-spin {
    from { transform: rotateY(0deg); }
    to   { transform: rotateY(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .focus-object__spin { animation: none; }
    .focus-object {
      transition: opacity 0.6s ease;
    }
    .focus-object--right,
    .focus-object--left,
    .focus-object--top,
    .focus-object--bottom { transform: none; }
  }

  /* Mobile — full opacity matching desktop so the rings read as
     the overlapping 3D circles they're supposed to be, not a faded
     ghost. Text contrast is fine because the rings sit in the
     section corner away from the headline body. */
</style>
