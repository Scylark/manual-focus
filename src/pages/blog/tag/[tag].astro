---
import Base from '../../../layouts/Base.astro';
import SEOHead from '../../../components/SEOHead.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { url } from '../../../utils/paths';
import { readingTime } from '../../../utils/blog';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allTags = [...new Set(posts.flatMap(p => p.data.tags))];

  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
const displayTag = tag.replace(/-/g, ' ');

// Tag-specific titles + descriptions so each tag landing has its own
// keyword-targeted meta, not a generic "posts tagged X" placeholder.
const tagMeta: Record<string, { title: string; description: string; headline: string }> = {
  'ai': {
    title: 'AI in marketing — Manual Focus blog',
    description: 'Senior-marketer perspective on AI in marketing — adoption, workflows, tooling, the failures nobody talks about, and what actually compounds.',
    headline: 'AI in marketing',
  },
  'marketing-strategy': {
    title: 'Marketing strategy posts — Manual Focus',
    description: 'Marketing strategy for the AI era. Positioning, channels, engines and pipelines, written from inside the work.',
    headline: 'Marketing strategy',
  },
  'fractional-cmo': {
    title: 'Fractional CMO posts — Manual Focus',
    description: 'Notes on fractional CMO work — what it is, when it fits, how to scope it, how to make it pay off.',
    headline: 'Fractional CMO',
  },
  'digital-transformation': {
    title: 'Digital transformation — Manual Focus blog',
    description: 'Digital transformation pieces from inside marketing functions actually doing the change work.',
    headline: 'Digital transformation',
  },
  'brand': {
    title: 'Brand strategy posts — Manual Focus',
    description: 'Brand thinking from senior operators — positioning, voice, narrative, and what AI changes about brand work.',
    headline: 'Brand strategy',
  },
  'go-to-market': {
    title: 'Go-to-market posts — Manual Focus',
    description: 'Go-to-market plays across owned, earned and paid channels, with AI threading through the workflow.',
    headline: 'Go-to-market',
  },
  'web3': {
    title: 'Web3 and digital asset marketing — Manual Focus',
    description: 'Notes from running marketing inside Web3 and digital asset companies. What works, what is theatre.',
    headline: 'Web3 marketing',
  },
  'fintech': {
    title: 'Fintech marketing posts — Manual Focus',
    description: 'Fintech marketing perspective — going to market in a regulated, trust-sensitive category.',
    headline: 'Fintech marketing',
  },
  'endurance-sports': {
    title: 'Endurance and sports brand marketing — Manual Focus',
    description: 'Marketing playbooks for endurance and sports brands. Cycling, running, triathlon. SEO, content engines and category-leading work.',
    headline: 'Endurance and sports brand marketing',
  },
  'leadership': {
    title: 'Marketing leadership posts — Manual Focus',
    description: 'Marketing leadership in the AI era. Building teams, integrating AI, protecting the taste layer.',
    headline: 'Marketing leadership',
  },
  'productivity': {
    title: 'Marketing productivity and workflow — Manual Focus',
    description: 'Workflow and productivity for marketing teams. AI as leverage, not as theatre. Pipelines that compound.',
    headline: 'Marketing productivity',
  },
};
const meta = tagMeta[tag] ?? {
  title: `${displayTag} — Manual Focus blog`,
  description: `Posts on ${displayTag} from the Manual Focus blog.`,
  headline: displayTag,
};
---
<Base title={meta.title} description={meta.description}>
  <SEOHead slot="seo" type="website" title={meta.title} description={meta.description} breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Blog', url: '/blog' }, { name: meta.headline, url: `/blog/tag/${tag}/` }]} />
  <section class="section">
    <div class="container">
      <h1 style="text-transform: capitalize;">{meta.headline}</h1>
      <p><a href={url('/blog')}>&larr; All posts</a></p>

      <div class="blog-grid">
        {posts.map((post: any) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            minutes={readingTime(post.body ?? '')}
          />
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  @media (min-width: 640px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
