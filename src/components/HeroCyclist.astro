---
/**
 * HeroCyclist — two-layer depth parallax hero.
 *
 * The cyclist + bike + foreground rocks live on a transparent
 * foreground layer (alpha-masked using the depth map). A separately
 * inpainted background sits behind. As the visitor scrolls — and
 * subtly at rest via an autoplay drift — the background translates
 * while the foreground stays anchored, producing the drone-pass
 * parallax read without shader artefacts.
 *
 * Pure CSS transforms on the layers. No WebGL — every shader-only
 * attempt on a single-image depth map ran into one of: rider tearing
 * at the silhouette, ghost copies of the rider sampled through the
 * shift, or a visible static halo around him. Separating into two
 * physical layers eliminates the class of artefact entirely.
 *
 * Asset prep (one-time, kept in /scripts/build-hero-layers.py if you
 * need to re-run): the depth map's silhouette is used as the alpha
 * channel for the foreground PNG, and the colour image is heavily
 * blurred in the cyclist's region to inpaint the background JPG.
 * The inpaint quality only matters in the narrow strip the parallax
 * shift reveals — the rest is covered by the sharp foreground.
 */
import { url } from '../utils/paths';

interface Props {
  background?: string;
  foreground?: string;
  fallbackImage?: string;
  /** Background drift per scroll-pixel. 0.20 = bg moves 20% of scroll. */
  parallax?: number;
}

const {
  background = '/images/hero-cyclist-background.jpg',
  foreground = '/images/hero-cyclist-foreground.png',
  fallbackImage = '/images/hero-cyclist.jpg',
  parallax = 0.25,
} = Astro.props;

const bgUrl = url(background);
const fgUrl = url(foreground);
const fallbackUrl = url(fallbackImage);
---
<section
  class="hero-cyclist"
  data-hero-cyclist
  data-parallax-amount={String(parallax)}
>
  <noscript>
    <img class="hero-cyclist-img-noscript" src={fallbackUrl} alt="" aria-hidden="true" />
  </noscript>

  <img
    class="hero-cyclist-bg"
    src={bgUrl}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <img
    class="hero-cyclist-fg"
    src={fgUrl}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />

  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-img-noscript {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    z-index: 0;
  }

  .hero-cyclist-bg,
  .hero-cyclist-fg {
    position: absolute;
    /* Slight overscale so the bg can drift on the X axis without
       revealing the section edge. The drift is clamped to this
       headroom in the JS below. */
    top: -3%;
    left: -6%;
    width: 112%;
    height: 106%;
    object-fit: cover;
    object-position: 65% center;
    pointer-events: none;
    will-change: transform;
  }
  .hero-cyclist-bg { z-index: 0; }
  .hero-cyclist-fg { z-index: 1; }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 3;
    /* Match the global .container constraint so the hero copy aligns
       with the page sections below it on wide viewports. Without
       this the hero text hugs the viewport edge while the rest of
       the page sits inside a 1280px centred container. */
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }
  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }
  @media (max-width: 768px) {
    .hero-cyclist { min-height: 560px; }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cyclist-bg,
    .hero-cyclist-fg {
      transform: none !important;
    }
  }
</style>

<script>
  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const bg = section.querySelector<HTMLElement>('.hero-cyclist-bg');
    const fg = section.querySelector<HTMLElement>('.hero-cyclist-fg');
    if (!bg || !fg) return;

    const amount = parseFloat(section.dataset.parallaxAmount || '0.25');
    if (amount <= 0) return;

    // Track scroll progress through the hero section (0 at top, 1 at
    // the point the section's bottom hits the top of the viewport).
    let scrollProgress = 0;
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const span = rect.height;
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / span));
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    window.addEventListener('resize', updateScroll, { passive: true });
    updateScroll();

    // Pause animation when off-screen so we're not running RAFs for
    // nothing on long scrolling pages.
    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    // Continuous render loop driven by RAF. Combines scroll progress
    // with an autoplay drift sine wave so the background breathes
    // even at rest before the visitor scrolls.
    function frame(now: number) {
      requestAnimationFrame(frame);
      if (!inView) return;
      const t = now / 1000;

      // Scroll-driven sweep: the background slides left and dips
      // slightly as the visitor moves down through the hero. Clamp
      // to ±3% horizontally and ±1.5% vertically so the overscaled
      // layer never reveals its edge.
      const ease = scrollProgress * scrollProgress * (3 - 2 * scrollProgress);
      const scrollX = -ease * 36;   // px, negative = bg drifts LEFT
      const scrollY = ease * 16;    // px, positive = bg drifts DOWN

      // Autoplay drift: gentle sine breathing on top of scroll.
      const driftX = Math.sin(t * 0.32) * 12;
      const driftY = Math.cos(t * 0.21) * 6;

      const bgX = scrollX + driftX;
      const bgY = scrollY + driftY;
      bg.style.transform = `translate3d(${bgX.toFixed(2)}px, ${bgY.toFixed(2)}px, 0)`;

      // Foreground gets a much smaller counter-drift so the cyclist
      // feels alive without breaking the anchored read. Keep this
      // subtle — 25% of the bg drift, opposite direction so they
      // separate visually on scroll.
      const fgX = -bgX * 0.15;
      const fgY = -bgY * 0.15;
      fg.style.transform = `translate3d(${fgX.toFixed(2)}px, ${fgY.toFixed(2)}px, 0)`;
    }
    requestAnimationFrame(frame);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
