  const root = document.querySelector<HTMLElement>('[data-diagnostic]');
  if (root) {
    const steps = {
      1: root.querySelector<HTMLElement>('[data-diag-step="1"]')!,
      2: root.querySelector<HTMLElement>('[data-diag-step="2"]')!,
      3: root.querySelector<HTMLElement>('[data-diag-step="3"]')!,
    };
    const opts1 = root.querySelector<HTMLElement>('[data-diag-options="1"]')!;
    const opts2 = root.querySelector<HTMLElement>('[data-diag-options="2"]')!;
    const q2El = root.querySelector<HTMLElement>('[data-diag-q2]')!;

    const show = (n: 1 | 2 | 3) => {
      steps[1].hidden = n !== 1;
      steps[2].hidden = n !== 2;
      steps[3].hidden = n !== 3;
    };

    const showResult = (r: { title: string; why: string; meta: string; url: string }) => {
      root.querySelector<HTMLElement>('[data-diag-title]')!.textContent = r.title;
      root.querySelector<HTMLElement>('[data-diag-why]')!.textContent = r.why;
      root.querySelector<HTMLElement>('[data-diag-meta]')!.textContent = r.meta;
      root.querySelector<HTMLAnchorElement>('[data-diag-link]')!.href = r.url;
      show(3);
    };

    Object.values(TREE).forEach((branch) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'diag-option';
      btn.textContent = branch.label;
      btn.addEventListener('click', () => {
        q2El.textContent = branch.q2.q;
        opts2.innerHTML = '';
        branch.q2.options.forEach((opt) => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'diag-option';
          b.textContent = opt.label;
          b.addEventListener('click', () => showResult(opt.result));
          opts2.appendChild(b);
        });
        show(2);
      });
      opts1.appendChild(btn);
    });

    root.querySelector('[data-diag-back]')?.addEventListener('click', () => show(1));
    root.querySelector('[data-diag-restart]')?.addEventListener('click', () => show(1));
  }
