---
import Base from '../layouts/Base.astro';
import LogoAnimation from '../components/LogoAnimation.astro';
import SEOHead from '../components/SEOHead.astro';
import BlogCard from '../components/BlogCard.astro';
import { url } from '../utils/paths';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---
<Base title="Home" description="Manual Focus. An AI-powered marketing agency that installs agent teams, automates production, and drives measurable growth." hideNavUntilScroll>
  <SEOHead slot="seo" type="website" title="Home" description="Manual Focus. An AI-powered marketing agency that installs agent teams, automates production, and drives measurable growth." />

  <!-- Hero -->
  <section class="hero section">
    <div class="container hero-inner">
      <LogoAnimation animate />
      <h1 class="hero-headline">Bringing focus to the noise.</h1>
    </div>
  </section>

  <!-- Sub-hero -->
  <section class="section sub-hero">
    <div class="container">
      <p class="hero-sub">We plug AI agent teams into your marketing operation. They handle production, sharpen your SEO, and free your people to do strategic work.</p>
      <a href={url('/enquire')} class="btn-cta" style="margin-top: var(--space-md);">Enquire</a>
    </div>
  </section>

  <!-- Problem Diagnosis -->
  <section class="section">
    <div class="container">
      <h2 class="section-headline">Your team is busy.<br />Your AI isn't.</h2>
      <p class="section-body">Most marketing teams are stretched thin doing repetitive work that AI should be handling. Product descriptions written one at a time. Images resized by hand. SEO audits that nobody has time to act on. We fix that. We install AI agent teams that take over the grind so your people can focus on strategy, creativity, and growth.</p>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-headline">What we do</h2>
      <div class="services-grid">
        <div class="service-card">
          <h3>AI agent teams</h3>
          <p>We build and deploy AI agents tailored to your marketing operation. Content agents that write, refine, and ship copy. Research agents that monitor competitors and flag opportunities. Reporting agents that pull data and write the summary. They run around the clock.</p>
        </div>
        <div class="service-card">
          <h3>Automated product creation</h3>
          <p>Product descriptions, listing copy, campaign assets. Generated at scale from your source data. We set up the pipeline so new products go from raw specs to publish-ready content without the bottleneck.</p>
        </div>
        <div class="service-card">
          <h3>Image enhancement</h3>
          <p>AI-powered image editing, background removal, resizing, and optimisation. One product photo becomes twenty platform-ready variants. No design queue. No freelancer turnaround.</p>
        </div>
        <div class="service-card">
          <h3>SEO audit and boost</h3>
          <p>We run AI-driven audits across your site, flag what's broken, and fix it. Technical issues, thin content, missing structure, poor internal linking. Then we set up agents to keep it healthy over time, not just a one-off report that collects dust.</p>
        </div>
      </div>
      <p class="section-note">We don't hand you a strategy deck and disappear. We install the systems and stay until they're running.</p>
      <a href={url('/services')} class="btn-cta" style="margin-top: var(--space-md);">Learn more</a>
    </div>
  </section>

  <!-- Brands We've Worked With -->
  <section class="section">
    <div class="container">
      <h2 class="section-headline">Brands we've worked with</h2>
      <div class="logo-bar">
        <img src={url('/images/brand-logos/classified-cycling.svg')} alt="Classified Cycling" class="brand-logo" width="140" height="40" loading="lazy" />
        <img src={url('/images/brand-logos/wahoo.svg')} alt="Wahoo" class="brand-logo" width="140" height="40" loading="lazy" />
        <img src={url('/images/brand-logos/wattbike.svg')} alt="Wattbike" class="brand-logo" width="140" height="40" loading="lazy" />
        <img src={url('/images/brand-logos/ribble-cycles.svg')} alt="Ribble Cycles" class="brand-logo" width="140" height="40" loading="lazy" />
        <img src={url('/images/brand-logos/rgt.svg')} alt="RGT" class="brand-logo" width="140" height="40" loading="lazy" />
        <img src={url('/images/brand-logos/motif-ai.svg')} alt="motif AI" class="brand-logo" width="140" height="40" loading="lazy" />
        <img src={url('/images/brand-logos/muuvr.svg')} alt="Muuvr" class="brand-logo" width="140" height="40" loading="lazy" />
        <img src={url('/images/brand-logos/planet-x.svg')} alt="Planet X" class="brand-logo" width="140" height="40" loading="lazy" />
        <img src={url('/images/brand-logos/pelotan.svg')} alt="Pelotan" class="brand-logo" width="140" height="40" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Operator Credibility -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-headline">We've been in the room<br />when things ship.</h2>
      <p class="section-body">Manual Focus was built by marketers who've run teams, launched products, and grown businesses across AI, fintech, Web3, and hardware. We've taken platforms from zero to hundreds of thousands of users and brought products to market in categories that didn't exist yet. That's why our systems work when deployed, not just on paper.</p>
      <a href={url('/about')} class="btn-cta" style="margin-top: var(--space-md);">More about us</a>
    </div>
  </section>

  <!-- Perspective (Blog Previews) -->
  <section class="section">
    <div class="container">
      <h2 class="section-headline">Perspective</h2>
      <div class="blog-grid">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Close -->
  <section class="section cta-close">
    <div class="container">
      <h2 class="section-headline">Ready to put AI to work?</h2>
      <p class="section-body">If your marketing team is doing work that machines should be handling, we can fix that. Tell us what's slowing you down.</p>
      <a href={url('/enquire')} class="btn-cta">Enquire</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .hero-headline {
    max-width: 900px;
    text-transform: uppercase;
    font-size: var(--font-size-xl);
  }

  .hero-sub {
    max-width: 600px;
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
  }

  .section-headline {
    text-transform: uppercase;
    max-width: 800px;
  }

  .section-body {
    max-width: 700px;
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    margin-top: var(--space-sm);
  }

  .section-note {
    color: var(--color-text-secondary);
    font-style: italic;
    margin-top: var(--space-md);
  }

  .section-alt {
    background-color: rgba(29, 29, 27, 0.02);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .service-card {
    padding: var(--space-md);
    border: 1px solid rgba(29, 29, 27, 0.08);
    border-radius: 4px;
  }

  .service-card h3 {
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  .service-card p {
    color: var(--color-text-secondary);
  }

  .logo-bar {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-md);
    align-items: center;
    justify-items: center;
  }

  .brand-logo {
    height: 2.5rem;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .brand-logo:hover {
    opacity: 1;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .cta-close {
    padding-block: var(--space-2xl);
  }

  @media (min-width: 640px) {
    .services-grid { grid-template-columns: 1fr 1fr; }
    .logo-bar { grid-template-columns: repeat(3, 1fr); }
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .logo-bar { grid-template-columns: repeat(5, 1fr); }
    .blog-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
