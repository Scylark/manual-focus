---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { url } from '../utils/paths';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  hideNavUntilScroll?: boolean;
}

const { title, description, ogImage = url('/images/og-default.png'), hideNavUntilScroll = false } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Manual Focus</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  {/* Theme bootstrap — runs before the body paints so the right theme is
      applied without a flash. ALWAYS lands in dark mode on page load —
      the brand's primary mode — regardless of system prefers-color-scheme
      or any prior toggle saved to localStorage. The in-page theme toggle
      still works to switch during a session, but the choice doesn't
      persist across loads. Dark is the canonical state of this site. */}
  <script is:inline>
    document.documentElement.setAttribute('data-theme', 'dark');
  </script>

  <!-- Favicons -->
  <link rel="icon" href={url('/favicon.svg')} type="image/svg+xml" />
  <link rel="icon" href={url('/favicon.ico')} sizes="32x32" />
  <link rel="apple-touch-icon" href={url('/apple-touch-icon.png')} />
  <link rel="manifest" href={url('/site.webmanifest')} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} | Manual Focus`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:url" content={canonicalUrl} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Manual Focus`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <!-- RSS autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title="Manual Focus Blog" href={url('/rss.xml')} />

  <!-- Plausible Analytics (uncomment when account is set up) -->
  <!-- <script defer data-domain="manual-focus.co.uk" src="https://plausible.io/js/script.js"></script> -->

  <slot name="seo" />
</head>
<body class:list={[{ 'has-fixed-nav': !hideNavUntilScroll }]}>
  <div class="scroll-progress" aria-hidden="true"></div>
  <a href="#main-content" class="sr-only">Skip to content</a>

  <Nav hideUntilScroll={hideNavUntilScroll} />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <script>
    // Scroll progress bar
    const progressBar = document.querySelector('.scroll-progress');
    if (progressBar) {
      window.addEventListener('scroll', () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        (progressBar as HTMLElement).style.width = `${progress}%`;
      }, { passive: true });
    }

    // Scroll-driven reveal. Each element animates as it enters the
    // viewport (opacity + translateY), then HOLDS at its revealed
    // state — no exit transition, headlines stay anchored once
    // they've landed. Tied to scroll progress rather than a single
    // IO threshold so the reveal dwells naturally as the user
    // scrolls into each section, the same feel as the hero and
    // manifesto.
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const revealItems: HTMLElement[] = [];
      // Collect .reveal elements + direct children of .stagger so
      // each gets driven by its own viewport position.
      document.querySelectorAll<HTMLElement>('.reveal').forEach(el => revealItems.push(el));
      document.querySelectorAll<HTMLElement>('.stagger').forEach(parent => {
        parent.querySelectorAll<HTMLElement>(':scope > *').forEach(child => revealItems.push(child));
      });

      if (revealItems.length > 0) {
        // Per-element last-opacity cache so we skip style writes
        // when nothing's changed. Crucial — on a long page with
        // many reveal elements, redundant writes cost real frames.
        const lastP = new WeakMap<HTMLElement, number>();

        // Only animate elements that are currently near the
        // viewport (within ±150vh). Far-away elements stay at their
        // initial state in CSS and don't get touched per-frame.
        const nearViewport = new Set<HTMLElement>();
        const visObs = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) nearViewport.add(entry.target as HTMLElement);
            else nearViewport.delete(entry.target as HTMLElement);
          });
        }, { rootMargin: '150% 0% 50% 0%' });
        revealItems.forEach(el => visObs.observe(el));

        let pending = false;
        function update() {
          const vh = window.innerHeight;
          // 70% of viewport height is the reveal window: element
          // starts revealing when its top is at vh, fully revealed
          // when its top is at 30% from the top of the viewport.
          const window70 = vh * 0.7;
          nearViewport.forEach(el => {
            const rect = el.getBoundingClientRect();
            const raw = (vh - rect.top) / window70;
            const p = raw < 0 ? 0 : raw > 1 ? 1 : raw;
            const prev = lastP.get(el);
            if (prev !== undefined && Math.abs(p - prev) < 0.01) return;
            const eased = p * p * (3 - 2 * p);
            el.style.opacity = eased.toFixed(3);
            el.style.transform = `translate3d(0, ${((1 - eased) * 40).toFixed(1)}px, 0)`;
            lastP.set(el, p);
          });
          pending = false;
        }
        window.addEventListener('scroll', () => {
          if (!pending) { pending = true; requestAnimationFrame(update); }
        }, { passive: true });
        window.addEventListener('resize', () => {
          if (!pending) { pending = true; requestAnimationFrame(update); }
        }, { passive: true });

        // Initial reveal for above-the-fold items. The
        // IntersectionObserver fires asynchronously so on first
        // paint, `nearViewport` is empty and `update()` skips every
        // element — leaving above-the-fold content invisible until
        // the user scrolls. Fix by synchronously identifying items
        // clearly within the initial viewport and snapping them to
        // their revealed state. Items below the fold are NOT touched
        // so positioning, stacking contexts and other transform-using
        // systems (data-scroll-scale, focus objects) stay untouched.
        const vhInit = window.innerHeight;
        revealItems.forEach(el => {
          // Skip elements that own their own transform via another
          // system (big-statement headlines use data-scroll-scale).
          if (el.hasAttribute('data-scroll-scale')) return;
          const rect = el.getBoundingClientRect();
          // Clearly within initial viewport — snap to revealed state.
          if (rect.top < vhInit * 0.85 && rect.bottom > 0) {
            el.style.opacity = '1';
            el.style.transform = 'none';
            lastP.set(el, 1);
            nearViewport.add(el);
          }
        });
        update();
      }
    } else {
      // Reduced motion: snap everything visible immediately, no
      // transforms. Headlines, copy and stagger lists all show
      // at full opacity.
      document.querySelectorAll<HTMLElement>('.reveal').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      document.querySelectorAll<HTMLElement>('.stagger > *').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }

    // Counter animation for stats
    const counters = document.querySelectorAll('[data-counter]');
    if (counters.length > 0) {
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const text = el.dataset.counter || '';
            const match = text.match(/^([\d,.]+)/);
            if (match) {
              const targetStr = match[1];
              const targetNum = parseFloat(targetStr.replace(/,/g, ''));
              const hasDecimal = targetStr.includes('.');
              const suffix = text.slice(match[0].length);
              const prefix = el.dataset.counterPrefix || '';
              const duration = 1200;
              const start = performance.now();

              const step = (now: number) => {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = eased * targetNum;
                let display: string;
                if (hasDecimal) {
                  display = current.toFixed(1);
                } else {
                  display = Math.round(current).toLocaleString();
                }
                el.textContent = prefix + display + suffix;
                if (progress < 1) requestAnimationFrame(step);
              };
              requestAnimationFrame(step);
            }
            counterObserver.unobserve(el);
          }
        });
      }, { threshold: 0.5 });

      counters.forEach(el => counterObserver.observe(el));
    }

    // Focus objects — scroll-driven rotation + entrance observer
    const focusObjects = document.querySelectorAll<HTMLElement>('[data-scroll-spin]');
    if (focusObjects.length > 0 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Entrance observer — also toggles is-visible so the infinite
      // spin animation only runs while the object is actually on
      // screen. Each FocusObject runs 56 ring slices in 3D; with a
      // few of them on the page that's a lot of GPU work to chew
      // continuously when they're nowhere near the viewport.
      const enterObs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) entry.target.classList.add('has-entered');
        });
      }, { threshold: 0.05, rootMargin: '0px 0px -10% 0px' });
      focusObjects.forEach(el => enterObs.observe(el));

      // Visibility observer — pauses the spin animation when the
      // object scrolls off-screen.
      const visObs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          entry.target.classList.toggle('is-visible', entry.isIntersecting);
        });
      }, { threshold: 0, rootMargin: '50px 0px 50px 0px' });
      focusObjects.forEach(el => visObs.observe(el));

      // Scroll-driven rotation + Y parallax — single rAF, no per-element listener.
      // Depth is derived from the ring's size: bigger rings sit closer to the
      // camera so they translate more on scroll, smaller ones less. The sign of
      // the spin multiplier also flips parallax direction so half drift up and
      // half drift down, which sells the depth feel.
      const items = [...focusObjects].map(el => {
        const mult = parseFloat(el.style.getPropertyValue('--scrollSpin') || el.getAttribute('data-scroll-spin') || '60');
        const sizePx = parseFloat(el.style.width) || 200;
        // depth 0.4 (background, small) → 1.6 (foreground, large)
        const depth = Math.min(1.6, Math.max(0.4, sizePx / 320));
        const dir = mult >= 0 ? 1 : -1;
        return {
          el,
          mult: isNaN(mult) ? 60 : mult,
          // y-parallax factor, much subtler now and clamped per-frame so rings
          // never drift more than ~120px from their designed position. Without
          // the clamp, absolute scroll-Y on a long page pushes them way past
          // section boundaries and the overflow:hidden clips them to slivers.
          yk: depth * 0.022 * dir,
        };
      });

      let pending = false;
      const update = () => {
        const sy = window.scrollY;
        for (const it of items) {
          const rot = (sy * it.mult) / 350;
          // Clamp the parallax to ±120px so rings stay close to their
          // designed slot regardless of overall page scroll distance.
          const yRaw = sy * it.yk;
          const yPx = Math.max(-120, Math.min(120, yRaw));
          it.el.style.setProperty('--scroll-rot', `${rot}deg`);
          it.el.style.setProperty('--scroll-y', `${yPx.toFixed(1)}px`);
        }
        pending = false;
      };
      window.addEventListener('scroll', () => {
        if (!pending) {
          pending = true;
          requestAnimationFrame(update);
        }
      }, { passive: true });
      update();
    } else if (focusObjects.length > 0) {
      // reduced-motion: just reveal without animation
      focusObjects.forEach(el => el.classList.add('has-entered'));
    }

  </script>
</body>
</html>
