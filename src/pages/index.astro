<script>
  // Hero parallax — subtle mouse tracking on desktop
  const parallaxEls = document.querySelectorAll<HTMLElement>('[data-parallax]');

  if (window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.addEventListener('mousemove', (e) => {
      const x = (e.clientX / window.innerWidth - 0.5);
      const y = (e.clientY / window.innerHeight - 0.5);
      parallaxEls.forEach(el => {
        el.style.transform = `translate3d(${x * -10}px, ${y * -6}px, 0)`;
      });
    }, { passive: true });
  }

  // Forge section — letter reveal on intersection
  const forgeText = document.querySelector<HTMLElement>('.forge-3d-text');
  if (forgeText) {
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          forgeText.classList.add('is-revealed');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    revealObs.observe(forgeText);
  }

  // Forge section — scroll progress (0→1) + 3D type tilt
  const forgeSection = document.querySelector<HTMLElement>('[data-forge]');
  const forgeTilt = document.querySelector<HTMLElement>('[data-forge-tilt]');
  if (forgeSection && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let forgePending = false;
    const updateForge = () => {
      const rect = forgeSection.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = -rect.top;
      const fp = Math.max(0, Math.min(1, total > 0 ? scrolled / total : 0));
      forgeSection.style.setProperty('--fp', fp.toFixed(4));
      if (forgeTilt) {
        // Tilt sweeps from 8°→22° X and -14°→4° Y as the section scrolls past
        const tiltX = 8 + fp * 14;
        const tiltY = -14 + fp * 18;
        const text = forgeTilt.querySelector<HTMLElement>('.forge-3d-text');
        if (text) {
          text.style.setProperty('--forge-tiltX', `${tiltX.toFixed(2)}deg`);
          text.style.setProperty('--forge-tiltY', `${tiltY.toFixed(2)}deg`);
        }
      }
      forgePending = false;
    };
    window.addEventListener('scroll', () => {
      if (!forgePending) {
        forgePending = true;
        requestAnimationFrame(updateForge);
      }
    }, { passive: true });
    updateForge();
  }

  // Scroll-scale headlines — grow as they approach centre of viewport
  const scaleEls = document.querySelectorAll<HTMLElement>('[data-scroll-scale]');
  if (scaleEls.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let scalePending = false;
    const updateScale = () => {
      const vh = window.innerHeight;
      scaleEls.forEach(el => {
        const rect = el.getBoundingClientRect();
        // 0 when element is well below viewport, 1 at centre, back to 0 above
        const centre = rect.top + rect.height / 2;
        const dist = Math.abs(centre - vh / 2) / vh; // 0..1+ where 0 is centred
        const t = Math.max(0, 1 - dist * 1.4);
        // Scale from 0.78 (off-centre) to 1 (centred)
        const s = 0.78 + t * 0.22;
        el.style.transform = `scale(${s.toFixed(3)})`;
      });
      scalePending = false;
    };
    window.addEventListener('scroll', () => {
      if (!scalePending) {
        scalePending = true;
        requestAnimationFrame(updateScale);
      }
    }, { passive: true });
    updateScale();
  }
</script>
