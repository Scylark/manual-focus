<script>
  // Starter diagnostic. Two questions, hardcoded decision tree,
  // mirrors the branching the setup-the-lens skill runs during
  // onboarding. Self-contained — additive only.
  type Result = { title: string; why: string; meta: string; url: string };
  type Q2 = { q: string; options: { label: string; result: Result }[] };

  const TREE: Record<string, { label: string; q2: Q2 }> = {
    brand: {
      label: 'Positioning, voice or naming work',
      q2: {
        q: 'Which of these sounds most like it?',
        options: [
          {
            label: "I've inherited a brand and need an honest read",
            result: {
              title: 'Positioning audit pipeline',
              why: 'A six-pass audit of where the brand actually sits today, run on its real public surface. Everything else in the brand stack builds on this.',
              meta: '2-3 WORKING DAYS · BRAND STACK',
              url: '/lens/brand/positioning-audit-pipeline/',
            },
          },
          {
            label: 'Our content sounds generic, off-voice, or like AI',
            result: {
              title: 'Brand voice extraction',
              why: 'Extracts a falsifiable voice profile from your best writing, then turns it into a scoring rubric every future draft gets held against.',
              meta: '1-2 WORKING DAYS · BRAND STACK',
              url: '/lens/brand/brand-voice-extraction/',
            },
          },
          {
            label: 'We need a name, a sub-brand or a tagline',
            result: {
              title: 'Naming sprint',
              why: 'Compresses a quarter of naming committee into a working day. 400 candidates, phonetic and trademark filters, eight defensible finalists.',
              meta: '1 WORKING DAY · BRAND STACK',
              url: '/lens/brand/naming-sprint/',
            },
