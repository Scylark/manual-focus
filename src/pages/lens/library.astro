---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SEOHead from '../../components/SEOHead.astro';
import { url } from '../../utils/paths';

const entries = await getCollection('lens');
entries.sort((a, b) => {
  const da = (a.data.updatedAt ?? a.data.publishedAt).getTime();
  const db = (b.data.updatedAt ?? b.data.publishedAt).getTime();
  return db - da;
});

const stacks = [
  { id: 'brand', name: 'Brand & positioning', short: 'Brand' },
  { id: 'demand', name: 'Demand & growth', short: 'Demand' },
  { id: 'content', name: 'Content & channels', short: 'Content' },
  { id: 'ops', name: 'Operating systems', short: 'Ops' },
  { id: 'productivity', name: 'Productivity & back office', short: 'Productivity' },
] as const;

const grouped = stacks.map(s => ({
  ...s,
  entries: entries.filter(e => e.data.stack === s.id),
}));

const totalCount = entries.length;
const formatDate = (date: Date) => date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="The Lens. Library" description="The full library behind Your AI marketing team. Brand, demand, content, ops and productivity workflows. Search and browse.">
  <SEOHead
    slot="seo"
    type="service"
    title="The Lens. Library"
    description="Browse the full library behind Your AI marketing team. Brand, demand, content, ops and productivity workflows from the Manual Focus methodology."
    breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'The Lens', url: '/lens' }, { name: 'Library', url: '/lens/library' }]}
  />

  <section class="library-head">
    <div class="container">
      <a href={url('/lens')} class="library-back mono">← THE LENS</a>
      <div class="eyebrow">LIBRARY</div>
      <h1 class="library-title">{totalCount} playbooks, five stacks.</h1>
      <p class="library-lead">The methodology Manual Focus brings to AI marketing work. Filter by stack, by stage, by channel. Pull what fits the brief in front of you. <strong>New to The Lens?</strong> <a href={url('/lens/start-here')} class="library-cap-link">Start here</a> for the orientation guide. Each playbook is honest about what AI can and cannot reliably do, so see the <a href={url('/lens/capabilities')} class="library-cap-link">capability reference</a>.</p>

      <div class="library-stack-nav" role="navigation" aria-label="Stack filters">
        {stacks.map(s => (
          <a href={url(`/lens/${s.id}`)} class="library-stack-chip">
            <span class="chip-stack mono">{s.short.toUpperCase()}</span>
            <span class="chip-count mono">{grouped.find(g => g.id === s.id)?.entries.length ?? 0} ENTRIES</span>
          </a>
        ))}
      </div>

      <div class="library-toolbar">
        <div class="library-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <path d="m20 20-3.5-3.5"/>
          </svg>
          <label for="library-q" class="sr-only">Search the library</label>
          <input
            type="search"
            id="library-q"
            data-library-search
            placeholder='Try "attribution", "email", "naming"...'
            autocomplete="off"
          />
        </div>
        <div class="library-stage-chips" role="group" aria-label="Filter by brand stage">
          {['pre-launch', 'launch', 'growth', 'scale', 'enterprise'].map(stage => (
            <button type="button" class="stage-chip mono" data-stage-filter={stage}>{stage.toUpperCase()}</button>
          ))}
        </div>
        <p class="library-result-count mono" data-library-count aria-live="polite"></p>
      </div>
    </div>
  </section>

  {grouped.map(group => group.entries.length > 0 && (
    <section class="library-stack-section" data-library-section>
      <div class="container">
        <div class="library-stack-head">
          <div class="eyebrow">STACK · {group.short.toUpperCase()}</div>
          <h2>{group.name}</h2>
          <a href={url(`/lens/${group.id}`)} class="library-stack-link mono">VIEW STACK →</a>
        </div>
        <div class="library-grid">
          {group.entries.map(entry => {
            const slug = entry.id.split('/').pop()?.replace(/\.md$/, '') ?? entry.id;
            return (
              <a
                href={url(`/lens/${entry.data.stack}/${slug}`)}
                class="library-card"
                data-library-card
                data-search={`${entry.data.title} ${entry.data.description} ${entry.data.outputs} ${entry.data.channels.join(' ')}`.toLowerCase()}
                data-stages={entry.data.brandStage.join(',')}
              >
                <div class="card-head mono">
                  <span class="card-stack">{group.short.toUpperCase()}</span>
                  {entry.data.status === 'updated' && <span class="card-flag flag-updated">UPDATED</span>}
                  {entry.data.status === 'beta' && <span class="card-flag flag-beta">BETA</span>}
                  {entry.data.preview && <span class="card-flag flag-preview">FREE</span>}
                </div>
                <h3 class="card-title">{entry.data.title}</h3>
                <p class="card-desc">{entry.data.description}</p>
                <div class="card-foot mono">
                  <span>{entry.data.shipTime}</span>
                  <span>·</span>
                  <span>{entry.data.readMin} min read</span>
                  <span>·</span>
                  <span>{formatDate(entry.data.updatedAt ?? entry.data.publishedAt)}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  ))}
</Base>

<style>
  .library-head {
    padding-block: var(--space-xl) var(--space-lg);
    border-bottom: 1px solid var(--color-line);
  }
  .library-back {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: var(--space-md);
  }
  .library-back:hover { color: var(--color-text); }
  .library-title {
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-block: var(--space-sm);
  }
  .library-lead {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: 1.5;
    max-width: 60ch;
    margin-bottom: var(--space-lg);
  }
  .library-cap-link {
    color: var(--color-cta-start);
    text-decoration: underline;
  }
  .library-stack-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }
  @media (min-width: 769px) {
    .library-stack-nav { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  .library-stack-chip {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: var(--space-md);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    text-decoration: none;
    background: var(--color-bg);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .library-stack-chip:hover {
    border-color: var(--color-cta-start);
    background: var(--color-bg-alt);
  }
  .chip-stack {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--color-cta-start);
  }
  .chip-count {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
  }

  .library-stack-section {
    padding-block: var(--space-xl);
    border-bottom: 1px solid var(--color-line);
  }
  .library-stack-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-sm) var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .library-stack-head h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: 1.1;
    color: var(--color-text);
    margin: 0;
    flex: 1 1 auto;
  }
  .library-stack-link {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--color-cta-start);
    text-decoration: none;
  }
  .library-stack-link:hover { color: var(--color-text); }

  .library-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
  @media (min-width: 769px) {
    .library-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .library-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  .library-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    background: var(--color-bg);
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    cursor: pointer;
  }
  .library-card::after {
    content: "READ PLAYBOOK →";
    position: absolute;
    bottom: var(--space-md);
    right: var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--color-cta-start);
    opacity: 0;
    transition: opacity 0.2s ease;
    background: var(--color-bg-alt);
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    pointer-events: none;
  }
  .library-card:hover {
    border-color: var(--color-cta-start);
    background: var(--color-bg-alt);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }
  .library-card:hover::after {
    opacity: 1;
  }
  .library-card:hover .card-title {
    color: var(--color-cta-start);
  }
  .library-card .card-title {
    transition: color 0.2s ease;
  }
  .card-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
  }
  .card-stack { color: var(--color-cta-start); }
  .card-flag {
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    line-height: 1;
  }
  .flag-updated {
    color: #7CA89A;
    border: 1px solid #7CA89A;
  }
  .flag-beta {
    color: var(--color-cta-start);
    border: 1px solid var(--color-cta-start);
  }
  .flag-preview {
    color: var(--color-text);
    border: 1px solid var(--color-cta-start);
    background: rgba(196, 90, 44, 0.08);
  }
  .card-title {
    font-size: clamp(1.1rem, 1.4vw, 1.4rem);
    line-height: 1.2;
    color: var(--color-text);
    margin: 0;
  }
  .card-desc {
    color: var(--color-text-secondary);
    line-height: 1.5;
    flex: 1 1 auto;
    font-size: var(--font-size-body);
  }
  .card-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-line);
  }

  /* Search + stage filter toolbar */
  .library-toolbar {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .library-search {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    background: var(--color-bg-alt);
    transition: border-color 0.2s ease;
    max-width: 560px;
  }
  .library-search:focus-within {
    border-color: var(--color-cta-start);
  }
  .library-search svg {
    width: 1rem;
    height: 1rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
  .library-search input {
    flex: 1 1 auto;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-size: 16px;
    font-family: var(--font-family);
  }
  .library-search input::placeholder { color: var(--color-text-muted); }
  .library-stage-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .stage-chip {
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .stage-chip:hover { color: var(--color-text); border-color: var(--color-text); }
  .stage-chip.is-active {
    color: var(--color-bg);
    background: var(--color-cta-start);
    border-color: var(--color-cta-start);
  }
  .library-result-count {
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    min-height: 1em;
    margin: 0;
  }

  /* Filter states. Hidden cards and emptied sections collapse. */
  .library-card.is-filtered { display: none; }
  .library-stack-section.is-empty { display: none; }
</style>

<script>
  // Library live filter. Pure DOM toggling against the data
  // attributes baked in at build time — no fetch, instant.
  const searchInput = document.querySelector<HTMLInputElement>('[data-library-search]');
  const stageChips = [...document.querySelectorAll<HTMLButtonElement>('[data-stage-filter]')];
  const cards = [...document.querySelectorAll<HTMLElement>('[data-library-card]')];
  const sections = [...document.querySelectorAll<HTMLElement>('[data-library-section]')];
  const countEl = document.querySelector<HTMLElement>('[data-library-count]');

  if (searchInput && cards.length) {
    const activeStages = new Set<string>();

    const apply = () => {
      const q = searchInput.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const matchesText = !q || (card.dataset.search ?? '').includes(q);
        const cardStages = (card.dataset.stages ?? '').split(',');
        const matchesStage = !activeStages.size || cardStages.some((s) => activeStages.has(s));
        const show = matchesText && matchesStage;
        card.classList.toggle('is-filtered', !show);
        if (show) visible++;
      });
      sections.forEach((section) => {
        const any = section.querySelector('[data-library-card]:not(.is-filtered)');
        section.classList.toggle('is-empty', !any);
      });
      if (countEl) {
        const filtering = q || activeStages.size;
        countEl.textContent = filtering
          ? `${visible} PLAYBOOK${visible === 1 ? '' : 'S'} MATCH`
          : '';
      }
    };

    searchInput.addEventListener('input', apply);
    stageChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const stage = chip.dataset.stageFilter ?? '';
        if (activeStages.has(stage)) {
          activeStages.delete(stage);
          chip.classList.remove('is-active');
        } else {
          activeStages.add(stage);
          chip.classList.add('is-active');
        }
        apply();
      });
    });

    // Let the rest of the site deep-link into a pre-filtered library
    // via /lens/library/?q=attribution
    const params = new URLSearchParams(window.location.search);
    const preset = params.get('q');
    if (preset) {
      searchInput.value = preset;
      apply();
    }
  }
</script>
