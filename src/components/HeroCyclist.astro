---
/**
 * HeroCyclist — autoplay background video hero.
 *
 * Immersity AI generates the depth-displacement drone-pass directly
 * as an MP4 with the camera motion already animated. We just play it
 * as a background video — no shaders, no layer separation, no
 * possible silhouette artefacts. The motion in the file IS the
 * effect the spec describes.
 *
 * The poster image is the static JPG so first paint is sharp while
 * the video buffers, and reduced-motion preference falls back to the
 * static poster permanently (the <video> still renders but doesn't
 * autoplay — the poster keeps showing).
 */
import { url } from '../utils/paths';

interface Props {
  video?: string;
  fallbackImage?: string;
}

const {
  video = '/images/hero-cyclist.mp4',
  fallbackImage = '/images/hero-cyclist.jpg',
} = Astro.props;

const videoUrl = url(video);
const fallbackUrl = url(fallbackImage);
---
<section class="hero-cyclist" data-hero-cyclist>
  <video
    class="hero-cyclist-video"
    src={videoUrl}
    poster={fallbackUrl}
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
  ></video>

  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Bias toward the rider on the right so the cropping eats the
       empty sky on the left, not the subject. Matches the IMG
       fallback elsewhere. */
    object-position: 65% center;
    z-index: 0;
    /* will-change keeps GPU compositing on for the video element so
       the playback stays smooth on lower-end hardware. */
    will-change: transform;
  }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }
  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }
  @media (max-width: 768px) {
    .hero-cyclist { min-height: 560px; }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }

  /* Reduced motion: pause the video so the poster image stays. */
  @media (prefers-reduced-motion: reduce) {
    .hero-cyclist-video {
      /* The poster shows until the video buffers; pausing keeps the
         poster as the visible frame. */
      animation-play-state: paused;
    }
  }
</style>

<script>
  // Respect prefers-reduced-motion by pausing the video so the poster
  // image stays as the visible frame. Without this the CSS media query
  // can't stop a <video> from playing — that has to be done in JS.
  function initHero() {
    const video = document.querySelector<HTMLVideoElement>('.hero-cyclist-video');
    if (!video) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      video.pause();
      video.removeAttribute('autoplay');
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
