---
/**
 * HeroCyclist — depth-displacement scroll hero, rewritten.
 *
 * One illustrated cyclist (1920×1080) plus a matching greyscale depth
 * map. A fragment shader does the heavy lifting, sampling the depth
 * per-pixel and offsetting the colour-texture lookup so foreground
 * pixels parallax further than background pixels as the visitor
 * scrolls. The plane stays a flat fullscreen quad, so there is no
 * subdivided geometry to produce facet artifacts and the source
 * pixels render at native sharpness.
 *
 * The section is full viewport height (100svh) so the hero copy has
 * room to breathe without clipping, and the image fills via
 * object-fit: cover on the IMG, mirrored in the shader with a
 * cover-fit UV transform so the WebGL render lines up with the IMG.
 *
 * Skips WebGL on reduced-motion, touch and mobile widths — the IMG
 * stays visible as the static fallback.
 */
import { url } from '../utils/paths';

interface Props {
  texture?: string;
  depthMap?: string;
  fallbackImage?: string;
  /**
   * Depth multiplier for the parallax shift. 0.12 gives ≈12% UV
   * separation between foreground (cyclist) and background (sky) at
   * full scroll — a clearly visible drone-pass read. Bounded by the
   * shader's MAX_SHIFT inset so the lookup never leaves the image.
   */
  strength?: number;
  /** Idle camera oscillation on top of the scroll-driven arc. */
  autoplay?: boolean;
}

const {
  texture = '/images/hero-cyclist.webp',
  depthMap = '/images/hero-cyclist-depth.png',
  fallbackImage = '/images/hero-cyclist.jpg',
  strength = 0.18,
  autoplay = true,
} = Astro.props;

const textureUrl = url(texture);
const depthUrl = url(depthMap);
const fallbackUrl = url(fallbackImage);
---
<section
  class="hero-cyclist"
  data-hero-cyclist
  data-texture={textureUrl}
  data-depth={depthUrl}
  data-strength={String(strength)}
  data-autoplay={autoplay ? 'true' : 'false'}
>
  <img
    class="hero-cyclist-img"
    src={fallbackUrl}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <canvas class="hero-cyclist-canvas" aria-hidden="true"></canvas>
  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    /* Full viewport height so the hero copy fits without clipping. svh
       keeps mobile address-bar collapse/expand from jumping the layout. */
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-img,
  .hero-cyclist-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-cyclist-img {
    z-index: 0;
    object-fit: cover;
    /* Bias toward the rider on the right so cropping eats the empty
       sky on the left rather than the subject. */
    object-position: 65% center;
  }
  .hero-cyclist-canvas {
    z-index: 1;
    /* Hidden until WebGL renders its first frame so we never see a
       partial/blank canvas. No fade — IMG and canvas swap instantly so
       the parallax-shifted canvas never composites over the static IMG
       (which would double the rider during the fade window). */
    visibility: hidden;
  }
  .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-canvas { visibility: visible; }
  .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { visibility: hidden; }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    /* Soft left-side darkening so the headline reads against the dawn
       sky. Fades to clear by 60% so the cyclist stays untouched. */
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    /* Top padding clears the fixed nav, bottom clears the scroll hint. */
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  /* Slot child pulled to the left half so headline sits on the empty
     sky, not over the cyclist on the right. */
  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }

  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }
  @media (max-width: 768px) {
    .hero-cyclist {
      /* Slightly less tall on mobile so the section doesn't dwarf
         the rest of the page on phones. */
      min-height: 560px;
    }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      /* Stronger top-down gradient on mobile so the headline reads
         no matter where the crop lands. */
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }

  /* Skip WebGL on reduced-motion and mobile. IMG stays visible. */
  @media (prefers-reduced-motion: reduce), (max-width: 768px) {
    .hero-cyclist-canvas { display: none; }
    .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { visibility: visible; }
  }
</style>

<script>
  import * as THREE from 'three';

  // The source image dimensions, used by the shader's cover-fit transform
  // so the WebGL render matches the IMG's object-fit: cover exactly.
  const IMG_W = 1920;
  const IMG_H = 1080;

  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;

    // Skip WebGL on small viewports, touch devices, and reduced-motion.
    // The IMG fallback is already in place — nothing else to do.
    const skipWebGL =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      window.matchMedia('(hover: none) and (pointer: coarse)').matches ||
      window.matchMedia('(max-width: 768px)').matches;
    if (skipWebGL) {
      section.dataset.webglReady = 'true';
      return;
    }

    const canvas = section.querySelector<HTMLCanvasElement>('.hero-cyclist-canvas');
    if (!canvas) return;

    const textureUrl = section.dataset.texture!;
    const depthUrl = section.dataset.depth!;
    const strength = parseFloat(section.dataset.strength || '0.18');
    const autoplay = section.dataset.autoplay === 'true';

    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: false,
        antialias: false,
        powerPreference: 'high-performance',
      });
    } catch {
      section.dataset.webglReady = 'true';
      return;
    }
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    renderer.setPixelRatio(dpr);
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    // Fullscreen quad approach. The vertex shader emits clip-space
    // coordinates directly so the geometry always fills the viewport,
    // independent of camera state. All parallax happens in the
    // fragment shader.
    const scene = new THREE.Scene();
    const camera = new THREE.Camera();
    const geometry = new THREE.PlaneGeometry(2, 2, 1, 1);

    const material = new THREE.ShaderMaterial({
      uniforms: {
        uTexture: { value: null as THREE.Texture | null },
        uDepth: { value: null as THREE.Texture | null },
        uCanvas: { value: new THREE.Vector2(1, 1) },
        uImage: { value: new THREE.Vector2(IMG_W, IMG_H) },
        uOffset: { value: new THREE.Vector2(0, 0) },
        uStrength: { value: strength },
      },
      vertexShader: /* glsl */ `
        varying vec2 vUv;
        void main() {
          vUv = uv;
          // Emit clip-space directly. position is the 2×2 plane corners,
          // already in NDC, so we skip the matrix multiply entirely.
          gl_Position = vec4(position.xy, 0.0, 1.0);
        }
      `,
      fragmentShader: /* glsl */ `
        precision highp float;
        uniform sampler2D uTexture;
        uniform sampler2D uDepth;
        uniform vec2 uCanvas;
        uniform vec2 uImage;
        uniform vec2 uOffset;
        uniform float uStrength;
        varying vec2 vUv;

        // CSS object-fit: cover, recreated in UV space. Returns the
        // image-UV that corresponds to the canvas-UV \`uv\`, cropping
        // whichever axis overflows so the image fills the canvas.
        vec2 cover(vec2 uv) {
          float canvasA = uCanvas.x / uCanvas.y;
          float imageA = uImage.x / uImage.y;
          vec2 scale = vec2(1.0);
          vec2 offset = vec2(0.0);
          if (canvasA > imageA) {
            // Canvas wider than image — fill width, crop top/bottom.
            scale.y = imageA / canvasA;
            offset.y = (1.0 - scale.y) * 0.5;
          } else {
            // Canvas taller than image — fill height, crop sides. Bias
            // toward x=0.65 so the rider stays in frame, matching the
            // IMG's object-position: 65% center.
            scale.x = canvasA / imageA;
            offset.x = (1.0 - scale.x) * 0.65;
          }
          return uv * scale + offset;
        }

        // 5-tap Gaussian-ish depth lookup. The depth map for an
        // illustrated subject has hard pixel-perfect edges where the
        // rider meets the sky, which a single texture2D sample would
        // read as a step from 1 to 0. Parallax shifts at that step
        // smear the silhouette into the background as a dark halo.
        // Averaging a small cross around the lookup softens the depth
        // transition over ~2 pixels so the shift gradient at the edge
        // is smooth and the halo disappears.
        float sampleDepth(vec2 uv) {
          vec2 px = vec2(1.0) / uImage;
          float c = texture2D(uDepth, uv).r;
          float l = texture2D(uDepth, uv - vec2(px.x, 0.0)).r;
          float r = texture2D(uDepth, uv + vec2(px.x, 0.0)).r;
          float u = texture2D(uDepth, uv - vec2(0.0, px.y)).r;
          float d = texture2D(uDepth, uv + vec2(0.0, px.y)).r;
          return c * 0.5 + (l + r + u + d) * 0.125;
        }

        void main() {
          // Inset the sampling region by MAX_SHIFT on every side so the
          // parallax offset never pushes the texture lookup outside the
          // image bounds (which would smear the clamped edge).
          const float MAX_SHIFT = 0.08;
          vec2 baseUv = cover(vUv);
          baseUv = baseUv * (1.0 - 2.0 * MAX_SHIFT) + vec2(MAX_SHIFT);

          // Centred depth: -0.5 at sky/distant, +0.5 at the rider.
          float depth = sampleDepth(baseUv) - 0.5;

          // Foreground (positive depth) shifts opposite to the camera
          // offset — standard motion-parallax. Background shifts with
          // the camera. uStrength tunes the depth-to-pixel mapping.
          vec2 shift = uOffset * depth * uStrength;

          gl_FragColor = texture2D(uTexture, baseUv + shift);
        }
      `,
    });

    const mesh = new THREE.Mesh(geometry, material);
    // Render the fullscreen quad without any camera transforms (matrices
    // are identity-friendly). We set frustumCulled false so a stale
    // frustum from the empty camera can't cull the mesh.
    mesh.frustumCulled = false;
    scene.add(mesh);

    function configureTexture(t: THREE.Texture, isColor: boolean) {
      t.colorSpace = isColor ? THREE.SRGBColorSpace : THREE.NoColorSpace;
      t.minFilter = THREE.LinearFilter;
      t.magFilter = THREE.LinearFilter;
      t.generateMipmaps = false;
      t.anisotropy = renderer.capabilities.getMaxAnisotropy();
      t.wrapS = THREE.ClampToEdgeWrapping;
      t.wrapT = THREE.ClampToEdgeWrapping;
      t.needsUpdate = true;
    }

    const loader = new THREE.TextureLoader();
    let loaded = 0;
    function onLoad() {
      if (++loaded < 2) return;
      // Two RAFs to let layout settle before measuring the canvas.
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          fitCanvas();
          renderer.render(scene, camera);
          section.dataset.webglReady = 'true';
          startLoop();
        });
      });
    }
    function onTexErr() {
      // If either texture fails to load via WebGL (rare, usually a
      // browser-specific WebP decode issue) the IMG fallback is already
      // on screen, so we just hide the canvas and leave the IMG in place
      // rather than swapping in a broken layer.
      const c = section.querySelector<HTMLElement>('.hero-cyclist-canvas');
      if (c) c.style.display = 'none';
    }
    loader.load(textureUrl, (t) => {
      configureTexture(t, true);
      material.uniforms.uTexture.value = t;
      onLoad();
    }, undefined, onTexErr);
    loader.load(depthUrl, (t) => {
      configureTexture(t, false);
      material.uniforms.uDepth.value = t;
      onLoad();
    }, undefined, onTexErr);

    function fitCanvas() {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      if (w <= 0 || h <= 0) return;
      renderer.setSize(w, h, false);
      material.uniforms.uCanvas.value.set(w, h);
    }
    const ro = new ResizeObserver(() => fitCanvas());
    ro.observe(canvas);

    // Scroll progress through the section, 0 at top, 1 at bottom.
    let scrollProgress = 0;
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const span = rect.height;
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / span));
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();

    // Pause render when hero is off-screen.
    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    let frameId: number | null = null;
    function startLoop() {
      function frame(now: number) {
        if (inView) {
          const t = now / 1000;
          // Scroll-driven offset: as the visitor scrolls through the
          // hero the virtual camera arcs right and dips down. Smoothstep
          // ease so the parallax accelerates into the scroll rather
          // than jerking on the first pixel.
          const ease = scrollProgress * scrollProgress * (3 - 2 * scrollProgress);
          const scrollX = ease * 0.50;
          const scrollY = ease * -0.30;
          // Autoplay micro-drift: heavier than the scroll-driven shift so
          // the depth read is obvious at rest, before the visitor scrolls.
          // Two slightly different periods so X and Y don't trace a simple
          // ellipse and feel motorised.
          const driftX = autoplay ? Math.sin(t * 0.32) * 0.35 : 0;
          const driftY = autoplay ? Math.cos(t * 0.23) * 0.20 : 0;
          material.uniforms.uOffset.value.set(scrollX + driftX, scrollY + driftY);
          renderer.render(scene, camera);
        }
        frameId = requestAnimationFrame(frame);
      }
      frameId = requestAnimationFrame(frame);
    }

    window.addEventListener('pagehide', () => {
      if (frameId != null) cancelAnimationFrame(frameId);
      ro.disconnect();
      renderer.dispose();
      geometry.dispose();
      material.dispose();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
