---
interface Props {
  animate?: boolean;
}
const { animate = false } = Astro.props;
---
<div class:list={['logo-animation', { 'logo-animation--animate': animate }]} aria-hidden="true">
  <svg viewBox="-10 -50 110 240" xmlns="http://www.w3.org/2000/svg" class="logo-circles" overflow="visible">
    <g class="spin-wrapper spin-wrapper--top">
      <circle class="circle-top" cx="45" cy="45" r="42" fill="none" stroke="#1D1D1B" stroke-width="5.86" stroke-miterlimit="10"/>
    </g>
    <g class="spin-wrapper spin-wrapper--bottom">
      <circle class="circle-bottom" cx="45" cy="93" r="42" fill="none" stroke="#1D1D1B" stroke-width="5.86" stroke-miterlimit="10"/>
    </g>
  </svg>
</div>

<style>
  .logo-animation {
    width: 80px;
    height: auto;
  }

  .logo-circles {
    width: 100%;
    height: auto;
  }

  /* Phase 1: circles drift in */
  .logo-animation--animate .circle-top {
    animation: drift-top 2.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    transform-origin: 45px 45px;
  }

  .logo-animation--animate .circle-bottom {
    animation: drift-bottom 2.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    transform-origin: 45px 93px;
  }

  /* Phase 2: wrappers spin around the midpoint between circles (45, 69) */
  .logo-animation--animate .spin-wrapper {
    transform-origin: 45px 69px;
  }

  .logo-animation--animate .spin-wrapper--top {
    animation: spin 1.8s cubic-bezier(0.4, 0, 0.2, 1) 2.5s forwards;
  }

  .logo-animation--animate .spin-wrapper--bottom {
    animation: spin 1.8s cubic-bezier(0.4, 0, 0.2, 1) 2.5s forwards;
  }

  @keyframes drift-top {
    0% {
      transform: translateY(-60px) rotate(-90deg) scale(0.6);
      opacity: 0;
    }
    20% {
      opacity: 0.4;
    }
    50% {
      transform: translateY(-10px) rotate(-15deg) scale(0.95);
      opacity: 0.8;
    }
    100% {
      transform: translateY(0) rotate(0deg) scale(1);
      opacity: 1;
    }
  }

  @keyframes drift-bottom {
    0% {
      transform: translateY(60px) rotate(90deg) scale(0.6);
      opacity: 0;
    }
    20% {
      opacity: 0.4;
    }
    50% {
      transform: translateY(10px) rotate(15deg) scale(0.95);
      opacity: 0.8;
    }
    100% {
      transform: translateY(0) rotate(0deg) scale(1);
      opacity: 1;
    }
  }

  /* Two full rotations (720deg) then back to rest */
  @keyframes spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(720deg); }
  }
</style>
