---
// Site-wide command palette. Opens on Cmd+K / Ctrl+K or the nav
// search button ([data-palette-open]). Lazily fetches the build-time
// search index on first open, then filters client-side with a
// lightweight scorer. Fully self-contained: no dependency on the
// reveal/animation systems, additive DOM only.
import { url } from '../utils/paths';
const indexUrl = url('/lens/search-index.json').replace(/\/$/, '');
---
<div class="palette-overlay" data-palette hidden>
  <div class="palette-backdrop" data-palette-close></div>
  <div class="palette-panel" role="dialog" aria-modal="true" aria-label="Search Manual Focus">
    <div class="palette-input-row">
      <svg class="palette-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/>
        <path d="m20 20-3.5-3.5"/>
      </svg>
      <input
        type="text"
        class="palette-input"
        placeholder="Search playbooks, skills, pages..."
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        data-palette-input
      />
      <button class="palette-esc mono" data-palette-close type="button">ESC</button>
    </div>
    <div class="palette-results" data-palette-results role="listbox"></div>
    <div class="palette-foot mono" aria-hidden="true">
      <span>↑↓ NAVIGATE</span>
      <span>↵ OPEN</span>
      <span>46 PLAYBOOKS · 26 SKILLS</span>
    </div>
  </div>
</div>

{/* is:global because result rows are created at runtime by the
    script below — JS-created nodes don't carry Astro's scope
    attribute, so scoped styles would never reach them. Every
    selector is .palette-* prefixed, so global is safe. */}
<style is:global>
  .palette-overlay {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 12vh var(--space-md) var(--space-md);
  }
  .palette-overlay[hidden] { display: none; }
  .palette-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .palette-panel {
    position: relative;
    width: 100%;
    max-width: 640px;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: 10px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 70vh;
    animation: paletteIn 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes paletteIn {
    from { transform: translateY(8px) scale(0.985); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .palette-panel { animation: none; }
  }

  .palette-input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--color-line);
  }
  .palette-glyph {
    width: 18px;
    height: 18px;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
  .palette-input {
    flex: 1 1 auto;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    /* 16px floor stops iOS zooming the page on focus */
    font-size: 16px;
    font-family: var(--font-family);
  }
  .palette-input::placeholder { color: var(--color-text-muted); }
  .palette-esc {
    flex-shrink: 0;
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
  }
  .palette-esc:hover { color: var(--color-text); }

  .palette-results {
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0.5rem;
    flex: 1 1 auto;
  }
  .palette-results:empty { display: none; }

  .palette-group-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    padding: 0.65rem 0.75rem 0.35rem;
  }
  .palette-item {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    width: 100%;
    text-align: left;
    padding: 0.6rem 0.75rem;
    border: none;
    background: transparent;
    border-radius: 6px;
    cursor: pointer;
    text-decoration: none;
  }
  .palette-item[aria-selected="true"],
  .palette-item:hover {
    background: var(--color-bg-alt);
  }
  .palette-item[aria-selected="true"] .palette-item-title {
    color: var(--color-cta-start);
  }
  .palette-item-tag {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    color: var(--color-cta-start);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.15rem 0.5rem;
    min-width: 4.6rem;
    text-align: center;
  }
  .palette-item-title {
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.3;
  }
  .palette-item-desc {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1 1 auto;
    min-width: 0;
  }
  .palette-empty {
    padding: 1.25rem 0.85rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .palette-foot {
    display: flex;
    gap: 1.25rem;
    padding: 0.6rem 1rem;
    border-top: 1px solid var(--color-line);
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
  }
  .palette-foot span:last-child { margin-left: auto; }
  @media (max-width: 600px) {
    .palette-overlay { padding-top: 6vh; }
    .palette-item-desc { display: none; }
    .palette-foot span:first-child,
    .palette-foot span:nth-child(2) { display: none; }
  }
</style>

<script define:vars={{ indexUrl }}>
  (() => {
    const overlay = document.querySelector('[data-palette]');
    if (!overlay) return;
    const input = overlay.querySelector('[data-palette-input]');
    const results = overlay.querySelector('[data-palette-results]');
    let index = null;
    let items = [];
    let selected = 0;

    const GROUP_ORDER = ['playbook', 'skill', 'page'];
    const GROUP_LABELS = { playbook: 'PLAYBOOKS', skill: 'SKILLS', page: 'PAGES' };

    async function loadIndex() {
      if (index) return index;
      try {
        const res = await fetch(indexUrl);
        index = await res.json();
      } catch {
        index = [];
      }
      return index;
    }

    // Scorer: exact-prefix beats word-boundary beats substring beats
    // description hit. Returns 0 for no match.
    function score(entry, q) {
      const title = entry.title.toLowerCase();
      const desc = (entry.desc || '').toLowerCase();
      if (title.startsWith(q)) return 100;
      if (title.split(/[\s-]+/).some((w) => w.startsWith(q))) return 80;
      if (title.includes(q)) return 60;
      if (desc.includes(q)) return 30;
      return 0;
    }

    function defaultRows() {
      // Empty query: quick links only, so the panel opens instantly
      // useful instead of dumping all 80 entries.
      return (index || []).filter((e) => e.type === 'page').slice(0, 7);
    }

    function render(query) {
      const q = query.trim().toLowerCase();
      let matched;
      if (!q) {
        matched = defaultRows();
      } else {
        matched = (index || [])
          .map((e) => ({ e, s: score(e, q) }))
          .filter((r) => r.s > 0)
          .sort((a, b) => b.s - a.s)
          .slice(0, 12)
          .map((r) => r.e);
      }

      results.innerHTML = '';
      items = [];
      selected = 0;

      if (!matched.length) {
        const empty = document.createElement('div');
        empty.className = 'palette-empty';
        empty.textContent = `Nothing for "${query}" here. `;
        // Hand the query off to the library's full-text filter,
        // which also matches outputs and channels.
        const a = document.createElement('a');
        a.className = 'palette-item';
        a.href = `/lens/library/?q=${encodeURIComponent(query)}`;
        a.innerHTML = `
          <span class="palette-item-tag">LIBRARY</span>
          <span class="palette-item-title"></span>`;
        a.querySelector('.palette-item-title').textContent = `Search the library for "${query}" →`;
        results.appendChild(empty);
        results.appendChild(a);
        items.push(a);
        select(0);
        return;
      }

      for (const group of GROUP_ORDER) {
        const inGroup = matched.filter((e) => e.type === group);
        if (!inGroup.length) continue;
        const label = document.createElement('div');
        label.className = 'palette-group-label';
        label.textContent = GROUP_LABELS[group];
        results.appendChild(label);
        for (const entry of inGroup) {
          const a = document.createElement('a');
          a.className = 'palette-item';
          a.href = entry.url;
          a.setAttribute('role', 'option');
          a.innerHTML = `
            <span class="palette-item-tag">${entry.stack.toUpperCase()}</span>
            <span class="palette-item-title"></span>
            <span class="palette-item-desc"></span>`;
          a.querySelector('.palette-item-title').textContent = entry.title;
          a.querySelector('.palette-item-desc').textContent = entry.desc || '';
          a.addEventListener('mouseenter', () => select(items.indexOf(a)));
          results.appendChild(a);
          items.push(a);
        }
      }
      select(0);
    }

    function select(i) {
      if (!items.length) return;
      selected = Math.max(0, Math.min(i, items.length - 1));
      items.forEach((el, idx) => el.setAttribute('aria-selected', idx === selected ? 'true' : 'false'));
      items[selected].scrollIntoView({ block: 'nearest' });
    }

    async function open() {
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      input.value = '';
      await loadIndex();
      render('');
      input.focus();
    }

    function close() {
      overlay.hidden = true;
      document.body.style.overflow = '';
    }

    document.addEventListener('keydown', (ev) => {
      if ((ev.metaKey || ev.ctrlKey) && ev.key.toLowerCase() === 'k') {
        ev.preventDefault();
        overlay.hidden ? open() : close();
        return;
      }
      if (overlay.hidden) return;
      if (ev.key === 'Escape') { ev.preventDefault(); close(); }
      if (ev.key === 'ArrowDown') { ev.preventDefault(); select(selected + 1); }
      if (ev.key === 'ArrowUp') { ev.preventDefault(); select(selected - 1); }
      if (ev.key === 'Enter' && items[selected]) {
        ev.preventDefault();
        window.location.href = items[selected].href;
      }
    });

    input.addEventListener('input', () => render(input.value));
    overlay.querySelectorAll('[data-palette-close]').forEach((el) =>
      el.addEventListener('click', close)
    );
    document.querySelectorAll('[data-palette-open]').forEach((el) =>
      el.addEventListener('click', (ev) => { ev.preventDefault(); open(); })
    );
  })();
</script>
