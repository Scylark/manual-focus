---
import Base from '../../layouts/Base.astro';
import SEOHead from '../../components/SEOHead.astro';
import BlogCard from '../../components/BlogCard.astro';
import { url } from '../../utils/paths';
import { formatTag, readingTime } from '../../utils/blog';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---
<Base title="Marketing blog — AI, content engines and senior-operator perspective" description="The Manual Focus blog. Senior marketing operators writing on AI in marketing, content engines, owned/earned/paid channels, and what actually works in the AI era.">
  <SEOHead slot="seo" type="website" title="Marketing blog — AI, content engines and senior-operator perspective" description="The Manual Focus blog. Senior marketing operators writing on AI in marketing, content engines, owned/earned/paid channels, and what actually works in the AI era." breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Blog', url: '/blog' }]} />

  <section class="section">
    <div class="container">
      <h1>Perspective</h1>
      <p class="lead">Opinions, insights, and the occasional provocation.</p>

      <nav class="tag-filter" aria-label="Filter by tag">
        <a href={url('/blog')} class="tag tag-current">All</a>
        {allTags.map(tag => (
          <a href={url(`/blog/tag/${tag}/`)} class="tag">{formatTag(tag)}</a>
        ))}
      </nav>

      <div class="blog-grid">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            minutes={readingTime(post.body ?? '')}
          />
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .lead {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-md);
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .tag {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-line);
    border-radius: 2px;
  }

  .tag:hover,
  .tag-current {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
