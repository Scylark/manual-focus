---
import Base from '../layouts/Base.astro';
import SEOHead from '../components/SEOHead.astro';
import BlogCard from '../components/BlogCard.astro';
import Spray from '../components/Spray.astro';
import FocusObject from '../components/FocusObject.astro';
import { url } from '../utils/paths';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---
<Base title="Home" description="Manual Focus is a marketing agency for ambitious brands. Senior operators using AI as leverage to ship brand, demand and growth in a fraction of the time. Particular depth in endurance and sports brands." hideNavUntilScroll>
  <SEOHead slot="seo" type="website" title="Home" description="Manual Focus is a marketing agency for ambitious brands. Senior operators using AI as leverage to ship brand, demand and growth in a fraction of the time. Particular depth in endurance and sports brands." />

  <!-- HERO -->
  <section class="hero">
    <!-- 3D focus objects scattered -->
    <FocusObject size={380} tiltX={62} tiltY={-15} spin={90} scrollSpin={120} style="top: 8vh; right: 4vw;" />
    <FocusObject size={200} tiltX={50} tiltY={22} tiltZ={-12} spin={-110} scrollSpin={-180} hueA="#00E5FF" hueB="#FF2D78" style="bottom: 14vh; right: 24vw;" enterFrom="left" />

    <div class="container hero-inner">
      <div class="hero-eyebrow">
        <span class="dot"></span>
        <span class="mono">MANUAL FOCUS · LONDON</span>
      </div>

      <h1 class="hero-headline" data-parallax>
        <span class="hero-line hero-line-1">Brand. Demand. Growth.</span>
        <span class="hero-line hero-line-2">
          <em class="hero-italic">
            <span class="char" style="--i: 0">A</span><span class="char" style="--i: 1">I</span><span class="char" style="--i: 2">&nbsp;</span><span class="char" style="--i: 3">a</span><span class="char" style="--i: 4">c</span><span class="char" style="--i: 5">c</span><span class="char" style="--i: 6">e</span><span class="char" style="--i: 7">l</span><span class="char" style="--i: 8">e</span><span class="char" style="--i: 9">r</span><span class="char" style="--i: 10">a</span><span class="char" style="--i: 11">t</span><span class="char" style="--i: 12">e</span><span class="char" style="--i: 13">d</span><span class="char" style="--i: 14">.</span>
          </em>
        </span>
      </h1>

      <div class="hero-meta">
        <p class="hero-sub">
          Manual Focus is a marketing agency for ambitious brands. Senior operators using AI
          as the leverage, with particular depth in
          <strong>endurance and sports brands</strong>.
        </p>
        <div class="hero-ctas">
          <a href={url('/enquire')} class="btn-cta">Book a working session</a>
          <a href={url('/services')} class="btn-ghost">How we work together</a>
        </div>
      </div>

      <div class="hero-scroll-hint" aria-hidden="true">
        <span class="mono">SCROLL</span>
        <span class="scroll-arrow"></span>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <section class="marquee-band" aria-hidden="true">
    <div class="marquee">
      <div class="marquee-track">
        <span>FRACTIONAL CMO</span><span class="marquee-dot">●</span>
        <span>STRATEGIC ADVISOR</span><span class="marquee-dot">●</span>
        <span>BUILD &amp; HAND OVER</span><span class="marquee-dot">●</span>
        <span>BRAND</span><span class="marquee-dot">●</span>
        <span>DEMAND</span><span class="marquee-dot">●</span>
        <span>GROWTH</span><span class="marquee-dot">●</span>
        <span>WEB</span><span class="marquee-dot">●</span>
        <span>PR</span><span class="marquee-dot">●</span>
        <span>PERFORMANCE</span><span class="marquee-dot">●</span>
        <span>ENDURANCE BRANDS</span><span class="marquee-dot">●</span>
        <span>THE FORGE</span><span class="marquee-dot">●</span>
        <span>FRACTIONAL CMO</span><span class="marquee-dot">●</span>
        <span>STRATEGIC ADVISOR</span><span class="marquee-dot">●</span>
        <span>BUILD &amp; HAND OVER</span><span class="marquee-dot">●</span>
        <span>BRAND</span><span class="marquee-dot">●</span>
        <span>DEMAND</span><span class="marquee-dot">●</span>
        <span>GROWTH</span><span class="marquee-dot">●</span>
        <span>WEB</span><span class="marquee-dot">●</span>
        <span>PR</span><span class="marquee-dot">●</span>
        <span>PERFORMANCE</span><span class="marquee-dot">●</span>
        <span>ENDURANCE BRANDS</span><span class="marquee-dot">●</span>
        <span>THE FORGE</span><span class="marquee-dot">●</span>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="section problem-section">
    <FocusObject size={420} tiltX={70} tiltY={25} spin={140} scrollSpin={90} hueA="#FF2D78" hueB="#C026D3" style="top: -80px; right: -120px;" enterFrom="right" />
    <FocusObject size={220} tiltX={45} tiltY={-30} spin={-100} scrollSpin={-150} hueA="#00E5FF" hueB="#FF2D78" style="bottom: 10%; left: -40px;" enterFrom="left" />

    <div class="container">
      <div class="eyebrow">001 · THE PROBLEM</div>
      <h2 class="big-statement reveal" data-scroll-scale style="transform-origin: left center;">
        Flat campaigns result in<br/>
        <span class="gradient-text">diminishing returns.</span>
      </h2>
      <div class="problem-grid">
        <p class="problem-copy reveal">
          Most marketing still launches the same way it has for a decade, with a six-week
          campaign, a content flurry, a paid push and the hope something sticks. A flat
          campaign produces flat results regardless of brief quality, budget size or how
          shiny the launch deck looks.
        </p>
        <p class="problem-copy reveal">
          We build something that keeps working after launch week ends, with owned, earned
          and paid wired together through the Forge. The system learns from each campaign
          and improves as new AI models arrive, so growth holds steady instead of tailing off.
        </p>
      </div>
    </div>
  </section>

  <!-- THREE WAYS TO WORK TOGETHER -->
  <section class="section ways-section">
    <FocusObject size={280} tiltX={50} tiltY={15} spin={-130} scrollSpin={-110} hueA="#FF2D78" hueB="#00E5FF" style="top: 6%; right: -100px;" enterFrom="right" />
    <FocusObject size={160} tiltX={68} tiltY={-25} spin={90} scrollSpin={70} style="bottom: 8%; left: 5%;" enterFrom="bottom" />

    <div class="container">
      <div class="eyebrow">002 · HOW WE WORK TOGETHER</div>
      <h2 class="big-statement reveal" data-scroll-scale style="transform-origin: left center;">
        Three ways to engage.<br/>
        One product, <span class="gradient-text">fully run by us</span>.
      </h2>

      <div class="ways-grid stagger">
        <article class="way-card">
          <div class="way-num mono">/01 · STRATEGIC ADVISOR</div>
          <h3>The senior voice in the room</h3>
          <p class="way-for">For companies with a marketing team but no senior leader running it.</p>
          <ul class="way-list">
            <li>Weekly working sessions on what to do next</li>
            <li>Reviews of work in progress</li>
            <li>Briefings on the AI tooling worth using, and where it fits your team's workflow</li>
            <li>Hiring and team-shape advice</li>
          </ul>
          <p class="way-shape mono">1–2 days a month. Day rate or monthly retainer.</p>
          <a href={url('/enquire')} class="btn-ghost way-cta">Book a session</a>
        </article>

        <article class="way-card way-card-featured">
          <div class="way-num mono"><span>/02 · FRACTIONAL CMO</span><span class="way-flag">MOST CHOSEN</span></div>
          <h3>Embedded senior marketer</h3>
          <p class="way-for">For companies that need senior marketing leadership without a full-time hire.</p>
          <ul class="way-list">
            <li>Set the marketing thesis and 90-day plan</li>
            <li>Lead and grow the existing team</li>
            <li>Embed AI and emerging tech into the workflows your team already runs</li>
            <li>Ship key pieces of the plan with that leverage in place</li>
          </ul>
          <p class="way-shape mono">1–2 days a week. Three-month minimum.</p>
          <a href={url('/enquire')} class="btn-ghost way-cta">Book a session</a>
        </article>

        <article class="way-card">
          <div class="way-num mono">/03 · BUILD &amp; HAND OVER</div>
          <h3>Scoped outcome, shipped fast</h3>
          <p class="way-for">For companies that know what they need built, and want it shipped fast.</p>
          <ul class="way-list">
            <li>Launches, SEO programs, content engines, brand refreshes</li>
            <li>Headless and rapid web builds on Shopify, BigCommerce, WooCommerce and WordPress</li>
            <li>AI and emerging tech wired into the build, not bolted on after</li>
            <li>Handed back with docs and training, fixed scope, fixed timeline, fixed price</li>
          </ul>
          <p class="way-shape mono">Project-based. Typical builds: 4–12 weeks.</p>
          <a href={url('/enquire')} class="btn-ghost way-cta">Book a session</a>
        </article>
      </div>

      <!-- /04 PRODUCT — AI workflows we own and run -->
      <article class="way-product reveal">
        <div class="way-product-inner">
          <div class="way-product-head">
            <div class="way-num mono"><span>/04 · MANUAL FOCUS · AI</span><span class="way-flag way-flag-alt">PRODUCT</span></div>
            <h3 class="way-product-headline">We run the AI workflows. You get the output.</h3>
            <p class="way-for way-product-for">For CTOs, CMOs and teams who don't have the bandwidth to keep up with new models, build pipelines or learn another tool every week.</p>
          </div>
          <div class="way-product-body">
            <ul class="way-list way-product-list">
              <li>Content planning, wireframing and production owned end-to-end by Manual Focus</li>
              <li>Pipelines maintained, models swapped in as they ship</li>
              <li>Output delivered on agreed cadence, in your brand, ready to use</li>
              <li>No internal training, no tool sprawl, no learning curve</li>
            </ul>
            <div class="way-product-foot">
              <p class="way-shape mono">Monthly retainer. Output on cadence.</p>
              <a href={url('/enquire')} class="btn-cta way-product-cta">Book a working session</a>
            </div>
          </div>
        </div>
      </article>

      <div class="services-cta reveal">
        <p class="services-note">Across endurance and sports brands, AI, fintech and digital assets. Every engagement starts with a 30-minute working session, free.</p>
        <a href={url('/services')} class="btn-ghost">Read the detail</a>
      </div>
    </div>
  </section>

  <!-- THE FORGE — 3D type sticky focal moment -->
  <section class="forge-section" data-forge>
    <div class="forge-sticky">
      <div class="forge-3d-wrap" data-forge-tilt>
        <h2 class="forge-3d-text">
          <span class="forge-line forge-line-1"><span class="fchar" style="--i:0">T</span><span class="fchar" style="--i:1">H</span><span class="fchar" style="--i:2">E</span></span>
          <span class="forge-line forge-line-2"><span class="fchar" style="--i:3">F</span><span class="fchar" style="--i:4">O</span><span class="fchar" style="--i:5">R</span><span class="fchar" style="--i:6">G</span><span class="fchar" style="--i:7">E</span></span>
        </h2>
      </div>
    </div>
  </section>

  <!-- WHY THE AI STAYS SHARP -->
  <section class="section forge-body-section">
    <div class="container">
      <div class="eyebrow">003 · WHY THE AI STAYS SHARP</div>
      <h3 class="forge-headline">The <span class="gradient-text">Forge</span> keeps us current.</h3>
      <p class="forge-copy">
        We're part of a collective of senior operators called the Foundry. The Foundry shares
        AI tooling through a platform called the Forge. That's why we ship at machine speed,
        and why our capability keeps getting sharper as new AI models arrive. The shared part
        is tooling and pipelines, not strategy or content.
      </p>
      <div class="forge-stats">
        <div class="forge-stat">
          <div class="forge-stat-num">50+</div>
          <div class="forge-stat-label">years of senior marketing experience across the collective</div>
        </div>
        <div class="forge-stat">
          <div class="forge-stat-num">SHARED</div>
          <div class="forge-stat-label">tooling and pipelines, not strategy or content</div>
        </div>
        <div class="forge-stat">
          <div class="forge-stat-num">LIVE</div>
          <div class="forge-stat-label">new AI models added as they ship</div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section stats-section section-alt">
    <FocusObject size={320} tiltX={55} tiltY={-20} spin={120} scrollSpin={140} hueA="#00E5FF" hueB="#FF2D78" style="top: -60px; left: -80px;" enterFrom="left" />

    <div class="container">
      <div class="eyebrow">004 · WHAT IT'S WORTH</div>
      <h2 class="stats-headline reveal">More marketing output, in a fraction of the time.</h2>
      <div class="stats-grid stagger">
        <div class="stat-card">
          <div class="stat-value" data-counter="4x" data-counter-prefix="">0x</div>
          <div class="stat-label">faster brief-to-live, on average</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" data-counter="3" data-counter-prefix="">0</div>
          <div class="stat-label">channels covered (owned, earned and paid) from day one</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" data-counter="60%" data-counter-prefix="">0%</div>
          <div class="stat-label">less time on production, more on strategy</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" data-counter="50+" data-counter-prefix="">0+</div>
          <div class="stat-label">years of marketing experience, combined</div>
        </div>
      </div>
      <p class="stats-disclaimer mono">* Across recent engagements. Best results when the strategy was right to begin with.</p>
    </div>
  </section>

  <!-- BRAND LOGOS -->
  <section class="section section-alt logos-section">
    <FocusObject size={200} tiltX={40} tiltY={30} spin={100} scrollSpin={80} hueA="#00E5FF" hueB="#FF2D78" style="bottom: -40px; right: -40px;" enterFrom="bottom" />

    <div class="container">
      <div class="eyebrow">005 · IN THE WILD</div>
      <h2 class="reveal logos-headline">Endurance and sports brands we've shipped with.</h2>
      <div class="logo-bar stagger">
        <span class="brand-mark brand-display">Classified</span>
        <span class="brand-mark brand-serif">Wahoo</span>
        <span class="brand-mark brand-display">Wattbike</span>
        <span class="brand-mark brand-mono">Ribble</span>
        <span class="brand-mark brand-display">RGT</span>
        <span class="brand-mark brand-serif">motif <em>AI</em></span>
        <span class="brand-mark brand-mono">Muuvr</span>
        <span class="brand-mark brand-display">Planet X</span>
        <span class="brand-mark brand-serif">Pelotan</span>
      </div>
      <p class="logos-note reveal">And further afield in AI, fintech, sports tech, hardware and digital assets.</p>
    </div>
  </section>

  <!-- CREDIBILITY -->
  <section class="section credibility-section">
    <FocusObject size={760} tiltX={58} tiltY={-12} spin={180} scrollSpin={60} style="top: -40px; right: -8%;" enterFrom="right" />
    <FocusObject size={320} tiltX={48} tiltY={22} tiltZ={-8} spin={-140} scrollSpin={-90} hueA="#00E5FF" hueB="#FF2D78" style="bottom: -40px; right: 18%; opacity: 0.85;" enterFrom="bottom" />

    <div class="container">
      <div class="credibility-grid">
        <div class="credibility-copy">
          <div class="eyebrow">006 · WHO WE ARE</div>
          <h2 class="reveal">
            Operators first.<br/>
            <span class="gradient-text">Marketers always.</span>
          </h2>
          <p class="reveal">
            Manual Focus is a marketing agency led by James Vickers, with 15+ years running
            brand, demand, product and growth across AI, fintech, sports tech, hardware and
            digital assets. James co-founded RGT Cycling and took it from 19k to 350k users
            before Wahoo Fitness acquired it. Around him, the Foundry brings senior operators
            with deep marketing CVs of their own. We do the hard miles on AI so the marketing
            side gets the upside.
          </p>
          {/* TODO: replace href with the Foundry website URL once available */}
          <a href="#foundry-tbd" target="_blank" rel="noopener noreferrer" class="btn-ghost reveal">Meet the Foundry ↗</a>
        </div>
        <div class="credibility-mark" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- BLOG / PERSPECTIVE -->
  <section class="section section-alt">
    <FocusObject size={180} tiltX={55} tiltY={20} spin={-90} scrollSpin={-100} hueA="#FF2D78" hueB="#00E5FF" style="top: 8%; left: -40px;" enterFrom="left" />

    <div class="container">
      <div class="eyebrow">007 · PERSPECTIVE</div>
      <h2 class="reveal">Notes from the work.</h2>
      <div class="blog-grid stagger">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA CLOSE -->
  <section class="section cta-close">
    <FocusObject size={520} tiltX={60} tiltY={-20} spin={160} scrollSpin={100} style="top: -100px; left: -120px;" enterFrom="left" />
    <FocusObject size={360} tiltX={50} tiltY={25} spin={-130} scrollSpin={-90} hueA="#00E5FF" hueB="#FF2D78" style="bottom: -80px; right: -60px;" enterFrom="right" />

    <div class="container cta-close-inner">
      <h2 class="cta-headline reveal">
        Marketing that should<br/>
        be <span class="gradient-text">working harder</span>?
      </h2>
      <p class="cta-sub reveal">30-minute working session, free. We walk through where AI fits in your marketing function. If we click, we plan the next 90 days.</p>
      <a href={url('/enquire')} class="btn-cta reveal">Book a working session</a>
    </div>
  </section>
</Base>

<style>
  /* ============================
     HERO
     ============================ */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding-block: var(--space-xl);
  }

  .hero-inner {
    position: relative;
    z-index: 3;
    display: grid;
    gap: var(--space-md);
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: var(--color-text-secondary);
  }
  .hero-eyebrow .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-cta-start);
    box-shadow: 0 0 12px var(--color-cta-start);
    animation: pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  .hero-headline {
    font-size: clamp(2.75rem, 8vw, 8.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-top: var(--space-sm);
    max-width: 1100px;
  }

  .hero-line {
    display: block;
    opacity: 0;
    transform: translateY(40px);
    animation: hero-line-in 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-line-1 { animation-delay: 0.15s; }
  /* Line 2 fades the container; chars handle their own animation */
  .hero-line-2 {
    animation-delay: 0.25s;
    perspective: 1200px;
    transform-style: preserve-3d;
  }
  .hero-line-3 { animation-delay: 0.45s; }

  @keyframes hero-line-in {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Per-character flip-in for the punchline */
  .char {
    display: inline-block;
    opacity: 0;
    transform: translateY(60px) rotateX(-80deg);
    transform-origin: 50% 100% -10px;
    backface-visibility: hidden;
    animation: char-in 0.85s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.7s + var(--i) * 0.055s);
    /* Apply gradient directly to each char — background-clip:text on parent
       doesn't reach through inline-block children */
    font-style: italic;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    /* Extend the padding box past the italic glyph's top-right overhang so the
       gradient covers the full letter instead of clipping at the box edge.
       Negative margin-right keeps letter spacing visually identical. */
    padding-right: 0.18em;
    margin-right: -0.18em;
  }
  @keyframes char-in {
    to { opacity: 1; transform: translateY(0) rotateX(0); }
  }

  .hero-italic {
    font-style: italic;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-meta {
    margin-top: var(--space-md);
    max-width: 720px;
  }

  .hero-sub {
    font-size: var(--font-size-lg);
    color: var(--color-text);
  }
  .hero-sub strong {
    font-weight: 700;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
  }
  .scroll-arrow {
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, var(--color-text-secondary), transparent);
    animation: scrollHint 2s ease-in-out infinite;
  }
  @keyframes scrollHint {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50% { transform: translateY(8px); opacity: 1; }
  }

  /* ============================
     MARQUEE
     ============================ */
  .marquee-band {
    background: var(--color-text);
    color: var(--color-bg);
    overflow: hidden;
    padding-block: 1.2rem;
    border-block: 1px solid var(--color-text);
    position: relative;
    z-index: 5;
  }
  .marquee {
    display: flex;
    width: max-content;
  }
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    white-space: nowrap;
    animation: marquee 35s linear infinite;
    padding-right: 2.5rem;
  }
  .marquee-dot {
    color: var(--color-cta-start);
    font-size: 0.6em;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ============================
     FORGE — 3D type sticky focal moment
     ============================ */
  .forge-section {
    position: relative;
    height: 180vh;
    background: linear-gradient(180deg, transparent 0%, rgba(10,10,11,0.6) 30%, rgba(10,10,11,0.6) 70%, transparent 100%);
  }
  .forge-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
