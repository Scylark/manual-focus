---
/**
 * HeroCyclist — scroll-driven graphic hero.
 *
 * The cyclist image fought against scroll-scrub because Midjourney
 * composed it for a static frame. The site is graphic-led anyway, so
 * the hero is now built from the brand's own visual language — the
 * Manual Focus interlocking rings — scaled massive and scroll-
 * choreographed into a wordmark reveal.
 *
 * Choreography across 0..1 scroll progress through the section:
 *  0.00 → 0.40: rings huge + centred, spinning slowly, breathing
 *  0.40 → 0.60: rings scale up, rotate faster, separate vertically
 *  0.55 → 0.75: rings fade out as the MANUAL FOCUS wordmark fades in
 *  0.70 → 0.90: wordmark settles, hero copy fades in beneath it
 *  0.90 → 1.00: wordmark shrinks to the final eyebrow position
 *
 * Mobile + reduced-motion: holds the final frame (wordmark resting,
 * hero copy visible). No scroll-scrub.
 */
---
<section class="hero-scroll" data-hero-scroll>
  <div class="hero-scroll-sticky">
    <!-- Two interlocking rings, scaled massive. SVG so they stay
         razor-sharp at any size and we get a real stroke gradient. -->
    <svg
      class="hero-rings"
      viewBox="-10 -50 110 240"
      preserveAspectRatio="xMidYMid meet"
      aria-hidden="true"
      data-rings
    >
      <defs>
        <linearGradient id="hero-ring-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="var(--color-cta-start)" />
          <stop offset="50%" stop-color="var(--color-cta-mid)" />
          <stop offset="100%" stop-color="var(--color-cta-end)" />
        </linearGradient>
      </defs>
      <circle
        class="hero-ring hero-ring-top"
        cx="45" cy="45" r="42"
        fill="none"
        stroke="url(#hero-ring-gradient)"
        stroke-width="5.86"
        stroke-miterlimit="10"
      />
      <circle
        class="hero-ring hero-ring-bot"
        cx="45" cy="93" r="42"
        fill="none"
        stroke="url(#hero-ring-gradient)"
        stroke-width="5.86"
        stroke-miterlimit="10"
      />
    </svg>

    <!-- Wordmark that reveals as the rings break apart. Centred at
         the resting position, scroll choreographs the transform. -->
    <div class="hero-wordmark" data-wordmark aria-hidden="true">
      <span class="hero-wordmark-line">MANUAL</span>
      <span class="hero-wordmark-line">FOCUS</span>
    </div>

    <!-- Slot for the actual hero copy (eyebrow, headline, CTAs).
         Fades in once the wordmark has resolved. -->
    <div class="hero-content" data-content>
      <slot />
    </div>
  </div>
</section>

<style>
  .hero-scroll {
    position: relative;
    width: 100%;
    /* Generous scroll runway with a long deliberate "hold" phase
       on the wordmark — about 5 viewport-heights of scroll, ~4 of
       which is animated (rest is sticky release). The hold lands
       at ~1.5 viewport-heights of scrolling, which feels like the
       wordmark genuinely sits before handing off. */
    height: 500vh;
    background: var(--color-bg);
    isolation: isolate;
    overflow: clip;
  }

  .hero-scroll-sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
  }

  /* MASSIVE rings — width and height set so the SVG box dominates the
     viewport. The viewBox is set up to centre the ring pair around
     (45, 69) in viewBox units, which we offset with transform-origin
     so transforms rotate / scale around the visual centre. */
  .hero-rings {
    position: absolute;
    inset: 0;
    margin: auto;
    width: min(160vh, 100vw);
    height: min(160vh, 100vw);
    /* Set initially — JS overrides via the animation loop. */
    transform: translateZ(0) scale(1) rotate(0deg);
    transform-origin: 50% 50%;
    will-change: transform, opacity;
    z-index: 1;
  }

  .hero-ring {
    /* Slight inner highlight pulse — gives the rings a sense of
       presence even when static. */
    filter: drop-shadow(0 8px 32px var(--color-cta-mid));
  }

  .hero-wordmark {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(0.2rem, 1vh, 0.6rem);
    z-index: 2;
    opacity: 0;
    pointer-events: none;
    will-change: opacity, transform;
    transform: translateZ(0) scale(0.7);
    transform-origin: 50% 50%;
  }

  .hero-wordmark-line {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(4rem, 18vw, 16rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    /* Faint glow behind the type so the gradient pops against the
       background even before the rings fade out. */
    filter: drop-shadow(0 0 40px rgba(255, 255, 255, 0.08));
  }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 3;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    opacity: 0;
    pointer-events: none;
    will-change: opacity, transform;
    transform: translate3d(0, 24px, 0);
  }

  .hero-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }

  @media (max-width: 1024px) {
    .hero-content > :global(*) { max-width: 72%; }
  }

  /* Mobile: keep the scrolly animation — CSS transforms + a JS
     scroll listener handle touch fine — but shorter section height so
     the scroll-dwell doesn't feel like padding on a phone, and
     smaller ring base size so it fits a narrower viewport. */
  @media (max-width: 768px), (hover: none) and (pointer: coarse) {
    .hero-scroll {
      /* 360vh on mobile — proportionally shorter than desktop's 500vh
         since each vh is a smaller absolute distance on a phone, but
         still leaves a clear hold phase on the wordmark. */
      height: 360vh;
    }
    .hero-scroll-sticky {
      min-height: 560px;
    }
    .hero-rings {
      width: min(100vh, 90vw);
      height: min(100vh, 90vw);
    }
    .hero-content {
      padding-block: clamp(3rem, 8vh, 5rem);
    }
    .hero-content > :global(*) { max-width: 100%; }
  }

  /* Reduced-motion: hold the resting state, no scroll animation. */
  @media (prefers-reduced-motion: reduce) {
    .hero-scroll { height: 100svh; min-height: 560px; }
    .hero-scroll-sticky { position: relative; height: 100%; }
    .hero-rings {
      width: min(80vh, 60vw);
      transform: scale(0.6) translate(0, -30%);
      opacity: 0.5;
    }
    .hero-wordmark { display: none; }
    .hero-content {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }
    .hero-content > :global(*) { max-width: 100%; }
  }
</style>

<script>
  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-scroll]');
    if (!section) return;
    const rings = section.querySelector<HTMLElement>('[data-rings]');
    const wordmark = section.querySelector<HTMLElement>('[data-wordmark]');
    const content = section.querySelector<HTMLElement>('[data-content]');
    if (!rings || !wordmark || !content) return;

    // Only bail on reduced-motion. The CSS-transform animation
    // performs well on mobile — Safari and Android Chrome both
    // batch RAF efficiently against touch scroll events.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Scroll progress 0..1 across the sticky-pinned distance.
    let scrollProgress = 0;
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const usefulSpan = Math.max(1, rect.height - window.innerHeight);
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / usefulSpan));
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    window.addEventListener('resize', updateScroll, { passive: true });
    updateScroll();

    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    /** Linear interpolation between a..b across t in [0, 1]. */
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    /** Maps src in [srcMin, srcMax] to [0, 1], clamped. */
    const norm = (src: number, srcMin: number, srcMax: number) =>
      Math.max(0, Math.min(1, (src - srcMin) / (srcMax - srcMin)));
    /** Smoothstep — eases the 0..1 input on a cubic curve. */
    const smooth = (t: number) => t * t * (3 - 2 * t);

    // Idle drift timestamp — adds a tiny constant rotation so the
    // rings have life on first paint, before any scroll.
    let startTime = performance.now();

    function frame(now: number) {
      requestAnimationFrame(frame);
      if (!inView) return;

      const p = scrollProgress;
      const t = (now - startTime) / 1000;

      // ── Rings ──────────────────────────────────────────────────
      // Phase A (0.00..0.55): present, scaling slightly up, rotating
      // Phase B (0.40..0.70): scale up further + rotate faster + fade
      // Idle drift: a constant slow rotation on top of the scroll one.
      const ringIdleRot = t * 8; // 8 deg/s baseline rotation
      const ringScrollRot = p * 540; // 1.5 full turns by end
      const ringRotation = ringIdleRot + ringScrollRot;
      const ringScale = lerp(1.0, 2.4, smooth(p));
      const ringSeparate = lerp(0, 60, smooth(norm(p, 0.25, 0.50))); // viewBox-units of vertical spread
      const ringOpacity = 1 - smooth(norm(p, 0.30, 0.50));

      rings.style.transform = `translateZ(0) scale(${ringScale.toFixed(3)}) rotate(${ringRotation.toFixed(2)}deg)`;
      rings.style.opacity = String(ringOpacity);
      // Separate the two circles by repositioning them along Y.
      const top = rings.querySelector<SVGCircleElement>('.hero-ring-top');
      const bot = rings.querySelector<SVGCircleElement>('.hero-ring-bot');
      if (top && bot) {
        top.setAttribute('cy', String(45 - ringSeparate));
        bot.setAttribute('cy', String(93 + ringSeparate));
      }

      // ── Wordmark ──────────────────────────────────────────────
      // Fades in 0.40..0.55, HOLDS at full size 0.55..0.94 — the
      // deliberate dwell is now ~40% of the total scroll progress.
      // With the section at 500vh that's ~160vh of pure dwell time
      // on the wordmark, ≈1.5 viewport-heights of scrolling before
      // the hand-off begins. Fade-out 0.94..1.00.
      const wordFadeIn = smooth(norm(p, 0.40, 0.55));
      const wordFadeOut = smooth(norm(p, 0.94, 1.00));
      const wordOpacity = wordFadeIn * (1 - wordFadeOut);
      const wordScale = lerp(0.7, 1.0, wordFadeIn) * lerp(1.0, 0.55, wordFadeOut);
      const wordTranslateY = lerp(40, 0, wordFadeIn) - lerp(0, 40, wordFadeOut);

      wordmark.style.opacity = String(wordOpacity);
      wordmark.style.transform = `translate3d(0, ${wordTranslateY.toFixed(2)}px, 0) scale(${wordScale.toFixed(3)})`;

      // ── Hero content ──────────────────────────────────────────
      // Fades + slides up across 0.92..1.00 — quick hand-off at the
      // end, while the wordmark is still finishing its fade-out.
      const contentT = smooth(norm(p, 0.92, 1.0));
      content.style.opacity = String(contentT);
      content.style.transform = `translate3d(0, ${lerp(24, 0, contentT).toFixed(2)}px, 0)`;
      content.style.pointerEvents = contentT > 0.5 ? 'auto' : 'none';
    }
    requestAnimationFrame(frame);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
