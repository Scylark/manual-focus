---
/**
 * HeroCyclist — scroll-driven image sequence hero.
 *
 * Immersity AI generated the depth-displacement drone-pass as an MP4,
 * but video scrubbing via currentTime is choppy on every browser
 * (video decoders aren't built for seeking). The reliable pattern
 * used by Apple product pages is to render the animation as a JPG
 * sequence and swap which frame is visible based on scroll position.
 *
 * Build-time: extract every 5th frame from hero-cyclist.mp4 at
 * 1280×720 JPG → /images/hero-frames/frame-001.jpg ... frame-060.jpg.
 *   ffmpeg -i hero-cyclist.mp4 -vf "select=not(mod(n\,5)),scale=1280:720" \
 *          -vsync vfr -q:v 4 hero-frames/frame-%03d.jpg
 *
 * Runtime: preload all 60 frames into the image cache, then on scroll
 * compute the target frame and set the visible <img>'s src. Browsers
 * swap cached images instantly with no decode lag, so the scrub is
 * pixel-precise and tear-free.
 *
 * Mobile + reduced-motion fall back to the static JPG.
 */
import { url } from '../utils/paths';

interface Props {
  /** Folder containing the JPG sequence (frame-001.jpg, ...). */
  framesDir?: string;
  /** Number of frames in the sequence. */
  frameCount?: number;
  fallbackImage?: string;
}

const {
  framesDir = '/images/hero-frames',
  frameCount = 60,
  fallbackImage = '/images/hero-cyclist.jpg',
} = Astro.props;

const firstFrameUrl = url(`${framesDir}/frame-001.jpg`);
const fallbackUrl = url(fallbackImage);
const framesDirUrl = url(framesDir);
---
<section
  class="hero-cyclist"
  data-hero-cyclist
  data-frames-dir={framesDirUrl}
  data-frame-count={String(frameCount)}
>
  <div class="hero-cyclist-sticky">
    <img
      class="hero-cyclist-frame"
      src={firstFrameUrl}
      alt=""
      aria-hidden="true"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />

    <div class="hero-cyclist-overlay" aria-hidden="true"></div>

    <div class="hero-cyclist-content">
      <slot />
    </div>
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    /* Taller than the viewport so the sticky child has scroll
       distance to scrub through the frame sequence. ~7 viewport-
       heights of total scroll, ~6 of useful scrub. */
    height: 260vh;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
  }

  .hero-cyclist-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    z-index: 0;
    /* Disable image dragging — purely decorative. */
    -webkit-user-drag: none;
    user-select: none;
  }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }
  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }

  /* Mobile + touch: drop the scrolly behaviour. The 160vh of extra
     scroll distance is annoying on a phone, and the scroll-scrub
     adds nothing because the visitor can't really see frame-by-
     frame parallax on a small screen. Just show the first frame. */
  @media (max-width: 768px), (hover: none) and (pointer: coarse) {
    .hero-cyclist { height: 100svh; min-height: 560px; }
    .hero-cyclist-sticky { position: relative; height: 100%; }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }
</style>

<script>
  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;
    const imgEl = section.querySelector<HTMLImageElement>('.hero-cyclist-frame');
    if (!imgEl) return;

    // Reduced-motion + mobile + touch: hold the first frame, no scrub.
    const skipScrub =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      window.matchMedia('(max-width: 768px)').matches ||
      window.matchMedia('(hover: none) and (pointer: coarse)').matches;
    if (skipScrub) return;

    const framesDir = section.dataset.framesDir!;
    const frameCount = parseInt(section.dataset.frameCount || '60', 10);

    // Preload the entire sequence into the browser cache so the src
    // swap on scroll is instant (cached images don't re-decode).
    const frameUrls: string[] = [];
    for (let i = 1; i <= frameCount; i++) {
      const n = String(i).padStart(3, '0');
      const u = `${framesDir}/frame-${n}.jpg`;
      frameUrls.push(u);
      const pre = new Image();
      pre.src = u;
    }

    // Track scroll progress through the sticky-pinned scroll range
    // (section height minus viewport height — the distance the
    // sticky child stays in place).
    let scrollProgress = 0;
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const usefulSpan = Math.max(1, rect.height - window.innerHeight);
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / usefulSpan));
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    window.addEventListener('resize', updateScroll, { passive: true });
    updateScroll();

    // Pause work when the hero is off-screen.
    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    // RAF loop: pick the frame for the current scroll position and
    // swap the visible <img>'s src. Caching means this is essentially
    // free — no decode, no flash, no tear.
    let lastFrame = -1;
    function frame() {
      requestAnimationFrame(frame);
      if (!inView) return;
      // Smoothstep so the parallax accelerates into the scroll
      // rather than jerking on the first pixel.
      const ease = scrollProgress * scrollProgress * (3 - 2 * scrollProgress);
      const idx = Math.min(frameCount - 1, Math.floor(ease * frameCount));
      if (idx !== lastFrame) {
        imgEl.src = frameUrls[idx];
        lastFrame = idx;
      }
    }
    requestAnimationFrame(frame);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
