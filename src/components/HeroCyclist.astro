---
/**
 * HeroCyclist — depth-displacement scroll hero, built to the spec at
 * /Users/jamesvickers/Downloads/manual-focus-hero-spec.md.
 *
 * Per the brief: Three.js + a subdivided plane + a vertex-displacement
 * shader. The depth map pushes per-vertex Z offsets so the flat image
 * becomes a relief, and a perspective camera arcs through scroll
 * producing real parallax — foreground reads closer, background further,
 * silhouettes occlude. Not fragment-shader parallax mapping (the trick
 * that kept producing silhouette artefacts on the cyclist).
 *
 * Scroll progress 0..1 drives a shallow 15° arc on x + z with a tiny
 * y ease so the rider appears to rotate slightly in view. An optional
 * autoplay micro-drift breathes the camera at rest so the hero has
 * life before the visitor scrolls. Skipped on mobile and reduced-motion,
 * which fall back to the static IMG.
 */
import { url } from '../utils/paths';

interface Props {
  texture?: string;
  depthMap?: string;
  fallbackImage?: string;
  /** Z-displacement world units. 0.30 = 30% of plane-to-camera distance. */
  strength?: number;
  /** Idle camera oscillation on top of the scroll-driven arc. */
  autoplay?: boolean;
}

const {
  texture = '/images/hero-cyclist.webp',
  depthMap = '/images/hero-cyclist-depth.png',
  fallbackImage = '/images/hero-cyclist.jpg',
  strength = 0.10,
  autoplay = true,
} = Astro.props;

const textureUrl = url(texture);
const depthUrl = url(depthMap);
const fallbackUrl = url(fallbackImage);
---
<section
  class="hero-cyclist"
  data-hero-cyclist
  data-texture={textureUrl}
  data-depth={depthUrl}
  data-strength={String(strength)}
  data-autoplay={autoplay ? 'true' : 'false'}
>
  <img
    class="hero-cyclist-img"
    src={fallbackUrl}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <canvas class="hero-cyclist-canvas" aria-hidden="true"></canvas>
  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-img,
  .hero-cyclist-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-cyclist-img {
    z-index: 0;
    object-fit: cover;
    object-position: 65% center;
  }
  .hero-cyclist-canvas {
    z-index: 1;
    /* Hidden until the first WebGL frame lands, then swapped in instantly
       (no opacity crossfade — that produces a visible ghost-pair during
       the fade window). */
    visibility: hidden;
  }
  .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-canvas { visibility: visible; }
  .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { visibility: hidden; }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }
  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }
  @media (max-width: 768px) {
    .hero-cyclist { min-height: 560px; }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }

  /* Skip WebGL on reduced-motion and mobile. IMG stays visible. */
  @media (prefers-reduced-motion: reduce), (max-width: 768px) {
    .hero-cyclist-canvas { display: none; }
    .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { visibility: visible; }
  }
</style>

<script>
  import * as THREE from 'three';

  const IMG_W = 1920;
  const IMG_H = 1080;
  const IMAGE_ASPECT = IMG_W / IMG_H;

  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;

    // Skip WebGL on touch, mobile widths, and reduced-motion.
    const skipWebGL =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      window.matchMedia('(hover: none) and (pointer: coarse)').matches ||
      window.matchMedia('(max-width: 768px)').matches;
    if (skipWebGL) {
      section.dataset.webglReady = 'true';
      return;
    }

    const canvas = section.querySelector<HTMLCanvasElement>('.hero-cyclist-canvas');
    if (!canvas) return;

    const textureUrl = section.dataset.texture!;
    const depthUrl = section.dataset.depth!;
    const strength = parseFloat(section.dataset.strength || '0.10');
    const autoplay = section.dataset.autoplay === 'true';

    // Renderer.
    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: false,
        antialias: true,
        powerPreference: 'high-performance',
      });
    } catch {
      section.dataset.webglReady = 'true';
      return;
    }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    // Shallow-perspective camera per the spec. FOV 38° gives a
    // cinematic compression without going so narrow that the parallax
    // shift becomes invisible.
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
    const baseZ = 1.6;
    camera.position.set(0, 0, baseZ);
    camera.lookAt(0, 0, 0);

    // Subdivided plane — 200×200 segments per the spec. Each vertex
    // samples the depth map and offsets along z, turning the flat image
    // into a relief surface.
    const geometry = new THREE.PlaneGeometry(1, 1, 200, 200);

    const material = new THREE.ShaderMaterial({
      uniforms: {
        uTexture: { value: null as THREE.Texture | null },
        uDepth: { value: null as THREE.Texture | null },
        uStrength: { value: strength },
      },
      vertexShader: /* glsl */ `
        uniform sampler2D uDepth;
        uniform float uStrength;
        varying vec2 vUv;
        void main() {
          vUv = uv;
          // Depth 0..1 — brighter = closer (per spec). Push the vertex
          // toward the camera (+z in Three.js space) so foreground
          // points actually move forward in the scene.
          float d = texture2D(uDepth, uv).r;
          vec3 displaced = position;
          displaced.z += d * uStrength;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(displaced, 1.0);
        }
      `,
      fragmentShader: /* glsl */ `
        precision highp float;
        uniform sampler2D uTexture;
        varying vec2 vUv;
        void main() {
          // Texture is stored as sRGB but sampled as raw bytes (because
          // colorSpace = NoColorSpace above). Decode to linear here so
          // the renderer's outputColorSpace = sRGB encodes it back
          // correctly on canvas write. Without this, the result is
          // double-gamma'd and reads as a dark, desaturated, purple-cast
          // version of the source.
          vec4 col = texture2D(uTexture, vUv);
          col.rgb = pow(col.rgb, vec3(2.2));
          gl_FragColor = col;
        }
      `,
    });

    const mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);

    function configureTexture(t: THREE.Texture, _isColor: boolean) {
      // NoColorSpace on both textures so we read raw bytes. The colour
      // shader does manual sRGB→linear, which the renderer then encodes
      // back to sRGB on output. Trying to rely on Three.js's automatic
      // colorspace conversion through a ShaderMaterial double-applies
      // the gamma and produces the dark/purple cast.
      t.colorSpace = THREE.NoColorSpace;
      t.minFilter = THREE.LinearFilter;
      t.magFilter = THREE.LinearFilter;
      t.generateMipmaps = false;
      t.anisotropy = renderer.capabilities.getMaxAnisotropy();
      t.wrapS = THREE.ClampToEdgeWrapping;
      t.wrapT = THREE.ClampToEdgeWrapping;
      t.needsUpdate = true;
    }

    const loader = new THREE.TextureLoader();
    let loaded = 0;
    function onLoad() {
      if (++loaded < 2) return;
      // Two RAFs to let layout settle before measuring the canvas.
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          fitCanvas();
          renderer.render(scene, camera);
          section.dataset.webglReady = 'true';
          startLoop();
        });
      });
    }
    function onTexErr() {
      // WebGL texture failed — hide the canvas and leave the IMG fallback
      // in place rather than swapping in a broken layer.
      canvas.style.display = 'none';
    }
    loader.load(textureUrl, (t) => {
      configureTexture(t, true);
      material.uniforms.uTexture.value = t;
      onLoad();
    }, undefined, onTexErr);
    loader.load(depthUrl, (t) => {
      configureTexture(t, false);
      material.uniforms.uDepth.value = t;
      onLoad();
    }, undefined, onTexErr);

    /**
     * Size the canvas and scale the plane so the image fills the viewport
     * (CSS object-fit:cover semantics) at the plane's z=0 depth. The
     * plane is overscaled 10% so the camera arc can shift the view
     * without ever revealing the plane's edge.
     */
    function fitCanvas() {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      if (w <= 0 || h <= 0) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();

      const vFov = (camera.fov * Math.PI) / 180;
      const viewH = 2 * Math.tan(vFov / 2) * baseZ;
      const viewW = viewH * camera.aspect;
      const viewAspect = w / h;

      let planeW: number, planeH: number;
      if (viewAspect > IMAGE_ASPECT) {
        // Canvas wider than image — fill width, overflow vertically.
        planeW = viewW;
        planeH = viewW / IMAGE_ASPECT;
      } else {
        // Canvas taller than image — fill height, overflow horizontally.
        planeH = viewH;
        planeW = viewH * IMAGE_ASPECT;
      }
      mesh.scale.set(planeW * 1.10, planeH * 1.10, 1);
    }
    const ro = new ResizeObserver(() => fitCanvas());
    ro.observe(canvas);

    // Scroll progress through the section, 0 at top, 1 at bottom.
    let scrollProgress = 0;
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const span = rect.height;
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / span));
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();

    // Pause render when the hero is out of view.
    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    // Render loop with the scroll-driven shallow arc + autoplay drift.
    let frameId: number | null = null;
    function startLoop() {
      function frame(now: number) {
        if (inView) {
          const t = now / 1000;
          // Shallow ~15° camera arc on x + z per the spec. Smoothstep
          // ease so the parallax accelerates into the scroll rather
          // than jerking on the first pixel.
          const ease = scrollProgress * scrollProgress * (3 - 2 * scrollProgress);
          // ~8° arc, the conservative end of the spec's 8-15° range —
          // any more and the lower-strength displacement stops hiding
          // the polygon stretching at the cyclist's silhouette.
          const angle = ease * 0.14;
          const arcX = Math.sin(angle) * 0.32;
          const arcZ = (1 - Math.cos(angle)) * 0.32;
          const arcY = -ease * 0.05;
          // Autoplay micro-drift — small enough that the cyclist
          // breathes against the cliff without warping at peak.
          const driftX = autoplay ? Math.sin(t * 0.30) * 0.022 : 0;
          const driftY = autoplay ? Math.cos(t * 0.23) * 0.013 : 0;
          camera.position.x = arcX + driftX;
          camera.position.y = arcY + driftY;
          camera.position.z = baseZ - arcZ;
          camera.lookAt(0, 0, 0);
          renderer.render(scene, camera);
        }
        frameId = requestAnimationFrame(frame);
      }
      frameId = requestAnimationFrame(frame);
    }

    window.addEventListener('pagehide', () => {
      if (frameId != null) cancelAnimationFrame(frameId);
      ro.disconnect();
      renderer.dispose();
      geometry.dispose();
      material.dispose();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
