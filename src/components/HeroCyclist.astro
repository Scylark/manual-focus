---
/**
 * HeroCyclist — static illustration hero with CSS scroll parallax.
 *
 * The depth-displacement WebGL approach in the original spec was tried
 * across several rounds (vertex displacement, fragment-shader UV
 * parallax, parallax-occlusion mapping) and each variation produced
 * artefacts on this particular asset — the cyclist sits on the right
 * edge of the 16:9 frame with no padding, so any meaningful depth-
 * weighted shift pushes the sample lookup off the right edge of the
 * image and the rider visibly tears apart.
 *
 * The pragmatic call: ship the static IMG with a scroll-driven CSS
 * parallax. The image drifts up at a slower rate than the page scroll,
 * creating depth read without sampling-off-image artefacts. Same
 * technique most marketing heroes use. Reliable. Clean.
 *
 * Parked spec + assets stay in:
 *   /Users/jamesvickers/Downloads/manual-focus-hero-spec.md
 *   /public/images/hero-cyclist-depth.png
 * to revisit once a re-rendered image with proper padding exists.
 */
import { url } from '../utils/paths';

interface Props {
  texture?: string;
  fallbackImage?: string;
  /** Pixels per scroll-pixel for the CSS parallax. 0 disables. */
  parallax?: number;
}

const {
  texture = '/images/hero-cyclist.webp',
  fallbackImage = '/images/hero-cyclist.jpg',
  parallax = 0.20,
} = Astro.props;

const imageUrl = url(texture);
const fallbackUrl = url(fallbackImage);
---
<section
  class="hero-cyclist"
  data-hero-cyclist
  data-parallax-amount={String(parallax)}
>
  <picture class="hero-cyclist-picture">
    <source srcset={imageUrl} type="image/webp" />
    <img
      class="hero-cyclist-img"
      src={fallbackUrl}
      alt=""
      aria-hidden="true"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </picture>

  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-picture {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    /* Slight overscale so the scroll-parallax translateY can drift the
       image without revealing the section edge. Matches the max drift
       distance. */
    width: 100%;
    height: 115%;
    top: -7.5%;
    will-change: transform;
  }

  .hero-cyclist-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    display: block;
  }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }
  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }
  @media (max-width: 768px) {
    .hero-cyclist { min-height: 560px; }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }

  /* Disable parallax for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-cyclist-picture {
      transform: none !important;
    }
  }
</style>

<script>
  function initParallax() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const picture = section.querySelector<HTMLElement>('.hero-cyclist-picture');
    if (!picture) return;

    const amount = parseFloat(section.dataset.parallaxAmount || '0');
    if (amount <= 0) return;

    let pending = false;
    function update() {
      const rect = section.getBoundingClientRect();
      // Drift the picture vertically by a fraction of how far the
      // section has scrolled past the viewport top. Clamp to ±7.5% of
      // the section height so the 115%/-7.5% overscale never reveals
      // the edge.
      const max = rect.height * 0.075;
      const shift = Math.max(-max, Math.min(max, -rect.top * amount));
      picture.style.transform = `translate3d(0, ${shift.toFixed(2)}px, 0)`;
      pending = false;
    }
    function onScroll() {
      if (!pending) {
        pending = true;
        requestAnimationFrame(update);
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initParallax);
  } else {
    initParallax();
  }
</script>
