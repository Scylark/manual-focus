---
import Base from '../layouts/Base.astro';
import SEOHead from '../components/SEOHead.astro';
import BlogCard from '../components/BlogCard.astro';
import Spray from '../components/Spray.astro';
import FocusObject from '../components/FocusObject.astro';
import HeroCyclist from '../components/HeroCyclist.astro';
import { url } from '../utils/paths';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---
<Base title="Manual Focus — Marketing agency for the AI era" description="Marketing agency for ambitious brands. Senior operators using AI as leverage to ship brand, demand and growth, with particular depth in endurance and sports brands. London." hideNavUntilScroll>
  <SEOHead slot="seo" type="website" title="Manual Focus — Marketing agency for the AI era" description="Marketing agency for ambitious brands. Senior operators using AI as leverage to ship brand, demand and growth, with particular depth in endurance and sports brands." />

  <!-- HERO — depth-displacement cyclist with headline overlay -->
  <HeroCyclist>
    <div class="hero-inner">
      <div class="hero-eyebrow">
        <span class="dot"></span>
        <span class="mono">MANUAL FOCUS · LONDON</span>
      </div>

      <h1 class="hero-headline" data-parallax>
        <span class="hero-line hero-line-1">Your marketing deserves</span>
        <span class="hero-line hero-line-1">more than the same playbook</span>
        <span class="hero-line hero-line-2">
          <em class="hero-italic">
            <span class="word"><span class="char" style="--i: 0">e</span><span class="char" style="--i: 1">v</span><span class="char" style="--i: 2">e</span><span class="char" style="--i: 3">r</span><span class="char" style="--i: 4">y</span><span class="char" style="--i: 5">o</span><span class="char" style="--i: 6">n</span><span class="char" style="--i: 7">e</span></span> <span class="word"><span class="char" style="--i: 9">e</span><span class="char" style="--i: 10">l</span><span class="char" style="--i: 11">s</span><span class="char" style="--i: 12">e</span></span> <span class="word"><span class="char" style="--i: 14">i</span><span class="char" style="--i: 15">s</span></span> <span class="word"><span class="char" style="--i: 17">r</span><span class="char" style="--i: 18">u</span><span class="char" style="--i: 19">n</span><span class="char" style="--i: 20">n</span><span class="char" style="--i: 21">i</span><span class="char" style="--i: 22">n</span><span class="char" style="--i: 23">g</span><span class="char" style="--i: 24">.</span></span>
          </em>
        </span>
      </h1>

      <div class="hero-meta">
        <p class="hero-sub">
          Manual Focus is a marketing agency for ambitious brands. Senior operators with
          AI as the leverage, building brand, demand and growth in a fraction of the time,
          with particular depth in <strong>endurance and sports brands</strong>.
        </p>
        <div class="hero-ctas">
          <a href={url('/enquire')} class="btn-cta">Book a working session</a>
          <a href={url('/services')} class="btn-ghost">How we work together</a>
        </div>
      </div>

      <div class="hero-scroll-hint" aria-hidden="true">
        <span class="mono">SCROLL</span>
        <span class="scroll-arrow"></span>
      </div>
    </div>
  </HeroCyclist>

  <!-- MARQUEE -->
  <section class="marquee-band" aria-hidden="true">
    <div class="marquee">
      <div class="marquee-track">
        <span>FRACTIONAL CMO</span><span class="marquee-dot">●</span>
        <span>STRATEGIC ADVISOR</span><span class="marquee-dot">●</span>
        <span>BUILD &amp; HAND OVER</span><span class="marquee-dot">●</span>
        <span>BRAND</span><span class="marquee-dot">●</span>
        <span>DEMAND</span><span class="marquee-dot">●</span>
        <span>GROWTH</span><span class="marquee-dot">●</span>
        <span>WEB</span><span class="marquee-dot">●</span>
        <span>PR</span><span class="marquee-dot">●</span>
        <span>PERFORMANCE</span><span class="marquee-dot">●</span>
        <span>ENDURANCE BRANDS</span><span class="marquee-dot">●</span>
        <span>THE FORGE</span><span class="marquee-dot">●</span>
        <span>FRACTIONAL CMO</span><span class="marquee-dot">●</span>
        <span>STRATEGIC ADVISOR</span><span class="marquee-dot">●</span>
        <span>BUILD &amp; HAND OVER</span><span class="marquee-dot">●</span>
        <span>BRAND</span><span class="marquee-dot">●</span>
        <span>DEMAND</span><span class="marquee-dot">●</span>
        <span>GROWTH</span><span class="marquee-dot">●</span>
        <span>WEB</span><span class="marquee-dot">●</span>
        <span>PR</span><span class="marquee-dot">●</span>
        <span>PERFORMANCE</span><span class="marquee-dot">●</span>
        <span>ENDURANCE BRANDS</span><span class="marquee-dot">●</span>
        <span>THE FORGE</span><span class="marquee-dot">●</span>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="section problem-section dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={320} tiltX={70} tiltY={25} spin={140} scrollSpin={90} style="top: 6%; right: 4%;" enterFrom="right" />

      <div class="container">
        <div class="eyebrow">001 · THE PROBLEM</div>
        <h2 class="big-statement reveal" data-scroll-scale style="transform-origin: left center;">
          Flat campaigns result in<br/>
          <span class="gradient-text">diminishing returns.</span>
        </h2>
        <div class="problem-grid">
          <p class="problem-copy reveal">
            Most marketing still launches the same way it has for a decade, with a six-week
            campaign, a content flurry, a paid push and the hope something sticks. A flat
            campaign produces flat results regardless of brief quality, budget size or how
            shiny the launch deck looks.
          </p>
          <p class="problem-copy reveal">
            We build something that keeps working after launch week ends, with owned, earned
            and paid wired together through the Forge. The system learns from each campaign
            and improves as new AI models arrive, so growth holds steady instead of tailing off.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- THREE WAYS TO WORK TOGETHER -->
  <section class="section ways-section">
    <FocusObject size={260} tiltX={50} tiltY={15} spin={-130} scrollSpin={-110} style="top: 6%; right: 3%;" enterFrom="right" />

    <div class="container">
      <div class="eyebrow">002 · HOW WE WORK TOGETHER</div>
      <h2 class="big-statement reveal" data-scroll-scale style="transform-origin: left center;">
        Three ways to engage.<br/>
        One product, <span class="gradient-text">fully run by us</span>.
      </h2>

      <div class="ways-grid stagger">
        <article class="way-card">
          <div class="way-num mono">/01 · STRATEGIC ADVISOR</div>
          <h3>The senior voice in the room</h3>
          <p class="way-for">For companies with a marketing team but no senior leader running it.</p>
          <ul class="way-list">
            <li>Weekly working sessions on what to do next</li>
            <li>Reviews of work in progress</li>
            <li>Briefings on the AI tooling worth using, and where it fits your team's workflow</li>
            <li>Hiring and team-shape advice</li>
          </ul>
          <p class="way-shape mono">1–2 days a month. Day rate or monthly retainer.</p>
          <a href={url('/enquire')} class="btn-ghost way-cta">Book a session</a>
        </article>

        <article class="way-card way-card-featured">
          <div class="way-num mono"><span>/02 · FRACTIONAL CMO</span><span class="way-flag">MOST CHOSEN</span></div>
          <h3>Embedded senior marketer</h3>
          <p class="way-for">For companies that need senior marketing leadership without a full-time hire.</p>
          <ul class="way-list">
            <li>Set the marketing thesis and 90-day plan</li>
            <li>Lead and grow the existing team</li>
            <li>Embed AI and emerging tech into the workflows your team already runs</li>
            <li>Ship key pieces of the plan with that leverage in place</li>
          </ul>
          <p class="way-shape mono">1–2 days a week. Three-month minimum.</p>
          <a href={url('/enquire')} class="btn-ghost way-cta">Book a session</a>
        </article>

        <article class="way-card">
          <div class="way-num mono">/03 · BUILD &amp; HAND OVER</div>
          <h3>Scoped outcome, shipped fast</h3>
          <p class="way-for">For companies that know what they need built, and want it shipped fast.</p>
          <ul class="way-list">
            <li>Launches, SEO programs, content engines, brand refreshes</li>
            <li>Headless and rapid web builds on Shopify, BigCommerce, WooCommerce and WordPress</li>
            <li>AI and emerging tech wired into the build, not bolted on after</li>
            <li>Handed back with docs and training, fixed scope, fixed timeline, fixed price</li>
          </ul>
          <p class="way-shape mono">Project-based. Typical builds: 4–12 weeks.</p>
          <a href={url('/enquire')} class="btn-ghost way-cta">Book a session</a>
        </article>
      </div>

      <!-- /04 PRODUCT — AI workflows we own and run -->
      <article class="way-product reveal">
        <div class="way-product-inner">
          <div class="way-product-head">
            <div class="way-num mono"><span>/04 · MANUAL FOCUS · AI</span><span class="way-flag way-flag-alt">PRODUCT</span></div>
            <h3 class="way-product-headline">We run the AI workflows. You get the output.</h3>
            <p class="way-for way-product-for">For CTOs, CMOs and teams who don't have the bandwidth to keep up with new models, build pipelines or learn another tool every week.</p>
          </div>
          <div class="way-product-body">
            <ul class="way-list way-product-list">
              <li>Content planning, wireframing and production owned end-to-end by Manual Focus</li>
              <li>Pipelines maintained, models swapped in as they ship</li>
              <li>Output delivered on agreed cadence, in your brand, ready to use</li>
              <li>No internal training, no tool sprawl, no learning curve</li>
            </ul>
            <div class="way-product-foot">
              <p class="way-shape mono">Monthly retainer. Output on cadence.</p>
              <a href={url('/enquire')} class="btn-cta way-product-cta">Book a working session</a>
            </div>
          </div>
        </div>
      </article>

      <div class="services-cta reveal">
        <p class="services-note">Across endurance and sports brands, AI, fintech and digital assets. Every engagement starts with a 30-minute working session, free.</p>
        <a href={url('/services')} class="btn-ghost">Read the detail</a>
      </div>
    </div>
  </section>

  <!-- THE FORGE — 3D type sticky focal moment -->
  <section class="forge-section" data-forge>
    <div class="forge-sticky">
      <div class="forge-grid" aria-hidden="true"></div>
      <div class="forge-aura" aria-hidden="true"></div>
      <div class="forge-3d-wrap" data-forge-tilt>
        <h2 class="forge-3d-text">
          <span class="forge-line forge-line-1"><span class="fchar" style="--i:0">T</span><span class="fchar" style="--i:1">H</span><span class="fchar" style="--i:2">E</span></span>
          <span class="forge-line forge-line-2"><span class="fchar" style="--i:3">F</span><span class="fchar" style="--i:4">O</span><span class="fchar" style="--i:5">R</span><span class="fchar" style="--i:6">G</span><span class="fchar" style="--i:7">E</span></span>
        </h2>
      </div>
    </div>
  </section>

  <!-- WHY THE AI STAYS SHARP -->
  <section class="section forge-body-section dwell-pin">
    <div class="dwell-pin-stage">
      <div class="container">
        <div class="eyebrow">003 · WHY THE AI STAYS SHARP</div>
        <h3 class="forge-headline">The <span class="gradient-text">Forge</span> keeps us current.</h3>
        <p class="forge-copy">
          We're part of a collective of senior operators called the Foundry. The Foundry shares
          AI tooling through a platform called the Forge. That's why we ship at machine speed,
          and why our capability keeps getting sharper as new AI models arrive. The shared part
          is tooling and pipelines, not strategy or content.
        </p>
        <div class="forge-stats">
          <div class="forge-stat">
            <div class="forge-stat-num">50+</div>
            <div class="forge-stat-label">years of senior marketing experience across the collective</div>
          </div>
          <div class="forge-stat">
            <div class="forge-stat-num">SHARED</div>
            <div class="forge-stat-label">tooling and pipelines, not strategy or content</div>
          </div>
          <div class="forge-stat">
            <div class="forge-stat-num">LIVE</div>
            <div class="forge-stat-label">new AI models added as they ship</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section stats-section section-alt dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={240} tiltX={55} tiltY={-20} spin={120} scrollSpin={140} style="top: 8%; right: 4%;" enterFrom="left" />

      <div class="container">
        <div class="eyebrow">004 · WHAT IT'S WORTH</div>
        <h2 class="stats-headline reveal">More marketing output, in a fraction of the time.</h2>
        <div class="stats-grid stagger">
          <div class="stat-card">
            <div class="stat-value" data-counter="4x" data-counter-prefix="">0x</div>
            <div class="stat-label">faster brief-to-live, on average</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" data-counter="3" data-counter-prefix="">0</div>
            <div class="stat-label">channels covered (owned, earned and paid) from day one</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" data-counter="60%" data-counter-prefix="">0%</div>
            <div class="stat-label">less time on production, more on strategy</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" data-counter="50+" data-counter-prefix="">0+</div>
            <div class="stat-label">years of marketing experience, combined</div>
          </div>
        </div>
        <p class="stats-disclaimer mono">* Across recent engagements. Best results when the strategy was right to begin with.</p>
      </div>
    </div>
  </section>

  <!-- BRAND LOGOS -->
  <section class="section section-alt logos-section dwell-pin">
    <div class="dwell-pin-stage">
      <div class="container">
        <div class="eyebrow">005 · IN THE WILD</div>
        <h2 class="reveal logos-headline">Endurance and sports brands we've shipped with.</h2>
        <div class="logo-bar stagger">
          <span class="brand-mark brand-display">Classified</span>
          <span class="brand-mark brand-serif">Wahoo</span>
          <span class="brand-mark brand-display">Wattbike</span>
          <span class="brand-mark brand-mono">Ribble</span>
          <span class="brand-mark brand-display">RGT</span>
          <span class="brand-mark brand-serif">motif <em>AI</em></span>
          <span class="brand-mark brand-mono">Muuvr</span>
          <span class="brand-mark brand-display">Planet X</span>
          <span class="brand-mark brand-serif">Pelotan</span>
        </div>
        <p class="logos-note reveal">And further afield in AI, fintech, sports tech, hardware and digital assets.</p>
      </div>
    </div>
  </section>

  <!-- CREDIBILITY -->
  <section class="section credibility-section dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={360} tiltX={58} tiltY={-12} spin={180} scrollSpin={60} style="top: 8%; right: 4%;" enterFrom="right" />

      <div class="container">
        <div class="credibility-grid">
          <div class="credibility-copy">
            <div class="eyebrow">006 · WHO WE ARE</div>
            <h2 class="reveal">
              Operators first.<br/>
              <span class="gradient-text">Marketers always.</span>
            </h2>
            <p class="reveal">
              Manual Focus is a marketing agency led by James Vickers, with 15+ years running
              brand, demand, product and growth across AI, fintech, sports tech, hardware and
              digital assets. James co-founded RGT Cycling and took it from 19k to 350k users
              before Wahoo Fitness acquired it. Around him, the Foundry brings senior operators
              with deep marketing CVs of their own. We do the hard miles on AI so the marketing
              side gets the upside.
            </p>
            {/* TODO: replace href with the Foundry website URL once available */}
            <a href="#foundry-tbd" target="_blank" rel="noopener noreferrer" class="btn-ghost reveal">Meet the Foundry ↗</a>
          </div>
          <div class="credibility-mark" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG / PERSPECTIVE -->
  <section class="section section-alt dwell-pin">
    <div class="dwell-pin-stage">
      <div class="container">
        <div class="eyebrow">007 · PERSPECTIVE</div>
        <h2 class="reveal">Notes from the work.</h2>
        <div class="blog-grid stagger">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- MANIFESTO — single sticky stage with absolutely-positioned lines that
       cross-fade as you scroll. Spacers below the stage create the scroll
       distance for the JS to drive the line index. -->
  <section class="manifesto-section" aria-label="Manifesto" data-manifesto>
    <div class="manifesto-stage">
      <p class="manifesto-line is-active" data-i="0"><span class="manifesto-text">Brand, sharpened by AI.</span></p>
      <p class="manifesto-line" data-i="1"><span class="manifesto-text">Demand, faster than the old playbook.</span></p>
      <p class="manifesto-line" data-i="2"><span class="manifesto-text">Growth, that compounds.</span></p>
      <p class="manifesto-line manifesto-line-final" data-i="3"><span class="manifesto-text"><span class="gradient-text">Senior operators.</span> Real conviction. No fluff.</span></p>
    </div>
    <div class="manifesto-spacer"></div>
    <div class="manifesto-spacer"></div>
    <div class="manifesto-spacer"></div>
    <div class="manifesto-spacer"></div>
  </section>

  <!-- CTA CLOSE -->
  <section class="section cta-close dwell-pin">
    <div class="dwell-pin-stage">
      <FocusObject size={520} tiltX={60} tiltY={-20} spin={160} scrollSpin={100} style="top: -100px; left: -120px;" enterFrom="left" />
      <FocusObject size={360} tiltX={50} tiltY={25} spin={-130} scrollSpin={-90} style="bottom: -80px; right: -60px;" enterFrom="right" />

      <div class="container cta-close-inner">
        <h2 class="cta-headline reveal">
          Got a problem, a brief,<br/>
          or a <span class="gradient-text">vague feeling</span> something's off?
        </h2>
        <p class="cta-sub reveal">Bring it. We'll figure out the shape of the work together. 30-minute working session, free.</p>
        <a href={url('/enquire')} class="btn-cta reveal">Book a working session</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ============================
     HERO
     ============================ */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding-block: var(--space-xl);
  }

  .hero-inner {
    position: relative;
    z-index: 3;
    display: grid;
    gap: var(--space-sm);
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: var(--color-text-secondary);
  }
  .hero-eyebrow .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-cta-start);
    box-shadow: 0 0 12px var(--color-cta-start);
    animation: pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  .hero-headline {
    font-size: clamp(1.85rem, 4.6vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin-top: var(--space-sm);
    /* Cyclist-hero sits behind, so the headline overrides theme text colour
       and gets a subtle shadow so it reads cleanly on the dawn sky. Font
       size tuned so all three lines + the italic punchline fit comfortably
       in the left half of the viewport without clipping. */
    color: #f6f0e8;
    text-shadow: 0 2px 18px rgba(15, 12, 8, 0.55);
  }
  .hero-sub {
    color: rgba(246, 240, 232, 0.92) !important;
    text-shadow: 0 1px 12px rgba(15, 12, 8, 0.55);
    max-width: 540px;
  }
  .hero-eyebrow {
    color: rgba(246, 240, 232, 0.85) !important;
  }
  .hero-scroll-hint .mono {
    color: rgba(246, 240, 232, 0.7);
  }

  .hero-line {
    display: block;
    opacity: 0;
    transform: translateY(40px);
    animation: hero-line-in 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-line-1 { animation-delay: 0.15s; }
  /* Line 2 fades the container; chars handle their own animation */
  .hero-line-2 {
    animation-delay: 0.25s;
    perspective: 1200px;
    transform-style: preserve-3d;
  }
  .hero-line-3 { animation-delay: 0.45s; }

  @keyframes hero-line-in {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Per-character flip-in for the punchline */
  .char {
    display: inline-block;
    opacity: 0;
    transform: translateY(60px) rotateX(-80deg);
    transform-origin: 50% 100% -10px;
    backface-visibility: hidden;
    animation: char-in 0.85s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.7s + var(--i) * 0.055s);
    /* Apply gradient directly to each char — background-clip:text on parent
       doesn't reach through inline-block children */
    font-style: italic;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    /* Extend the padding box past the italic glyph's top-right overhang so the
       gradient covers the full letter instead of clipping at the box edge.
       Negative margin-right keeps letter spacing visually identical. */
    padding-right: 0.18em;
    margin-right: -0.18em;
  }
  @keyframes char-in {
    to { opacity: 1; transform: translateY(0) rotateX(0); }
  }

  .hero-italic {
    font-style: italic;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  /* Wrap each italic word in an inline-block so the per-char inline-blocks
     inside can never break across lines — the whole word wraps as a unit. */
  .hero-italic .word {
    display: inline-block;
    white-space: nowrap;
  }

  .hero-meta {
    margin-top: var(--space-md);
    max-width: 720px;
  }

  .hero-sub {
    font-size: var(--font-size-lg);
    color: var(--color-text);
  }
  .hero-sub strong {
    font-weight: 700;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
  }
  .scroll-arrow {
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, var(--color-text-secondary), transparent);
    animation: scrollHint 2s ease-in-out infinite;
  }
  @keyframes scrollHint {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50% { transform: translateY(8px); opacity: 1; }
  }

  /* ============================
     MARQUEE
     ============================ */
  .marquee-band {
    background: var(--color-text);
    color: var(--color-bg);
    overflow: hidden;
    padding-block: 1.2rem;
    border-block: 1px solid var(--color-text);
    position: relative;
    z-index: 5;
  }
  .marquee {
    display: flex;
    width: max-content;
  }
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    white-space: nowrap;
    animation: marquee 35s linear infinite;
    padding-right: 2.5rem;
  }
  .marquee-dot {
    color: var(--color-cta-start);
    font-size: 0.6em;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ============================
     FORGE — 3D type sticky focal moment
     ============================ */
  .forge-section {
    position: relative;
    height: 180vh;
    background: linear-gradient(180deg, transparent 0%, rgba(10,10,11,0.6) 30%, rgba(10,10,11,0.6) 70%, transparent 100%);
  }
  .forge-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    /* Nudge content so it visually centres in the area BELOW the fixed nav */
    padding-top: 4.5rem;
    isolation: isolate;
  }

  /* Vanishing-point grid behind the type — drives the sense of depth.
     Opacity tracks --fp so the grid fades in as you scroll into peak. */
  .forge-grid {
    position: absolute;
    inset: -10% -10% -10% -10%;
    pointer-events: none;
    z-index: 0;
    background-image:
      linear-gradient(to right, rgba(242, 237, 230, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(242, 237, 230, 0.06) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 55%, black, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 55%, black, transparent 75%);
    opacity: calc(0.35 + var(--fp, 0) * 0.4);
    transform: perspective(1200px) rotateX(45deg) translate3d(0, calc(var(--fp, 0) * -8%), 0);
    transform-origin: 50% 100%;
  }

  /* Radial aura behind the type that builds and recedes around peak.
     Two layered gradients give a magenta core + cyan halo. The aura center
     follows the cursor via --mx/--my (offset by 20% of viewport), so the
     light source feels like it's tied to where you're looking. */
  .forge-aura {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    --aura-x: calc(50% + var(--mx, 0) * 30%);
    --aura-y: calc(52% + var(--my, 0) * 28%);
    background:
      radial-gradient(ellipse 35% 45% at var(--aura-x) var(--aura-y),
        rgba(192, 38, 211, calc(0.4 * var(--fp, 0))) 0%,
        rgba(192, 38, 211, calc(0.18 * var(--fp, 0))) 30%,
        transparent 60%),
      radial-gradient(ellipse 60% 70% at var(--aura-x) var(--aura-y),
        rgba(0, 229, 255, calc(0.14 * var(--fp, 0))) 0%,
        transparent 65%);
    filter: blur(24px);
  }

  .forge-3d-wrap {
    perspective: 1400px;
    pointer-events: none;
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .forge-3d-text {
    font-family: var(--font-display);
    font-size: clamp(4rem, 14vw, 14rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    /* Day: deep ink on cream. Night: cream on black (set further down). */
    color: #1A1612;
    margin: 0;
    transform-style: preserve-3d;
    /* Scale builds from 0.72 (off in the distance) up to 1.05 (right in your
       face at peak) so the type feels like it's coming toward camera as you
       scroll into the section. Composed with the tilt rotations. */
    transform:
      rotateX(var(--forge-tiltX, 18deg))
      rotateY(var(--forge-tiltY, -14deg))
      scale(var(--forge-scale, 1));
    transform-origin: 50% 60%;
    will-change: transform;
  }
  .forge-line {
    display: block;
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  /* Per-letter flip-in for the Forge wordmark — triggers on intersection */
  .fchar {
    display: inline-block;
    opacity: 0;
    transform: translateY(80px) rotateX(-90deg);
    transform-origin: 50% 100% -20px;
    backface-visibility: hidden;
    /* Deep extrusion: 18 layers walking from a terracotta sunrise edge into
       a deep cocoa shadow, then atmospheric softening, then a warm-dark
       ground shadow. Moebius-adjacent comic depth — single hue family,
       saturated front edge, fading to ink. */
    text-shadow:
      /* Edge highlight catching the morning light on the front face */
      -1px -1px 0 rgba(255, 255, 255, 0.35),
      /* Extruded depth — terracotta sunrise fading into deep cocoa */
      1px 1px 0 #C45A2C,
      2px 2px 0 #B85429,
      3px 3px 0 #AC4E26,
      4px 4px 0 #9F4823,
      5px 5px 0 #934220,
      6px 6px 0 #863B1C,
      7px 7px 0 #793519,
      8px 8px 0 #6C2F16,
      9px 9px 0 #5F2913,
      10px 10px 0 #532410,
      11px 11px 0 #461E0D,
      12px 12px 0 #39190B,
      13px 13px 0 #2D1408,
      14px 14px 0 #221006,
      15px 15px 0 #170B04,
      16px 16px 0 #0E0702,
      17px 17px 0 #060301,
      18px 18px 0 #020100,
      /* Atmospheric blur on the deepest layers — warm dark, not cool black */
      19px 19px 1px rgba(22, 12, 6, 0.85),
      20px 20px 2px rgba(22, 12, 6, 0.75),
      22px 22px 6px rgba(22, 12, 6, 0.55),
      /* Diffuse ground shadow */
      26px 36px 50px rgba(22, 12, 6, 0.4);
    transition: opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--i) * 0.08s);
  }
  .forge-3d-text.is-revealed .fchar {
    opacity: 1;
    transform: translateY(0) rotateX(0);
  }

  /* Night theme: flip the wordmark back to cream face + pink-to-purple-black
     extrusion that the dark/neon original was built around. */
  :global([data-theme="dark"]) .forge-3d-text {
    color: #f6f0e8;
  }
  :global([data-theme="dark"]) .fchar {
    text-shadow:
      -1px -1px 0 rgba(255, 255, 255, 0.18),
      1px 1px 0 #e02862,
      2px 2px 0 #d2255b,
      3px 3px 0 #c52255,
      4px 4px 0 #b81f4e,
      5px 5px 0 #ab1c47,
      6px 6px 0 #9e1941,
      7px 7px 0 #91163a,
      8px 8px 0 #841333,
      9px 9px 0 #77102d,
      10px 10px 0 #6a0d26,
      11px 11px 0 #5d0a20,
      12px 12px 0 #500819,
      13px 13px 0 #430613,
      14px 14px 0 #36040d,
      15px 15px 0 #290208,
      16px 16px 0 #1c0104,
      17px 17px 0 #100002,
      18px 18px 0 #060001,
      19px 19px 1px rgba(0, 0, 0, 0.9),
      20px 20px 2px rgba(0, 0, 0, 0.85),
      22px 22px 6px rgba(0, 0, 0, 0.7),
      26px 36px 50px rgba(0, 0, 0, 0.85);
  }

  /* ============================
     FORGE body — normal section flow
     ============================ */
  .forge-body-section {
    text-align: center;
  }
  .forge-body-section .eyebrow {
    justify-content: center;
    display: inline-flex;
  }
  .forge-headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-top: var(--space-sm);
  }
  .forge-copy {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 760px;
    margin: var(--space-md) auto 0;
    line-height: 1.55;
  }
  .forge-copy strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .forge-stats {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    max-width: 880px;
    margin-inline: auto;
  }
  .forge-stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .forge-stat-label {
    margin-top: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .forge-stats { grid-template-columns: 1fr; gap: var(--space-md); }
  }

  @media (prefers-reduced-motion: reduce) {
    .forge-section { height: auto; }
    .forge-sticky { position: relative; height: auto; padding-block: var(--space-2xl); display: block; }
    .forge-3d-text { transform: none; }
    .fchar { opacity: 1; transform: none; transition: none; }
    .hero-line { opacity: 1; transform: none; animation: none; }
    .char { opacity: 1; transform: none; animation: none; }
  }

  /* ============================
     PROBLEM
     ============================ */
  .problem-section { overflow: hidden; position: relative; }
  .big-statement {
    font-size: clamp(2.5rem, 8vw, 7rem);
    line-height: 0.95;
    max-width: 1100px;
    position: relative;
    z-index: 2;
  }
  .strike {
    position: relative;
    color: var(--color-text-muted);
  }
  .strike::after {
    content: '';
    position: absolute;
    left: -5%;
    right: -5%;
    top: 50%;
    height: 0.18em;
    background: var(--color-cta-gradient);
    transform: rotate(-3deg);
  }
  .problem-grid {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
    gap: var(--space-md);
    max-width: 920px;
    position: relative;
    z-index: 2;
  }
  .problem-grid .problem-copy { margin: 0; }
  .problem-copy {
    font-size: var(--font-size-lg);
    color: var(--color-text);
  }
  .problem-copy strong {
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .problem-grid { grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
  }

  /* ============================
     STATS
     ============================ */
  .stats-section { overflow: hidden; position: relative; }
  .stats-headline {
    font-size: clamp(2.5rem, 7vw, 6rem);
    max-width: 1000px;
    position: relative;
    z-index: 2;
  }
  .stats-grid {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
    position: relative;
    z-index: 2;
  }
  .stat-card {
    position: relative;
    padding: var(--space-md);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    background: var(--color-card-bg);
    backdrop-filter: blur(6px);
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .stat-card:hover {
    border-color: var(--color-text);
    transform: translateY(-4px);
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1;
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .stat-label {
    margin-top: var(--space-sm);
    color: var(--color-text-secondary);
    font-size: var(--font-size-body);
    max-width: 240px;
  }
  .stats-disclaimer {
    margin-top: var(--space-md);
    color: var(--color-text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  .mono { font-family: var(--font-mono); }

  @media (min-width: 640px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-md); }
  }
  @media (min-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ============================
     THREE WAYS TO WORK TOGETHER
     ============================ */
  .ways-section { overflow: hidden; position: relative; }
  .ways-grid {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    z-index: 2;
  }
  .way-card {
    position: relative;
    padding: var(--space-md);
    background: var(--color-bg);
    transition: background 0.3s ease;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .way-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-cta-gradient);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
  }
  /* Hairline gradient accent that draws in on hover from the top edge */
  .way-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 100%;
    height: 2px;
    background: var(--color-cta-gradient);
    transition: right 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 2;
  }
  .way-card:hover::before { opacity: 0.06; }
  .way-card:hover::after { right: 0; }
  .way-card:hover { background: var(--color-bg-alt); }
  .way-card:hover .way-cta { transform: translateX(4px); }
  .way-cta { transition: transform 0.3s ease; }

  /* Featured tier — Fractional CMO */
  .way-card-featured::after { right: 0; }
  .way-flag {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-cta-start);
    color: var(--color-cta-start);
    border-radius: 999px;
    background: rgba(255, 45, 120, 0.06);
    white-space: nowrap;
    line-height: 1;
  }
  .way-card > * { position: relative; z-index: 1; }
  .way-num {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.12em;
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }
  .way-card h3 {
    font-size: clamp(1.25rem, 1.8vw, 1.75rem);
    margin-bottom: var(--space-xs);
  }
  .way-for {
    color: var(--color-text);
    font-size: var(--font-size-body);
    font-style: italic;
    margin-bottom: var(--space-md);
  }
  .way-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-md);
    flex: 1;
  }
  .way-list li {
    font-size: var(--font-size-body);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
    padding-left: 1rem;
    position: relative;
    line-height: 1.5;
  }
  .way-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-cta-start);
    font-weight: 700;
  }
  .way-shape {
    color: var(--color-text);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    margin-top: auto;
    padding: var(--space-sm) 0;
    border-top: 1px solid var(--color-line);
  }
  .way-cta {
    margin-top: var(--space-sm);
    align-self: flex-start;
    font-size: 0.75rem;
    padding: 0.5rem 1.1rem;
  }
  .services-cta {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
    position: relative;
    z-index: 2;
  }
  .services-note {
    font-size: var(--font-size-lg);
    max-width: 760px;
  }

  @media (min-width: 768px) {
    .ways-grid { grid-template-columns: repeat(3, 1fr); }
    .services-cta { flex-direction: row; align-items: center; justify-content: space-between; }
  }

  /* /04 PRODUCT — visually distinct from the engagement tiers above:
     wider, with a stronger gradient hairline and a clear "Manual Focus owns this" feel */
  .way-product {
    margin-top: var(--space-md);
    position: relative;
    border: 1px solid var(--color-line);
    border-radius: 4px;
    background:
      linear-gradient(180deg, rgba(192, 38, 211, 0.06), rgba(0, 229, 255, 0.02)),
      var(--color-bg);
    overflow: hidden;
    z-index: 2;
  }
  .way-product::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--color-cta-gradient);
  }
  .way-product-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    padding: var(--space-md);
  }
  .way-product-headline {
    font-size: clamp(1.5rem, 2.8vw, 2.4rem);
    line-height: 1.05;
    margin-top: var(--space-xs);
    max-width: 28ch;
  }
  .way-product-for {
    margin-top: var(--space-sm);
    max-width: 48ch;
  }
  .way-product-list { margin-bottom: var(--space-md); }
  .way-product-foot {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: flex-start;
    border-top: 1px solid var(--color-line);
    padding-top: var(--space-md);
  }
  .way-product-cta {
    align-self: flex-start;
    font-size: 0.85rem;
    padding: 0.7rem 1.4rem;
  }
  .way-flag-alt {
    border-color: var(--color-cta-end);
    color: var(--color-cta-end);
    background: rgba(0, 229, 255, 0.06);
  }
  @media (min-width: 900px) {
    .way-product-inner {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-lg);
      padding: var(--space-lg);
    }
    .way-product-foot {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-md);
    }
  }

  /* ============================
     LOGOS
     ============================ */
  .logos-section { position: relative; overflow: hidden; }
  .logos-headline {
    font-size: clamp(2rem, 5vw, 4rem);
    position: relative;
    z-index: 2;
    max-width: 1000px;
  }
  .logos-note {
    margin-top: var(--space-lg);
    color: var(--color-text-secondary);
    font-size: var(--font-size-body);
    position: relative;
    z-index: 2;
  }
  .logo-bar {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-lg);
    align-items: center;
    justify-items: center;
    position: relative;
    z-index: 2;
  }
  .brand-mark {
    color: var(--color-text-secondary);
    transition: color 0.3s ease, transform 0.3s ease;
    cursor: default;
    line-height: 1;
  }
  .brand-mark:hover {
    color: var(--color-text);
    transform: translateY(-2px);
  }
  /* Each brand gets a different typographic treatment so the wall reads as
     a collection of brands rather than a uniform text list. */
  .brand-display {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 2.25rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .brand-serif {
    font-family: 'Inter', serif;
    font-weight: 300;
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    letter-spacing: -0.01em;
  }
  .brand-serif em {
    font-style: italic;
    font-weight: 500;
  }
  .brand-mono {
    font-family: var(--font-mono);
    font-size: clamp(0.875rem, 1.2vw, 1.05rem);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
  }
  @media (min-width: 640px) {
    .logo-bar { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .logo-bar { grid-template-columns: repeat(5, 1fr); }
  }

  /* ============================
     CREDIBILITY
     ============================ */
  .credibility-section { overflow: hidden; position: relative; }
  .credibility-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: start;
    position: relative;
    z-index: 2;
  }
  .credibility-copy h2 {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
  }
  .credibility-copy p {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 540px;
    margin-block: var(--space-md);
  }
  .credibility-mark {
    position: relative;
    min-height: 1rem;
  }

  @media (min-width: 900px) {
    .credibility-grid { grid-template-columns: 1.3fr 1fr; }
  }

  /* ============================
     BLOG
     ============================ */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    position: relative;
    z-index: 2;
  }
  @media (min-width: 640px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ============================
     MANIFESTO — single sticky stage with cross-fading lines
     Four full-height spacers create the scroll distance. The stage stays
     sticky at the top of the viewport while you scroll, and the JS picks
     which line is active based on scroll progress through the section.
     Each line slides + blurs in from the right, settles, then slides out
     left as the next one takes over.
     ============================ */
  .manifesto-section {
    position: relative;
    border-top: 1px solid var(--color-line);
    background: var(--color-bg);
  }
  .manifesto-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: var(--space-md);
    overflow: hidden;
    /* Perspective on the stage gives each line real depth — they
       fly through space, not slide across a flat plane. */
    perspective: 1200px;
    perspective-origin: 50% 50%;
  }
  /* Each spacer drives one pledge's scroll slot. 180vh = each
     pledge gets ~1.8 viewport-heights of scroll progress, with the
     active "fully in focus" window being most of that, so the
     visitor can actually read each line as it lands. */
  .manifesto-spacer { height: 180vh; }
  /* The outer .manifesto-line is just a centering container for the
     absolutely-positioned slot in the sticky stage. The opacity, transform
     and blur are driven directly from scroll position by JS per frame, so
     the line glides smoothly with the scroll rather than transitioning at
     thresholds. No CSS transitions on those properties for that reason. */
  .manifesto-line {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding-inline: var(--space-md);
    pointer-events: none;
    opacity: 0;
    will-change: opacity, transform, filter;
  }
  .manifesto-text {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 9vw, 8rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--color-text);
    text-transform: uppercase;
    text-align: center;
    max-width: 18ch;
  }
  .manifesto-line-final .manifesto-text {
    font-family: var(--font-family);
    font-weight: 600;
    font-size: clamp(1.5rem, 4.5vw, 3.5rem);
    letter-spacing: -0.01em;
    line-height: 1.2;
    max-width: 24ch;
    text-transform: none;
  }
  .manifesto-line-final .gradient-text {
    background: var(--color-cta-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  @media (max-width: 768px) {
    .manifesto-stage { height: 70vh; }
    /* Mobile: 100vh per pledge — each pledge gets a viewport-height
       of scroll, with the active read window being ~40vh of that.
       Substantial dwell, still ~5 viewport-heights total for the
       whole manifesto so the visitor isn't swiping forever. */
    .manifesto-spacer { height: 100vh; }
    .manifesto-text { font-size: clamp(2rem, 11vw, 4rem); }
    .manifesto-line-final .manifesto-text { font-size: clamp(1.25rem, 5vw, 2rem); }
  }

  /* ============================
     CTA CLOSE
     ============================ */
  .cta-close {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-2xl);
    text-align: center;
  }
  .cta-close-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    position: relative;
    z-index: 2;
  }
  .cta-headline {
    font-size: clamp(2rem, 6vw, 5rem);
    max-width: 1100px;
    line-height: 1;
  }
  .cta-sub {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    max-width: 540px;
  }

  /* ============================
     RESPONSIVE TWEAKS — mobile
     ============================ */
  @media (max-width: 768px) {
    /* HERO — tighter spacing, smaller type, hide scroll hint */
    .hero {
      min-height: auto;
      padding-block: var(--space-lg) var(--space-md);
    }
    .hero-headline { font-size: clamp(2.25rem, 11vw, 3.5rem); }
    .hero-sub { font-size: 1rem; line-height: 1.55; }
    .hero-scroll-hint { display: none; }
    .hero-ctas { gap: var(--space-sm); }

    /* Italic char padding — the right-edge crop fix pushes the trailing period
       onto a new line at narrow viewports. Reduce overhang and zero out
       the last char so the line wraps cleanly. */
    .char { padding-right: 0.08em; margin-right: -0.08em; }
    .hero-italic .char:last-child { padding-right: 0; margin-right: 0; }

    /* Kill the scroll-scale animation on mobile — it scales headlines down
       to 78% when off-centre, which looks like a rendering bug on small viewports. */
    [data-scroll-scale] { transform: none !important; }

    /* Section headlines down a notch */
    .big-statement { font-size: clamp(1.875rem, 9vw, 3rem); }
    .stats-headline { font-size: clamp(1.875rem, 9vw, 3rem); }
    .logos-headline { font-size: clamp(1.625rem, 7vw, 2.5rem); }
    .cta-headline { font-size: clamp(1.75rem, 8vw, 3rem); }
    .forge-headline { font-size: clamp(1.75rem, 7vw, 2.75rem); }

    /* /02 way-num row — allow MOST CHOSEN pill to wrap below the label
       instead of squashing /02 · FRACTIONAL CMO onto two lines */
    .way-num { flex-wrap: wrap; row-gap: 0.5rem; }

    /* /04 product card — tighter padding on mobile */
    .way-product-inner { padding: var(--space-md); gap: var(--space-sm); }
    .way-product-headline { font-size: clamp(1.5rem, 6vw, 2rem); }

    /* Forge sticky — don't dominate scroll on small screens */
    .forge-section { min-height: 60vh; }
    .forge-sticky { padding-block: var(--space-md); }

    /* CTA close — less vertical padding */
    .cta-close { padding-block: var(--space-xl); }
    .cta-sub { font-size: 1rem; }

    /* Bigger touch targets on buttons */
    .btn-cta, .btn-ghost { padding: 0.85rem 1.4rem; font-size: 0.85rem; }
    .way-cta { padding: 0.6rem 1.2rem; }

    /* Problem section — single column reads better on mobile */
    .problem-copy { font-size: 1rem; }
  }

  /* Even tighter on the smallest phones */
  @media (max-width: 380px) {
    .container { padding-inline: var(--space-sm); }
    .hero-headline { font-size: clamp(2rem, 10vw, 3rem); }
  }

  /* ============================
     DWELL-PIN — sections that should hold the visitor's eye briefly
     as they scroll past. Same pattern as the hero and manifesto:
     the section is tall, the content inside is sticky-pinned at the
     top of the viewport for the duration of the pin. Combined with
     the scroll-driven reveal in Base.astro, the visitor sees the
     headline + body fade up into place during the section approach,
     then HOLD in view for ~100vh of pinned scroll before the section
     releases and the next one slides up. The vertical movement
     genuinely pauses for a moment even while the scroll wheel keeps
     spinning. Mobile drops the pin entirely — adds too much page
     length on a phone for too little visual payoff.
     ============================ */
  .section.dwell-pin,
  .dwell-pin {
    /* Pin range = section height MINUS stage height. With stage at
       100svh, 320vh gives ~220vh of pinned dwell — matching the
       MANUAL FOCUS wordmark's hold phase in the hero so every section
       has the same "scroll wheel keeps moving but content stays put"
       feel that the user said felt right. FocusObjects inside each
       stage keep spinning during the pin (design flourishes alive).
       Then 100vh exit phase; the section's explicit bg matches the
       page bg so the exit doesn't show a colour gap.
       overflow MUST be visible — many .section variants have an
       overflow:hidden rule to contain absolutely-positioned
       FocusObjects, but that rule on the parent of a sticky child
       kills position:sticky. We clip at the stage level instead. */
    min-height: 320vh;
    padding-block: 0;
    position: relative;
    background: var(--color-bg);
    overflow: visible;
  }
  .dwell-pin-stage {
    position: sticky;
    top: 0;
    /* 100svh = exactly one safe viewport so the stage fills the
       screen edge-to-edge while pinned. Content centred inside, so
       a section with less content has equal top/bottom breathing
       room instead of all the empty space landing below the text. */
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: var(--space-2xl);
    width: 100%;
    background: var(--color-bg);
    /* Clip FocusObjects + other absolutely-positioned decoration
       inside the stage instead of on the section (which would break
       the sticky behaviour). */
    overflow: hidden;
  }
  .dwell-pin-stage > .container { width: 100%; }
  /* Section variants that have their own background colour need to
     pass that through to the dwell-pin sticky stage too, otherwise
     during the exit phase the stage's bg differs from the section's
     and you get a visible colour seam. */
  .section.section-alt.dwell-pin,
  .section.section-alt.dwell-pin .dwell-pin-stage {
    background: var(--color-bg-alt, var(--color-bg));
  }
  @media (max-width: 768px) {
    /* On mobile the dwell-pin pattern reverts to a normal section —
       sticky-pinned sections would add too much scroll distance for a
       phone, where each swipe is more effort than a desktop wheel
       tick. The content still gets the scroll-driven reveal as it
       enters the viewport, just without the pinned hold. */
    .section.dwell-pin,
    .dwell-pin {
      min-height: 0;
      padding-block: var(--space-xl);
    }
    .dwell-pin-stage {
      position: relative;
      top: auto;
      min-height: 0;
      display: block;
      padding-block: 0;
    }
  }

  /* ============================
     MOBILE PERF — strip expensive paint effects on phones.
     backdrop-filter and large filter:blur() are re-evaluated every
     frame the content behind them changes, which on a fixed nav
     over a scrolling page means every scroll frame. Disabling them
     on small viewports is invisible to the user and saves a huge
     amount of GPU work on mid-range Android and any iPhone before
     the Pro Max line.
     ============================ */
  @media (max-width: 768px) {
    .stat-card {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
    .forge-aura {
      filter: blur(8px);
    }
  }
</style>

<script>
  // Hero parallax — subtle mouse tracking on desktop
  const parallaxEls = document.querySelectorAll<HTMLElement>('[data-parallax]');

  if (window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.addEventListener('mousemove', (e) => {
      const x = (e.clientX / window.innerWidth - 0.5);
      const y = (e.clientY / window.innerHeight - 0.5);
      parallaxEls.forEach(el => {
        el.style.transform = `translate3d(${x * -10}px, ${y * -6}px, 0)`;
      });
    }, { passive: true });
  }

  // Forge section — letter reveal on intersection
  const forgeText = document.querySelector<HTMLElement>('.forge-3d-text');
  if (forgeText) {
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          forgeText.classList.add('is-revealed');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    revealObs.observe(forgeText);
  }

  // Manifesto — scroll-scrubbed animation. Each line owns 1/total of the
  // scrollable section. We compute that line's "slot progress" (-∞..+∞,
  // 0 = perfectly centred) and drive opacity, X translation and blur
  // directly from that value every frame, so the motion glides with the
  // scroll rather than triggering at thresholds.
  const manifestoSection = document.querySelector<HTMLElement>('[data-manifesto]');
  const manifestoLines = document.querySelectorAll<HTMLElement>('.manifesto-line');
  if (manifestoSection && manifestoLines.length) {
    const total = manifestoLines.length;
    let manifestoPending = false;
    const updateManifesto = () => {
      const rect = manifestoSection.getBoundingClientRect();
      const scrollable = rect.height - window.innerHeight;
      const progress = scrollable > 0
        ? Math.max(0, Math.min(1, -rect.top / scrollable))
        : 0;
      manifestoLines.forEach((line, i) => {
        // slot = -0.5 .. +0.5 across this line's own scroll range.
        // 0 = centred, sharp. Past ±0.5 means the next/previous line owns it.
        const slot = progress * total - i - 0.5;
        const clamped = Math.max(-1.2, Math.min(1.2, slot));
        const abs = Math.abs(clamped);

        // Plateau opacity: each pledge is sharp + at full opacity
        // across most of its slot, only blurring + fading at the
        // very edges of the transition to the next/previous line.
        // Wide plateau = real dwell time to read.
        const t = Math.max(0, Math.min(1, (abs - 0.38) / 0.17));
        const opacity = 1 - t * t * (3 - 2 * t);

        // Each line flies through 3D space toward and past the camera.
        // Incoming line (clamped < 0): translateZ negative = far away,
        // perspective makes it small. Reaches sharp focus at clamped = 0.
        // Outgoing line (clamped > 0): translateZ positive = past the
        // screen plane, perspective makes it loom large. The X drift,
        // rotateX tilt and depth-of-field blur compound the read.
        const x = -clamped * 60;                 // px gentle drift
        const z = clamped * 420;                 // px depth fly-through
        const rotX = clamped * -14;              // deg pitch as it passes
        const skew = -clamped * 2;               // deg
        const blur = abs * 14;                   // depth-of-field at extremes

        line.style.opacity = opacity.toFixed(3);
        line.style.transform =
          `translate3d(${x.toFixed(1)}px, 0, ${z.toFixed(1)}px)` +
          ` rotateX(${rotX.toFixed(2)}deg) skewX(${skew.toFixed(2)}deg)`;
        line.style.filter = `blur(${blur.toFixed(1)}px)`;
      });
      manifestoPending = false;
    };
    window.addEventListener('scroll', () => {
      if (!manifestoPending) {
        manifestoPending = true;
        requestAnimationFrame(updateManifesto);
      }
    }, { passive: true });
    updateManifesto();
  }

  // Forge section — scroll progress (0→1) + 3D type tilt + cursor follow.
  // Mouse-driven offsets compose on top of the scroll-driven base tilt and
  // shift the aura center toward the cursor, so the wordmark feels alive
  // and responds to where you're looking on the page.
  const forgeSection = document.querySelector<HTMLElement>('[data-forge]');
  const forgeTilt = document.querySelector<HTMLElement>('[data-forge-tilt]');
  if (forgeSection && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let forgePending = false;
    let mouseX = 0;  // -0.5 .. 0.5, relative to section
    let mouseY = 0;
    let mouseXTarget = 0;
    let mouseYTarget = 0;
    let fp = 0;
    const text = forgeSection.querySelector<HTMLElement>('.forge-3d-text');

    const updateForge = () => {
      const rect = forgeSection.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = -rect.top;
      fp = Math.max(0, Math.min(1, total > 0 ? scrolled / total : 0));
      forgeSection.style.setProperty('--fp', fp.toFixed(4));
      // Ease mouse toward target so motion feels weighty, not jittery.
      mouseX += (mouseXTarget - mouseX) * 0.12;
      mouseY += (mouseYTarget - mouseY) * 0.12;
      forgeSection.style.setProperty('--mx', mouseX.toFixed(3));
      forgeSection.style.setProperty('--my', mouseY.toFixed(3));
      if (text) {
        // Base scroll-driven tilt with cursor offset layered on top.
        const tiltX = 14 + fp * 18 + (-mouseY * 14);
        const tiltY = -22 + fp * 32 + (mouseX * 18);
        const bell = 4 * fp * (1 - fp);
        const scale = 0.72 + bell * 0.33;
        text.style.setProperty('--forge-tiltX', `${tiltX.toFixed(2)}deg`);
        text.style.setProperty('--forge-tiltY', `${tiltY.toFixed(2)}deg`);
        text.style.setProperty('--forge-scale', scale.toFixed(3));
      }
      forgePending = false;
      // Keep easing while there's still mouse delta to settle.
      if (Math.abs(mouseXTarget - mouseX) > 0.001 || Math.abs(mouseYTarget - mouseY) > 0.001) {
        forgePending = true;
        requestAnimationFrame(updateForge);
      }
    };
    const requestForgeUpdate = () => {
      if (!forgePending) {
        forgePending = true;
        requestAnimationFrame(updateForge);
      }
    };
    window.addEventListener('scroll', requestForgeUpdate, { passive: true });
    // Track cursor relative to the sticky stage so the offset is centred
    // around the viewport regardless of where you are in the section.
    const sticky = forgeSection.querySelector<HTMLElement>('.forge-sticky');
    if (sticky) {
      sticky.addEventListener('mousemove', (e) => {
        const r = sticky.getBoundingClientRect();
        mouseXTarget = ((e.clientX - r.left) / r.width) - 0.5;
        mouseYTarget = ((e.clientY - r.top) / r.height) - 0.5;
        requestForgeUpdate();
      });
      sticky.addEventListener('mouseleave', () => {
        mouseXTarget = 0;
        mouseYTarget = 0;
        requestForgeUpdate();
      });
    }
    updateForge();
  }

  // Scroll-scale headlines — grow as they approach centre of viewport
  const scaleEls = document.querySelectorAll<HTMLElement>('[data-scroll-scale]');
  if (scaleEls.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let scalePending = false;
    const updateScale = () => {
      const vh = window.innerHeight;
      scaleEls.forEach(el => {
        const rect = el.getBoundingClientRect();
        // 0 when element is well below viewport, 1 at centre, back to 0 above
        const centre = rect.top + rect.height / 2;
        const dist = Math.abs(centre - vh / 2) / vh; // 0..1+ where 0 is centred
        const t = Math.max(0, 1 - dist * 1.4);
        // Scale from 0.78 (off-centre) to 1 (centred)
        const s = 0.78 + t * 0.22;
        el.style.transform = `scale(${s.toFixed(3)})`;
      });
      scalePending = false;
    };
    window.addEventListener('scroll', () => {
      if (!scalePending) {
        scalePending = true;
        requestAnimationFrame(updateScale);
      }
    }, { passive: true });
    updateScale();
  }
</script>
