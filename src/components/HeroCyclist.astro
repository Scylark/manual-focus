---
/**
 * HeroCyclist — scroll-scrubbed Immersity drone-pass hero.
 *
 * Per the spec: scroll progress 0 → 1 drives the camera through the
 * arc. With Immersity producing the parallax as a pre-rendered MP4,
 * we get that by scrubbing the video's currentTime from 0 to duration
 * as the visitor scrolls through the hero section. No shaders, no
 * layer separation — just the animation Immersity already baked in,
 * driven by scroll instead of autoplay.
 *
 * Before scroll engages there's a subtle idle drift — the video
 * currentTime oscillates gently around the start frame so the hero
 * has life before the visitor scrolls. Once they scroll, the scroll
 * value takes over and the idle drift fades out.
 *
 * Reduced-motion holds the poster frame, no video plays.
 */
import { url } from '../utils/paths';

interface Props {
  video?: string;
  fallbackImage?: string;
}

const {
  video = '/images/hero-cyclist.mp4',
  fallbackImage = '/images/hero-cyclist.jpg',
} = Astro.props;

const videoUrl = url(video);
const fallbackUrl = url(fallbackImage);
---
<section class="hero-cyclist" data-hero-cyclist>
  <video
    class="hero-cyclist-video"
    src={videoUrl}
    poster={fallbackUrl}
    muted
    playsinline
    preload="auto"
    aria-hidden="true"
  ></video>

  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    z-index: 0;
    will-change: transform;
  }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }
  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }
  @media (max-width: 768px) {
    .hero-cyclist { min-height: 560px; }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }
</style>

<script>
  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;
    const video = section.querySelector<HTMLVideoElement>('.hero-cyclist-video');
    if (!video) return;

    // Reduced-motion: leave the poster as the visible frame, no playback.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      return;
    }

    // Pause the video so currentTime drives the frame — we'll set the
    // time ourselves from scroll and the idle drift loop. The poster
    // covers the first paint until the video metadata is loaded enough
    // to seek.
    video.pause();

    let duration = 0;
    let scrollProgress = 0;
    let lastInteraction = 0;       // timestamp of last scroll event
    let idleDriftActive = true;     // true until the visitor scrolls

    // Once the metadata is loaded we know how long the clip is and can
    // start setting currentTime. Until then leave the poster up.
    video.addEventListener('loadedmetadata', () => {
      duration = video.duration || 0;
    });

    // Map the section's scroll position to a 0..1 progress value.
    // 0 when the section top is at the viewport top, 1 when the
    // section's bottom edge hits the viewport top.
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const span = rect.height;
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / span));
      lastInteraction = performance.now();
      // First user scroll cancels the idle drift permanently — the
      // scroll position is now the source of truth.
      if (scrollProgress > 0.005 && idleDriftActive) idleDriftActive = false;
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    window.addEventListener('resize', updateScroll, { passive: true });
    updateScroll();

    // Pause render when off-screen so we're not pegging the seek
    // pipeline on long scrolling pages.
    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    function frame(now: number) {
      requestAnimationFrame(frame);
      if (!inView || duration <= 0) return;

      let target: number;
      if (idleDriftActive) {
        // Idle drift — gentle oscillation around the start of the clip
        // so the hero has life before the visitor scrolls. Uses about
        // 8% of the clip length, sinewaved over a 6-second period.
        const t = now / 1000;
        const driftFrac = (Math.sin(t * (Math.PI * 2 / 6)) + 1) * 0.5; // 0..1
        target = duration * 0.08 * driftFrac;
      } else {
        // Scroll-driven scrub. Smoothstep eased so the parallax
        // accelerates into the scroll rather than jerking on the
        // first pixel. Maps progress 0..1 across the full clip.
        const ease = scrollProgress * scrollProgress * (3 - 2 * scrollProgress);
        target = ease * duration;
      }

      // Only seek if the target moved meaningfully — saves the browser
      // from a stream of identical seeks per frame, which can hitch.
      if (Math.abs(video.currentTime - target) > 0.01) {
        video.currentTime = target;
      }
    }
    requestAnimationFrame(frame);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
