---
/**
 * HeroCyclist — depth-driven parallax hero where the cyclist stays
 * anchored and the background drifts around him.
 *
 * The conventional "drone pass" framing for a marketing hero locks
 * the subject as the focal point and animates the surroundings —
 * opposite to physical motion parallax (where closer things shift
 * more). Earlier attempts shifted the cyclist (depth × offset), which
 * sampled the colour texture from off the right edge of the frame and
 * visibly tore the rider apart.
 *
 * This version inverts that — shift = (1 - depth) × offset. The rider
 * (depth ~1) samples at the un-shifted UV and stays exactly where the
 * source IMG puts him. The sky and distant cliffs (depth ~0) shift
 * the full amount and produce the visible parallax read against the
 * anchored cyclist.
 *
 * MeshBasicMaterial + onBeforeCompile injects the UV shift into the
 * standard <map_fragment> chunk so Three.js's built-in sRGB pipeline
 * handles the colour pass — output matches the source IMG exactly.
 * Skipped on mobile and reduced-motion, which fall back to the IMG.
 */
import { url } from '../utils/paths';

interface Props {
  texture?: string;
  depthMap?: string;
  fallbackImage?: string;
  /**
   * UV-shift magnitude for the background (depth=0). 0.10 = max 10%
   * shift of the sky relative to the anchored cyclist at peak combined
   * scroll + drift. Tuned so the background drifts visibly without
   * sampling past the image edge on the left.
   */
  strength?: number;
  /** Idle drift on the background before the visitor scrolls. */
  autoplay?: boolean;
}

const {
  texture = '/images/hero-cyclist.webp',
  depthMap = '/images/hero-cyclist-depth.png',
  fallbackImage = '/images/hero-cyclist.jpg',
  strength = 0.10,
  autoplay = true,
} = Astro.props;

const textureUrl = url(texture);
const depthUrl = url(depthMap);
const fallbackUrl = url(fallbackImage);
---
<section
  class="hero-cyclist"
  data-hero-cyclist
  data-texture={textureUrl}
  data-depth={depthUrl}
  data-strength={String(strength)}
  data-autoplay={autoplay ? 'true' : 'false'}
>
  <img
    class="hero-cyclist-img"
    src={fallbackUrl}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <canvas class="hero-cyclist-canvas" aria-hidden="true"></canvas>
  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-img,
  .hero-cyclist-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-cyclist-img {
    z-index: 0;
    object-fit: cover;
    object-position: 65% center;
  }
  .hero-cyclist-canvas {
    z-index: 1;
    visibility: hidden;
  }
  .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-canvas { visibility: visible; }
  .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { visibility: hidden; }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }
  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }
  @media (max-width: 768px) {
    .hero-cyclist { min-height: 560px; }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }

  @media (prefers-reduced-motion: reduce), (max-width: 768px) {
    .hero-cyclist-canvas { display: none; }
    .hero-cyclist[data-webgl-ready="true"] .hero-cyclist-img { visibility: visible; }
  }
</style>

<script>
  import * as THREE from 'three';

  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;

    const skipWebGL =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      window.matchMedia('(hover: none) and (pointer: coarse)').matches ||
      window.matchMedia('(max-width: 768px)').matches;
    if (skipWebGL) {
      section.dataset.webglReady = 'true';
      return;
    }

    const canvas = section.querySelector<HTMLCanvasElement>('.hero-cyclist-canvas');
    if (!canvas) return;

    const textureUrl = section.dataset.texture!;
    const depthUrl = section.dataset.depth!;
    const strength = parseFloat(section.dataset.strength || '0.10');
    const autoplay = section.dataset.autoplay === 'true';

    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: false,
        antialias: true,
        powerPreference: 'high-performance',
      });
    } catch {
      section.dataset.webglReady = 'true';
      return;
    }
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    // Static camera + flat plane. All motion happens in the fragment
    // shader via the UV shift uniform.
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
    const baseZ = 1.6;
    camera.position.set(0, 0, baseZ);
    camera.lookAt(0, 0, 0);

    const geometry = new THREE.PlaneGeometry(1, 1, 1, 1);

    // MeshBasicMaterial + onBeforeCompile keeps Three.js's built-in
    // sRGB colour pipeline intact so the rendered output matches the
    // source IMG. Inject the depth-driven UV shift into the standard
    // <map_fragment> chunk.
    const depthUniform = { value: null as THREE.Texture | null };
    const offsetUniform = { value: new THREE.Vector2(0, 0) };
    const strengthUniform = { value: strength };
    const material = new THREE.MeshBasicMaterial({ map: null });
    material.onBeforeCompile = (shader) => {
      shader.uniforms.uDepth = depthUniform;
      shader.uniforms.uOffset = offsetUniform;
      shader.uniforms.uStrength = strengthUniform;

      shader.fragmentShader = shader.fragmentShader
        .replace(
          '#include <common>',
          `#include <common>
           uniform sampler2D uDepth;
           uniform vec2 uOffset;
           uniform float uStrength;`,
        )
        .replace(
          '#include <map_fragment>',
          `#ifdef USE_MAP
             // Anchor the cyclist, drift the background WITHOUT
             // duplicating him.
             //
             // The naïve (1 - depth) inverted parallax keeps the rider
             // pixels in place, but the sky pixels next to him still
             // shift — and a sky pixel just left of the rider sampled
             // through his silhouette returns the rider's colour, so
             // the rider appears duplicated to the left.
             //
             // Solution: only apply the shift when both the source
             // depth (current pixel) AND the shifted-target depth are
             // background. If shifting would land the sample on the
             // rider, fall back to the unshifted UV — the sky pixel
             // just holds still rather than copying the rider.
             float dHere = texture2D(uDepth, vMapUv).r;
             float bgHere = smoothstep(0.55, 0.45, dHere);

             vec2 wantShift = uOffset * uStrength;
             float dTarget = texture2D(uDepth, vMapUv + wantShift).r;
             float bgTarget = smoothstep(0.55, 0.45, dTarget);

             float bgMask = bgHere * bgTarget;
             vec2 shift = wantShift * bgMask;

             vec4 sampledDiffuseColor = texture2D(map, vMapUv + shift);
             diffuseColor *= sampledDiffuseColor;
           #endif`,
        );
    };

    const mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);

    function configureColor(t: THREE.Texture) {
      t.colorSpace = THREE.SRGBColorSpace;
      t.minFilter = THREE.LinearFilter;
      t.magFilter = THREE.LinearFilter;
      t.generateMipmaps = false;
      t.anisotropy = renderer.capabilities.getMaxAnisotropy();
      t.wrapS = THREE.ClampToEdgeWrapping;
      t.wrapT = THREE.ClampToEdgeWrapping;
      t.needsUpdate = true;
    }
    function configureDepth(t: THREE.Texture) {
      t.colorSpace = THREE.NoColorSpace;
      t.minFilter = THREE.LinearFilter;
      t.magFilter = THREE.LinearFilter;
      t.generateMipmaps = false;
      t.wrapS = THREE.ClampToEdgeWrapping;
      t.wrapT = THREE.ClampToEdgeWrapping;
      t.needsUpdate = true;
    }

    const loader = new THREE.TextureLoader();
    let loaded = 0;
    function onLoad() {
      if (++loaded < 2) return;
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          fitCanvas();
          renderer.render(scene, camera);
          section.dataset.webglReady = 'true';
          startLoop();
        });
      });
    }
    function onTexErr() {
      canvas.style.display = 'none';
    }
    loader.load(textureUrl, (t) => {
      configureColor(t);
      material.map = t;
      material.needsUpdate = true;
      onLoad();
    }, undefined, onTexErr);
    loader.load(depthUrl, (t) => {
      configureDepth(t);
      depthUniform.value = t;
      onLoad();
    }, undefined, onTexErr);

    const IMAGE_ASPECT = 1920 / 1080;
    function fitCanvas() {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      if (w <= 0 || h <= 0) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();

      const vFov = (camera.fov * Math.PI) / 180;
      const viewH = 2 * Math.tan(vFov / 2) * baseZ;
      const viewW = viewH * camera.aspect;
      const viewAspect = w / h;

      let planeW: number, planeH: number;
      if (viewAspect > IMAGE_ASPECT) {
        planeW = viewW;
        planeH = viewW / IMAGE_ASPECT;
      } else {
        planeH = viewH;
        planeW = viewH * IMAGE_ASPECT;
      }
      mesh.scale.set(planeW, planeH, 1);
    }
    const ro = new ResizeObserver(() => fitCanvas());
    ro.observe(canvas);

    let scrollProgress = 0;
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const span = rect.height;
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / span));
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();

    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    let frameId: number | null = null;
    function startLoop() {
      function frame(now: number) {
        if (inView) {
          const t = now / 1000;
          const ease = scrollProgress * scrollProgress * (3 - 2 * scrollProgress);
          // Scroll-driven sweep — the sky drifts left and dips down
          // slightly as the visitor scrolls through the hero, while the
          // cyclist stays anchored. Negative scrollX so the background
          // shifts LEFT (sky reveals what's to the right of itself),
          // which leaves the rider visually pushed RIGHT into the cliff —
          // the cinematic "world is moving past the rider" read.
          const scrollX = ease * -0.70;
          const scrollY = ease * 0.30;
          // Autoplay drift so the sky breathes before the visitor scrolls.
          const driftX = autoplay ? Math.sin(t * 0.25) * 0.35 : 0;
          const driftY = autoplay ? Math.cos(t * 0.19) * 0.20 : 0;
          offsetUniform.value.set(scrollX + driftX, scrollY + driftY);
          renderer.render(scene, camera);
        }
        frameId = requestAnimationFrame(frame);
      }
      frameId = requestAnimationFrame(frame);
    }

    window.addEventListener('pagehide', () => {
      if (frameId != null) cancelAnimationFrame(frameId);
      ro.disconnect();
      renderer.dispose();
      geometry.dispose();
      material.dispose();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
