---
/**
 * HeroCyclist — static illustration hero with optional CSS scroll parallax.
 *
 * Replaces the WebGL displacement experiment after several rounds of
 * rendering bugs. The IMG renders via the browser's native bicubic
 * scaling, which already looks sharp on every viewport. A subtle
 * transform: translateY drifts the image as the visitor scrolls,
 * giving the hero life without any shader complexity.
 *
 * The depth-displacement WebGL approach is parked, not abandoned —
 * the spec is still in /Users/jamesvickers/Downloads/manual-focus-hero-spec.md
 * and the cyclist + depth assets are in /public/images/. Worth coming
 * back to once the rest of the site is settled.
 */
import { url } from '../utils/paths';

interface Props {
  texture?: string;
  fallbackImage?: string;
  /** Pixels per scroll-pixel for the parallax drift. 0 disables. */
  parallax?: number;
}

const {
  texture = '/images/hero-cyclist.webp',
  fallbackImage = '/images/hero-cyclist.jpg',
  parallax = 0.15,
} = Astro.props;

const imageUrl = url(texture);
const fallbackUrl = url(fallbackImage);
---

<section class="hero-cyclist" data-hero-cyclist data-parallax-amount={String(parallax)}>
  <picture class="hero-cyclist-picture">
    <source srcset={imageUrl} type="image/webp" />
    <img
      class="hero-cyclist-img"
      src={fallbackUrl}
      alt=""
      aria-hidden="true"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </picture>

  <div class="hero-cyclist-overlay" aria-hidden="true"></div>

  <div class="hero-cyclist-content">
    <slot />
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    /* Section matches the image's 16:9 aspect so the IMG fills its
       natural shape. Capped at viewport height on tall monitors, floored
       at 540px on narrow mobile so it stays impactful. */
    aspect-ratio: 16 / 9;
    max-height: 100svh;
    min-height: 540px;
    overflow: hidden;
    background: var(--color-bg);
    isolation: isolate;
  }

  .hero-cyclist-picture {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    /* Slight overscale so the parallax translateY can drift without
       revealing the section edge. The amount matches the max drift. */
    width: 100%;
    height: 110%;
    top: -5%;
    /* will-change keeps the GPU compositor in charge of this transform
       on scroll, so the parallax stays smooth without paint churn. */
    will-change: transform;
  }

  .hero-cyclist-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    /* Soft left-side darkening so the headline reads on the dawn sky.
       Fades to clear by 65% so the cyclist on the right stays untouched. */
    background: linear-gradient(
      to right,
      rgba(15, 12, 8, 0.50) 0%,
      rgba(15, 12, 8, 0.22) 35%,
      transparent 65%
    );
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    color: #f6f0e8;
  }

  /* Pull slot child to the left half so the headline sits on the empty
     sky, not over the cyclist on the right. */
  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 55%;
  }
  @media (max-width: 900px) {
    .hero-cyclist-content > :global(*) { max-width: 100%; }
  }

  /* No parallax for reduced-motion. */
  @media (prefers-reduced-motion: reduce) {
    .hero-cyclist-picture {
      transform: none !important;
    }
  }
</style>

<script>
  function initParallax() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const picture = section.querySelector<HTMLElement>('.hero-cyclist-picture');
    if (!picture) return;

    const amount = parseFloat(section.dataset.parallaxAmount || '0');
    if (amount <= 0) return;

    let pending = false;
    function update() {
      const rect = section.getBoundingClientRect();
      // Drift the picture vertically by a fraction of how far the section
      // has been scrolled past the top of the viewport. Negative rect.top
      // = section has scrolled up. Multiply by the parallax amount.
      // The 5% top offset + 110% height in CSS gives ±5% headroom so the
      // drift never reveals the section edge.
      const shift = Math.max(-rect.height * 0.05, Math.min(rect.height * 0.05, -rect.top * amount));
      picture.style.transform = `translate3d(0, ${shift.toFixed(2)}px, 0)`;
      pending = false;
    }
    function onScroll() {
      if (!pending) {
        pending = true;
        requestAnimationFrame(update);
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initParallax);
  } else {
    initParallax();
  }
</script>
