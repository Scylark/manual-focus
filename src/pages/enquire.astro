---
import Base from '../layouts/Base.astro';
import SEOHead from '../components/SEOHead.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
---
<Base title="Enquire — Book a free 30-minute working session" description="Book a free 30-minute working session with Manual Focus. We'll talk through where you are, what you need, and which engagement tier makes sense.">
  <SEOHead slot="seo" type="website" title="Enquire — Book a free 30-minute working session" description="Book a free 30-minute working session with Manual Focus. We'll talk through where you are, what you need, and which engagement tier makes sense." breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Enquire', url: '/enquire' }]} />

  <section class="section">
    <div class="container">
      <h1>Let's talk</h1>
      <p class="lead">Book a 30-minute working session. We'll talk through where you are, what you need, and which engagement tier makes sense. If we click, we scope the work and start.</p>
      <EnquiryForm />
    </div>
  </section>
</Base>

<style>
  .lead {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-lg);
    max-width: var(--max-width-prose);
  }
</style>
