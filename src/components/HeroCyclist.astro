---
/**
 * HeroCyclist — scroll-driven image sequence hero, drawn to a canvas.
 *
 * Switching the visible <img>'s src on scroll causes a brief flash on
 * every browser because JPGs aren't decoded until they're actually
 * rendered — fast scrolling hides this, slow scrolling exposes it.
 *
 * The canonical fix (used by Apple's product pages) is a <canvas>:
 * decode each frame once with img.decode(), then on scroll just
 * drawImage() the matching frame. Canvas drawing is a synchronous
 * pixel blit, no decode-on-display step, no swap flash.
 *
 * Build-time: extract every 5th frame from hero-cyclist.mp4 at
 * 1280×720 JPG → /images/hero-frames/frame-001.jpg ... frame-060.jpg.
 *   ffmpeg -i hero-cyclist.mp4 -vf "select=not(mod(n\,5)),scale=1280:720" \
 *          -vsync vfr -q:v 4 hero-frames/frame-%03d.jpg
 *
 * Mobile + reduced-motion render the first frame and skip the
 * scroll-scrub loop entirely.
 */
import { url } from '../utils/paths';

interface Props {
  framesDir?: string;
  frameCount?: number;
  fallbackImage?: string;
}

const {
  framesDir = '/images/hero-frames',
  frameCount = 60,
  fallbackImage = '/images/hero-cyclist.jpg',
} = Astro.props;

const fallbackUrl = url(fallbackImage);
const framesDirUrl = url(framesDir);
const firstFrameUrl = url(`${framesDir}/frame-001.jpg`);
---
<section
  class="hero-cyclist"
  data-hero-cyclist
  data-frames-dir={framesDirUrl}
  data-frame-count={String(frameCount)}
>
  <div class="hero-cyclist-sticky">
    <!-- Poster image for first paint + reduced-motion + mobile.
         JS hides this once the canvas is rendering. -->
    <img
      class="hero-cyclist-poster"
      src={firstFrameUrl}
      alt=""
      aria-hidden="true"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <canvas
      class="hero-cyclist-canvas"
      aria-hidden="true"
      data-fallback={fallbackUrl}
    ></canvas>

    <div class="hero-cyclist-overlay" aria-hidden="true"></div>

    <div class="hero-cyclist-content">
      <slot />
    </div>
  </div>
</section>

<style>
  .hero-cyclist {
    position: relative;
    width: 100%;
    /* ~260vh of section gives ~160vh of pinned scroll distance for
       the canvas scrub. */
    height: 260vh;
    background: #1a1612;
    isolation: isolate;
  }

  .hero-cyclist-sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
  }

  .hero-cyclist-poster,
  .hero-cyclist-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-cyclist-poster {
    object-fit: cover;
    object-position: 65% center;
    z-index: 0;
  }

  .hero-cyclist-canvas {
    z-index: 1;
    /* Hidden until the canvas pipeline is up and rendering frames.
       JS flips this to visible once the first drawImage lands. */
    visibility: hidden;
  }

  .hero-cyclist[data-canvas-ready="true"] .hero-cyclist-canvas {
    visibility: visible;
  }
  .hero-cyclist[data-canvas-ready="true"] .hero-cyclist-poster {
    visibility: hidden;
  }

  .hero-cyclist-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(to right,
        rgba(15, 12, 8, 0.62) 0%,
        rgba(15, 12, 8, 0.30) 38%,
        rgba(15, 12, 8, 0.0) 60%),
      linear-gradient(to bottom,
        rgba(15, 12, 8, 0.35) 0%,
        rgba(15, 12, 8, 0.0) 22%,
        rgba(15, 12, 8, 0.0) 70%,
        rgba(15, 12, 8, 0.35) 100%);
  }

  .hero-cyclist-content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    height: 100%;
    display: flex;
    align-items: center;
    padding-inline: var(--space-md);
    padding-block: clamp(4rem, 9vh, 6.5rem);
    color: #f6f0e8;
  }

  .hero-cyclist-content > :global(*) {
    width: 100%;
    max-width: 58%;
  }
  @media (max-width: 1024px) {
    .hero-cyclist-content > :global(*) { max-width: 72%; }
  }

  @media (max-width: 768px), (hover: none) and (pointer: coarse) {
    .hero-cyclist { height: 100svh; min-height: 560px; }
    .hero-cyclist-sticky { position: relative; height: 100%; }
    .hero-cyclist-content > :global(*) { max-width: 100%; }
    .hero-cyclist-overlay {
      background:
        linear-gradient(to bottom,
          rgba(15, 12, 8, 0.55) 0%,
          rgba(15, 12, 8, 0.20) 35%,
          rgba(15, 12, 8, 0.45) 80%,
          rgba(15, 12, 8, 0.65) 100%);
    }
  }
</style>

<script>
  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero-cyclist]');
    if (!section) return;
    const canvas = section.querySelector<HTMLCanvasElement>('.hero-cyclist-canvas');
    if (!canvas) return;

    const skipScrub =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      window.matchMedia('(max-width: 768px)').matches ||
      window.matchMedia('(hover: none) and (pointer: coarse)').matches;
    if (skipScrub) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const framesDir = section.dataset.framesDir!;
    const frameCount = parseInt(section.dataset.frameCount || '60', 10);

    // Load + DECODE every frame. img.decode() is the bit that fixes
    // the flash on swap — it forces the browser to do the JPG decode
    // ahead of time, so drawImage just blits already-decoded pixels.
    const frames: HTMLImageElement[] = [];
    let loadedCount = 0;
    const promises: Promise<void>[] = [];
    for (let i = 1; i <= frameCount; i++) {
      const n = String(i).padStart(3, '0');
      const img = new Image();
      img.src = `${framesDir}/frame-${n}.jpg`;
      frames.push(img);
      promises.push(
        (img.decode ? img.decode() : new Promise((r) => {
          if (img.complete) r(undefined);
          else img.addEventListener('load', () => r(undefined), { once: true });
        }))
          .catch(() => {})
          .then(() => {
            loadedCount++;
          }),
      );
    }

    // Canvas sizing — backing-store resolution matches CSS box × DPR
    // so the rendered output isn't blurry on retina displays.
    function sizeCanvas() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      if (w <= 0 || h <= 0) return;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
    }
    const ro = new ResizeObserver(sizeCanvas);
    ro.observe(canvas);

    // CSS object-fit:cover + object-position:65% center, recreated in
    // drawImage with a source rect. Picks which slice of the frame to
    // blit so the canvas fills with no letterboxing and the rider
    // stays roughly where the poster has him.
    function drawCover(img: HTMLImageElement) {
      const cw = canvas.width;
      const ch = canvas.height;
      if (cw <= 0 || ch <= 0) return;
      const iw = img.naturalWidth || img.width;
      const ih = img.naturalHeight || img.height;
      if (iw <= 0 || ih <= 0) return;

      const canvasA = cw / ch;
      const imageA = iw / ih;
      let sx: number, sy: number, sw: number, sh: number;
      if (canvasA > imageA) {
        // Canvas wider than image — fill width, crop top/bottom.
        sw = iw;
        sh = iw / canvasA;
        sx = 0;
        sy = (ih - sh) * 0.5;
      } else {
        // Canvas taller than image — fill height, crop sides. Bias
        // toward x=0.65 to match the IMG's object-position.
        sh = ih;
        sw = ih * canvasA;
        sx = (iw - sw) * 0.65;
        sy = 0;
      }
      ctx!.drawImage(img, sx, sy, sw, sh, 0, 0, cw, ch);
    }

    // Track scroll progress.
    let scrollProgress = 0;
    function updateScroll() {
      const rect = section.getBoundingClientRect();
      const usefulSpan = Math.max(1, rect.height - window.innerHeight);
      const scrolled = -rect.top;
      scrollProgress = Math.max(0, Math.min(1, scrolled / usefulSpan));
    }
    window.addEventListener('scroll', updateScroll, { passive: true });
    window.addEventListener('resize', updateScroll, { passive: true });
    updateScroll();

    let inView = true;
    new IntersectionObserver(([entry]) => {
      inView = entry.isIntersecting;
    }, { threshold: 0 }).observe(section);

    // Wait for ALL frames to decode before showing the canvas — that
    // way the first paint is a complete, smooth scrub-ready hero.
    // Until then the poster image stays visible.
    Promise.all(promises).then(() => {
      sizeCanvas();
      drawCover(frames[0]);
      section.dataset.canvasReady = 'true';
      // Start RAF loop.
      let lastFrame = -1;
      function loop() {
        requestAnimationFrame(loop);
        if (!inView) return;
        const ease = scrollProgress * scrollProgress * (3 - 2 * scrollProgress);
        const idx = Math.min(frameCount - 1, Math.floor(ease * frameCount));
        if (idx !== lastFrame) {
          drawCover(frames[idx]);
          lastFrame = idx;
        }
      }
      requestAnimationFrame(loop);
    });

    window.addEventListener('pagehide', () => {
      ro.disconnect();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
